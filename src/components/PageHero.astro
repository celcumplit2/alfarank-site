---
type Props = {
  eyebrow?: string;
  title: string;
  text: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
};

const {
  eyebrow,
  title,
  text,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel
} = Astro.props;
---

<section class="page-hero">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1>{title}</h1>
  <p class="hero-text">{text}</p>
  {(primaryHref || secondaryHref) && (
    <div class="hero-actions">
      {primaryHref && <a class="button primary" href={primaryHref}>{primaryLabel}</a>}
      {secondaryHref && <a class="button secondary" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
  )}
</section>
