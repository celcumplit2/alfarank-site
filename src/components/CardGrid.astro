---
import SystemIcon from "@/components/SystemIcon.astro";

type Card = {
  title: string;
  summary: string;
  href?: string;
  icon?: string;
  tags?: string[];
};

type Props = {
  items: Card[];
  variant?: "standard" | "glyph";
};

const { items, variant = "glyph" } = Astro.props;

const glyphStyleFor = (icon?: string) => {
  if (["data", "monitor", "ranking"].includes(icon ?? "")) {
    return "diagonal";
  }

  if (icon === "commerce") {
    return "object";
  }

  return "bleed";
};
---

<div class:list={["card-grid", variant === "glyph" && "card-grid--glyph"]}>
  {items.map((item) => (
    <a
      class:list={[
        "glass-card",
        variant === "glyph" && "glass-card--glyph",
        variant === "glyph" && `glyph-${glyphStyleFor(item.icon)}`
      ]}
      href={item.href ?? "#"}
    >
      {variant === "glyph" ? (
        <>
          <div class="card-glyph" aria-hidden="true">
            <SystemIcon name={item.icon} />
          </div>
          <div class="card-content">
            <div class="card-main">
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </div>
            {item.tags && item.tags.length > 0 && (
              <div class="card-tags">
                {item.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
              </div>
            )}
          </div>
        </>
      ) : (
        <>
          <SystemIcon name={item.icon} />
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          {item.href && <span class="card-link">Open</span>}
        </>
      )}
    </a>
  ))}
</div>
