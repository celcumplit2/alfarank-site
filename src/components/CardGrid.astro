---
import SystemIcon from "@/components/SystemIcon.astro";

type Card = {
  title: string;
  summary: string;
  href?: string;
  icon?: string;
};

type Props = {
  items: Card[];
};

const { items } = Astro.props;
---

<div class="card-grid">
  {items.map((item) => (
    <a class="glass-card" href={item.href ?? "#"}>
      <SystemIcon name={item.icon} />
      <h3>{item.title}</h3>
      <p>{item.summary}</p>
      {item.href && <span class="card-link">Open</span>}
    </a>
  ))}
</div>
