---
import BrandLogo from "@/components/BrandLogo.astro";
import { alternatePaths, localeLabels, locales, localizePath, stripLocaleFromPath, t } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
  alternateLocales?: Locale[];
};

const { locale = "en", alternateLocales = [...locales] } = Astro.props;
const navItems = [
  { label: t(locale, "capabilities"), href: "/capabilities/" },
  { label: t(locale, "solutions"), href: "/solutions/" },
  { label: t(locale, "systems"), href: "/systems/" },
  { label: t(locale, "cases"), href: "/cases/" },
  { label: t(locale, "technologies"), href: "/technologies/" },
  { label: t(locale, "industries"), href: "/industries/" },
  { label: "News", href: "/news/", global: true },
  { label: t(locale, "about"), href: "/about/" }
].map((item) => ({ ...item, href: item.global ? item.href : localizePath(item.href, locale) }));

const homeHref = localizePath("/", locale);
const startProjectHref = localizePath("/start-project/", locale);
const activeAlternateLocales = alternateLocales.length > 0 ? alternateLocales : [...locales];
const activeAlternateLocaleSet = new Set<Locale>(activeAlternateLocales);
const languageLinks = alternatePaths(stripLocaleFromPath(Astro.url.pathname)).filter((item) =>
  activeAlternateLocaleSet.has(item.locale)
);
const languageNames: Record<Locale, string> = {
  en: "English",
  ro: "Romana",
  ru: "Русский"
};
---

<header class="site-header">
  <a class="brand" href={homeHref} aria-label={t(locale, "homeAria")}>
    <BrandLogo />
  </a>
  <nav class="site-nav desktop-nav" aria-label={t(locale, "primaryNavigation")}>
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
  <div class="header-actions">
    <details class="language-switcher" data-no-translate>
      <summary aria-label={t(locale, "language")}>
        <span>{localeLabels[locale]}</span>
        <span class="language-switcher__chevron" aria-hidden="true">▾</span>
      </summary>
      <div class="language-switcher__menu" role="list">
        {languageLinks.map((item) => (
          <a class:list={{ active: item.locale === locale }} href={item.href} aria-current={item.locale === locale ? "true" : undefined} role="listitem">
            <span>{localeLabels[item.locale]}</span>
            <small>{languageNames[item.locale]}</small>
          </a>
        ))}
      </div>
    </details>
    <a class="header-cta" href={startProjectHref}>{t(locale, "startProject")}</a>
  </div>
  <details class="mobile-menu">
    <summary>{t(locale, "menu")}</summary>
    <nav class="mobile-nav" aria-label={t(locale, "mobileNavigation")}>
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <details class="language-switcher mobile-language-switcher" data-no-translate>
        <summary aria-label={t(locale, "language")}>
          <span>{localeLabels[locale]}</span>
          <span class="language-switcher__chevron" aria-hidden="true">▾</span>
        </summary>
        <div class="language-switcher__menu" role="list">
          {languageLinks.map((item) => (
            <a class:list={{ active: item.locale === locale }} href={item.href} aria-current={item.locale === locale ? "true" : undefined} role="listitem">
              <span>{localeLabels[item.locale]}</span>
              <small>{languageNames[item.locale]}</small>
            </a>
          ))}
        </div>
      </details>
      <a class="mobile-cta" href={startProjectHref}>{t(locale, "startProject")}</a>
    </nav>
  </details>
</header>
