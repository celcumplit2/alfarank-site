---
import { localizePath, t } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div>
    <strong>AlfaRank</strong>
    <p>{t(locale, "footerText")}</p>
  </div>
  <div class="footer-links">
    <a href={localizePath("/capabilities/", locale)}>{t(locale, "capabilities")}</a>
    <a href={localizePath("/solutions/", locale)}>{t(locale, "solutions")}</a>
    <a href={localizePath("/systems/", locale)}>{t(locale, "systems")}</a>
    <a href={localizePath("/start-project/", locale)}>{t(locale, "startProject")}</a>
  </div>
  <span class="footer-meta">&copy; {year} AlfaRank</span>
</footer>
