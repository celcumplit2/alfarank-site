---
import BrandLogo from "@/components/BrandLogo.astro";
import ContactChannels from "@/components/ContactChannels.astro";
import { getCapabilities, getSolutions, localizePath, t } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;
const year = new Date().getFullYear();

const footerCopy = {
  en: {
    brandNote: "Digital systems, automation, content infrastructure, web platforms, and data workflows for practical business operations.",
    coreLabel: "Sitemap core",
    coreState: "Routes online",
    navigation: "Site map",
    capabilities: "Build directions",
    routes: "Solution routes",
    standard: "Standard pages",
    company: "Company data",
    contacts: "Direct channels",
    contactNote: "Fast channel for project context and partner introductions.",
    legalName: "Legal name",
    idno: "IDNO",
    registered: "Registered",
    office: "Registered office",
    jurisdiction: "Jurisdiction",
    copyright: "All rights reserved."
  },
  ro: {
    brandNote: "Sisteme digitale, automatizare, infrastructura de continut, platforme web si fluxuri de date pentru operatiuni de business.",
    coreLabel: "Nucleu sitemap",
    coreState: "Rute active",
    navigation: "Harta site",
    capabilities: "Directii de build",
    routes: "Rute de solutii",
    standard: "Pagini standard",
    company: "Date companie",
    contacts: "Canale directe",
    contactNote: "Canal rapid pentru context de proiect si introduceri de parteneri.",
    legalName: "Denumire juridica",
    idno: "IDNO",
    registered: "Inregistrare",
    office: "Sediu inregistrat",
    jurisdiction: "Jurisdictie",
    copyright: "Toate drepturile rezervate."
  },
  ru: {
    brandNote: "Цифровые системы, автоматизация, контентная инфраструктура, веб-платформы и процессы данных для бизнес-операций.",
    coreLabel: "Ядро карты",
    coreState: "Маршруты активны",
    navigation: "Карта сайта",
    capabilities: "Направления работ",
    routes: "Маршруты решений",
    standard: "Стандартные страницы",
    company: "Данные компании",
    contacts: "Прямые каналы",
    contactNote: "Быстрый канал для проектного контекста и партнерских интро.",
    legalName: "Юридическое имя",
    idno: "IDNO",
    registered: "Регистрация",
    office: "Юридический адрес",
    jurisdiction: "Юрисдикция",
    copyright: "Все права защищены."
  }
}[locale];

const navigationLinks = [
  { label: t(locale, "capabilities"), href: "/capabilities/" },
  { label: t(locale, "solutions"), href: "/solutions/" },
  { label: t(locale, "systems"), href: "/systems/" },
  { label: t(locale, "technologies"), href: "/technologies/" },
  { label: t(locale, "industries"), href: "/industries/" },
  { label: t(locale, "about"), href: "/about/" }
].map((item) => ({ ...item, href: localizePath(item.href, locale) }));

const capabilitySlugs = [
  "ai-automation",
  "web-product-development",
  "seo-content-infrastructure",
  "data-systems-scraping",
  "ecommerce-systems",
  "wordpress-api-integrations"
];

const solutionSlugs = [
  "automate-lead-processing",
  "upgrade-existing-website",
  "generate-more-content",
  "scale-seo-infrastructure",
  "build-data-monitoring-system",
  "launch-digital-product"
];

const capabilityMap = new Map(getCapabilities(locale).map((item) => [item.slug, item]));
const solutionMap = new Map(getSolutions(locale).map((item) => [item.slug, item]));

const capabilityLinks = capabilitySlugs
  .map((slug) => capabilityMap.get(slug))
  .filter(Boolean)
  .map((item) => ({ label: item!.title, href: localizePath(`/capabilities/${item!.slug}/`, locale) }));

const solutionLinks = solutionSlugs
  .map((slug) => solutionMap.get(slug))
  .filter(Boolean)
  .map((item) => ({ label: item!.title, href: localizePath(`/solutions/${item!.slug}/`, locale) }));

const routeLinks = [
  { label: "ALFA Pulse", href: localizePath("/alfa-pulse/", locale) },
  { label: t(locale, "startProject"), href: localizePath("/start-project/", locale) },
  { label: t(locale, "partnerProgram"), href: localizePath("/partner-program/", locale) }
];

const standardLinks = [
  { label: locale === "ru" ? "Новости" : locale === "ro" ? "Stiri" : "News", href: localizePath("/news/", locale) },
  {
    label: locale === "ru" ? "Редакционная политика" : locale === "ro" ? "Politica editoriala" : "Editorial Policy",
    href: localizePath("/news/editorial-policy/", locale)
  },
  { label: locale === "ru" ? "Контакты" : locale === "ro" ? "Contact" : "Contact", href: localizePath("/contact/", locale) },
  { label: locale === "ru" ? "Конфиденциальность" : locale === "ro" ? "Confidentialitate" : "Privacy Policy", href: localizePath("/privacy-policy/", locale) },
  { label: locale === "ru" ? "Условия" : locale === "ro" ? "Termeni" : "Terms", href: localizePath("/terms-and-conditions/", locale) },
  { label: locale === "ru" ? "Куки" : locale === "ro" ? "Cookies" : "Cookies", href: localizePath("/cookie-policy/", locale) },
  { label: locale === "ru" ? "Карта сайта" : locale === "ro" ? "Harta site" : "Sitemap", href: localizePath("/sitemap/", locale) }
];

const companyDetails = [
  { label: footerCopy.legalName, value: ["Societatea cu Răspundere Limitată", '"ALFA RANK"'] },
  { label: footerCopy.idno, value: "1019600054378" },
  { label: footerCopy.registered, value: "2019-11-19" },
  { label: footerCopy.office, value: "str. Nicolae Dimo 4/1, MD-2068 Chisinau" },
  { label: footerCopy.jurisdiction, value: "Republic of Moldova" }
];

const footerNodes = [
  { title: footerCopy.navigation, className: "footer-orbit-node--map", links: navigationLinks },
  { title: footerCopy.capabilities, className: "footer-orbit-node--capabilities", links: capabilityLinks },
  { title: footerCopy.routes, className: "footer-orbit-node--routes", links: [...routeLinks, ...solutionLinks.slice(0, 2)] },
  { title: footerCopy.standard, className: "footer-orbit-node--standard", links: standardLinks }
];
---

<footer class="site-footer site-footer--orbit">
  <div class="footer-orbit-field" aria-hidden="true">
    <svg viewBox="0 0 1180 620" preserveAspectRatio="none">
      <ellipse class="footer-orbit footer-orbit--outer" cx="585" cy="302" rx="520" ry="214" />
      <ellipse class="footer-orbit footer-orbit--middle" cx="620" cy="306" rx="438" ry="158" />
      <ellipse class="footer-orbit footer-orbit--inner" cx="520" cy="312" rx="306" ry="104" />
      <path class="footer-route footer-route--solid" d="M274 266 C 408 128, 760 126, 952 250" />
      <path class="footer-route footer-route--dash" d="M264 368 C 440 496, 792 480, 1004 336" />
      <path class="footer-route footer-route--fine" d="M188 320 C 356 246, 770 210, 1088 278" />
      <circle class="footer-route-dot" cx="274" cy="266" r="5" />
      <circle class="footer-route-dot" cx="952" cy="250" r="5" />
      <circle class="footer-route-dot" cx="1004" cy="336" r="5" />
      <circle class="footer-route-dot" cx="540" cy="414" r="4" />
    </svg>
  </div>

  <section class="footer-orbit-core">
    <a class="footer-brand" href={localizePath("/", locale)} aria-label={t(locale, "homeAria")}>
      <BrandLogo class="brand-logo--footer" />
    </a>
    <span>{footerCopy.coreLabel}</span>
    <h2>{footerCopy.navigation}</h2>
    <p>{footerCopy.brandNote}</p>
    <div class="footer-orbit-core__actions">
      <a class="footer-cta" href={localizePath("/start-project/", locale)}>{t(locale, "startProject")}</a>
      <a class="footer-mini-link" href={localizePath("/partner-program/", locale)}>{t(locale, "partnerProgram")}</a>
    </div>
    <small><i></i>{footerCopy.coreState}</small>
  </section>

  {footerNodes.map((node) => (
    <nav class:list={["footer-orbit-node", node.className]} aria-label={node.title}>
      <h2>{node.title}</h2>
      <div class="footer-links">
        {node.links.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </nav>
  ))}

  <section class="footer-orbit-node footer-orbit-node--company" aria-labelledby="footer-company-title">
    <h2 id="footer-company-title">{footerCopy.company}</h2>
    <dl class="footer-company__grid">
      {companyDetails.map((item) => (
        <div class="footer-company__item">
          <dt>{item.label}</dt>
          <dd class="notranslate" data-no-translate translate="no">
            {Array.isArray(item.value) ? item.value.map((line) => <span>{line}</span>) : item.value}
          </dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="footer-orbit-node footer-orbit-node--contact" aria-label={footerCopy.contacts}>
    <h2>{footerCopy.contacts}</h2>
    <p>{footerCopy.contactNote}</p>
    <ContactChannels locale={locale} variant="footer" />
  </section>

  <div class="footer-meta">
    <span>&copy; {year} AlfaRank</span>
    <nav aria-label={footerCopy.standard}>
      {standardLinks.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <span>{footerCopy.copyright}</span>
  </div>
</footer>
