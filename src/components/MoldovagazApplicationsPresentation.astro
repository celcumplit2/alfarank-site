const contentLocale = locale === "ro" ? "ro" : locale === "ru" ? "ru" : "en";
const copy = localizedCopy[contentLocale];
const alternateLocales: Locale[] = ["en", "ro", "ru"];
const { assumptions, needFromClient, overview, riskBlocks, timeline, visualNodes, workBlocks } = copy;
---

<Layout
  title={copy.metaTitle}
  description={copy.metaDescription}
  locale={locale}
  alternateLocales={alternateLocales}
  robots="noindex, nofollow"
>
  <div class="mgas-brief-page" data-no-translate>
    <section class="mgas-brief-hero">
      <div class="mgas-brief-hero__copy">
        <p class="eyebrow">{copy.heroEyebrow}</p>
        <h1>{copy.heroTitle}</h1>
        <p>{copy.heroText}</p>
        <div class="mgas-brief-actions" aria-label={copy.navAria}>
          <a href="#summary">{copy.nav.summary}</a>
          <a href="#timeline">{copy.nav.timeline}</a>
          <a href="#work">{copy.nav.work}</a>
        </div>
      </div>
      <div class="mgas-brief-flow" aria-label={copy.flowAria}>
        {visualNodes.map((node, index) => (
          <div class="mgas-brief-flow__node">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{node.label}</strong>
            <small>{node.note}</small>
          </div>
        ))}
      </div>
    </section>

    <section class="mgas-brief-section" id="summary">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">{copy.summaryEyebrow}</p>
        <h2>{copy.summaryTitle}</h2>
        <p>{copy.summaryText}</p>
      </div>
      <div class="mgas-summary-grid">
        {overview.map((item) => (
          <article class="mgas-summary-item">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mgas-brief-section" id="timeline">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">{copy.timelineEyebrow}</p>
        <h2>{copy.timelineTitle}</h2>
        <p>{copy.timelineText}</p>
      </div>
      <div class="mgas-timeline-grid">
        {timeline.map((item, index) => (
          <article class="mgas-timeline-card">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>
              {Array.isArray(item.name) ? item.name.map((line) => <span>{line}</span>) : item.name}
            </h3>
            <dl>
              <div>
                <dt>{copy.termLabel}</dt>
                <dd>{item.time}</dd>
              </div>
              <div>
                <dt>{copy.budgetLabel}</dt>
                <dd>{item.cost}</dd>
              </div>
            </dl>
            <p>{item.scope}</p>
          </article>
        ))}
      </div>
      <div class="mgas-note-band">
        <strong>{copy.recommendedLabel}</strong>
        <p>{copy.recommendedText}</p>
      </div>
    </section>

    <section class="mgas-brief-section" id="work">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">{copy.workEyebrow}</p>
        <h2>{copy.workTitle}</h2>
        <p>{copy.workText}</p>
      </div>
      <div class="mgas-details-list">
        {workBlocks.map((block, index) => (
          <details class="mgas-detail" open={index === 0}>
            <summary>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{block.title}</strong>
              <small>{block.short}</small>
            </summary>
            <div class="mgas-detail__body">
              <p><b>{copy.resultLabel}</b> {block.result}</p>
              <ul>
                {block.details.map((detail) => <li>{detail}</li>)}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="mgas-brief-section" id="risks">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">{copy.risksEyebrow}</p>
        <h2>{copy.risksTitle}</h2>
        <p>{copy.risksText}</p>
      </div>
      <div class="mgas-details-list mgas-details-list--two">
        {riskBlocks.map((block) => (
          <details class="mgas-detail">
            <summary>
              <strong>{block.title}</strong>
              <small>{block.text}</small>
            </summary>
            <div class="mgas-detail__body">
              <ul>
                {block.checks.map((check) => <li>{check}</li>)}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="mgas-brief-section" id="assumptions">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">{copy.assumptionsEyebrow}</p>
        <h2>{copy.assumptionsTitle}</h2>
        <p>{copy.assumptionsText}</p>
      </div>
      <ul class="mgas-check-list">
        {assumptions.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="mgas-brief-section" id="client-input">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">{copy.clientInputEyebrow}</p>
        <h2>{copy.clientInputTitle}</h2>
        <p>{copy.clientInputText}</p>
      </div>
      <ul class="mgas-check-list mgas-check-list--columns">
        {needFromClient.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  </div>
</Layout>

