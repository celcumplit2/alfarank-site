---
import Layout from "@/layouts/Layout.astro";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "ru" } = Astro.props;

const overview = [
  {
    label: "Что предлагается",
    value: "Цифровой модуль вокруг 1C/ERP",
    text: "Заявления остаются в основной учетной системе, а новый модуль показывает статус клиенту, контролирует сроки и помогает руководству видеть ситуацию."
  },
  {
    label: "Срок первого запуска",
    value: "До 16 недель",
    text: "Ориентир относится к первому рабочему запуску после согласования объема: клиентская проверка статуса, связь с 1C/ERP, сроки, уведомления и панель контроля."
  },
  {
    label: "Бюджет первого запуска",
    value: "До 110 000 EUR",
    text: "Это верхняя предварительная оценка для обсуждения. После обследования объем можно уточнить и при необходимости уменьшить без потери логики запуска."
  }
];

const workBlocks = [
  {
    title: "1. Обследование текущего процесса",
    short: "Фиксируем, как заявление проходит путь от подачи до результата.",
    result: "Согласованная карта процесса, список услуг, статусов, сроков, ролей и данных.",
    details: [
      "разобрать виды заявлений и услуг Единого окна;",
      "описать текущие этапы обработки заявления;",
      "собрать нормативные и внутренние сроки по услугам;",
      "определить роли: клиент, оператор, подразделение, руководитель, администратор;",
      "согласовать, какие данные можно показывать клиенту, а какие остаются внутренними."
    ]
  },
  {
    title: "2. Связь с 1C/ERP",
    short: "Новый модуль должен получать данные из существующей учетной системы.",
    result: "Заявления, статусы, счета, оплаты и ключевые события автоматически поступают в новый модуль.",
    details: [
      "проверить, какие данные уже есть в 1C/ERP и насколько они заполнены;",
      "согласовать способ обмена данными: API, веб-сервис, регламентный обмен или другой доступный механизм;",
      "настроить получение новых заявлений и изменений по ним;",
      "предусмотреть работу при временной недоступности 1C/ERP;",
      "вести журнал ошибок обмена, чтобы сбои не оставались незамеченными."
    ]
  },
  {
    title: "3. Карточка заявления",
    short: "Каждое заявление получает единую цифровую карточку.",
    result: "По каждому заявлению видно номер, услугу, статус, срок, ответственный блок, документы, оплату, историю и результат.",
    details: [
      "собрать основные данные заявления в одной структуре;",
      "разделить внутренний статус и публичный статус для клиента;",
      "хранить историю изменений и отправленных уведомлений;",
      "показывать причину остановки, отказа или снятия заявки;",
      "оставить ручное заполнение только для исключений: причина задержки, недостающие документы, дата выезда."
    ]
  },
  {
    title: "4. Страница проверки статуса для клиента",
    short: "Клиент проверяет заявление без звонка и визита.",
    result: "На сайте появляется страница проверки статуса по номеру заявления, телефону и одноразовому коду.",
    details: [
      "сделать раздел на сайте: Проверить статус заявления;",
      "добавить вход по номеру заявления и телефону с одноразовым кодом;",
      "добавить QR-код на подтверждении или квитанции;",
      "показать клиенту текущий этап, дату регистрации, последнее обновление, оставшиеся рабочие дни и следующее действие;",
      "сделать интерфейс на русском и румынском языках, удобный для телефона."
    ]
  },
  {
    title: "5. Статусы и контроль сроков",
    short: "Система считает сроки и заранее показывает риск просрочки.",
    result: "У каждого заявления есть контрольная дата, остаток рабочих дней, статус срока и причина остановки срока.",
    details: [
      "настроить правила сроков для каждого вида услуги;",
      "учитывать рабочие, выходные и праздничные дни;",
      "останавливать срок, когда ожидается действие клиента: документы, оплата, доступ к объекту;",
      "выделять заявления по цветам: в срок, риск, последний день, просрочено, срок остановлен;",
      "показывать руководителям заявления без движения и заявления с риском нарушения срока."
    ]
  },
  {
    title: "6. Уведомления клиентам и сотрудникам",
    short: "Сообщения отправляются по событиям, а не только после обращения клиента.",
    result: "Клиент получает понятные уведомления, а сотрудники и руководители получают предупреждения по срокам.",
    details: [
      "подготовить шаблоны сообщений на русском и румынском языках;",
      "отправлять уведомления о регистрации, счете, оплате, недостающих документах, готовности или снятии заявки;",
      "напоминать клиенту до снятия заявки с исполнения;",
      "предупреждать исполнителя до контрольного срока;",
      "уведомлять руководителя, если заявление перешло в риск или просрочку."
    ]
  },
  {
    title: "7. Панель руководителя и отчеты",
    short: "Руководство видит не отдельные звонки, а полную картину процесса.",
    result: "Появляется панель с активными заявлениями, рисками, просрочками, нагрузкой и причинами задержек.",
    details: [
      "сделать общий обзор: активные, в срок, в риске, просрочены, ждут клиента, завершены;",
      "добавить реестр заявлений с поиском, фильтрами и выгрузкой;",
      "показать контроль по подразделениям и типам услуг;",
      "собирать причины задержек, отказов и снятия заявок;",
      "показывать показатели: средний срок исполнения, доля заявлений в срок, заявления без движения."
    ]
  },
  {
    title: "8. Безопасность и доказательная база",
    short: "Система должна защищать данные и фиксировать каждое важное действие.",
    result: "Доступ клиента защищен кодом, права сотрудников разделены по ролям, история действий сохраняется.",
    details: [
      "проверять доступ клиента через номер заявления, телефон и одноразовый код;",
      "не показывать лишние персональные данные и внутренние комментарии;",
      "разделить права сотрудников по ролям и подразделениям;",
      "фиксировать изменения статусов, отправку уведомлений, причины задержек и снятие заявки;",
      "предусмотреть резервное копирование, контроль сессий и журнал ошибок."
    ]
  }
];

const riskBlocks = [
  {
    title: "Данные в 1C/ERP",
    text: "Сложность зависит от того, насколько аккуратно в 1C ведутся заявления, статусы, телефоны, счета, оплаты и подразделения.",
    checks: [
      "есть ли готовый способ обмена данными;",
      "одинаково ли заполняются поля разными сотрудниками;",
      "можно ли получить не только текущий статус, но и события по заявлению."
    ]
  },
  {
    title: "Карта статусов",
    text: "Внутренние статусы могут быть понятны сотрудникам, но слишком техническими для клиента.",
    checks: [
      "нужно согласовать публичные формулировки;",
      "каждый внутренний этап должен попадать в понятный статус для клиента;",
      "для спорных ситуаций нужны правила: что показывать, а что оставить внутри компании."
    ]
  },
  {
    title: "Сроки и остановка срока",
    text: "Система должна считать не календарные дни, а рабочие дни с учетом праздников и случаев, когда срок остановлен из-за действий клиента.",
    checks: [
      "нужен утвержденный календарь рабочих и нерабочих дней;",
      "по каждой услуге должен быть понятен нормативный срок;",
      "нужно определить события, которые останавливают и возобновляют срок."
    ]
  },
  {
    title: "Уведомления",
    text: "Сообщение должно уходить в правильный момент, по правильному каналу и с юридически аккуратной формулировкой.",
    checks: [
      "нужен выбранный поставщик SMS/Viber/e-mail;",
      "шаблоны должны быть согласованы на русском и румынском языках;",
      "каждое отправленное сообщение должно сохраняться в истории заявления."
    ]
  },
  {
    title: "Персональные данные",
    text: "Клиентская страница не должна раскрывать лишнюю информацию даже при наличии номера заявления.",
    checks: [
      "доступ только через подтверждение телефона;",
      "QR-код не должен сразу открывать персональные данные;",
      "сотрудники должны видеть только те заявления, которые относятся к их роли."
    ]
  },
  {
    title: "Привычки сотрудников",
    text: "Проект успешен только если он не создает параллельный учет и не увеличивает ручную работу.",
    checks: [
      "основная работа остается в 1C/ERP;",
      "ручной ввод нужен только для исключений;",
      "руководство получает контроль без дополнительных отчетов от сотрудников."
    ]
  }
];

const timeline = [
  {
    name: "Предпроектное обследование",
    time: "до 3 недель",
    cost: "до 10 000 EUR",
    scope: "анализ процессов, данных, статусов, сроков, ролей, уведомлений и доступного обмена с 1C/ERP"
  },
  {
    name: "Первый рабочий запуск",
    time: "до 16 недель",
    cost: "до 110 000 EUR",
    scope: "клиентский модуль, статусы, сроки, уведомления, панель руководителя, роли, журнал действий, базовые отчеты"
  }
];

const assumptions = [
  "1C/ERP остается основной системой учета заявлений.",
  "Стоимость сообщений SMS/Viber/e-mail оплачивается отдельно по тарифам поставщика.",
  "Если для 1C/ERP потребуется доработка со стороны их подрядчика, она оценивается отдельно.",
  "Точная стоимость фиксируется после обследования данных, статусов и правил сроков.",
  "Первый запуск лучше делать на ограниченном перечне услуг, затем расширять систему."
];

const needFromClient = [
  "список видов заявлений и услуг Единого окна;",
  "текущие статусы и этапы обработки в 1C/ERP;",
  "нормативные и внутренние сроки по каждому виду услуги;",
  "описание, какие подразделения участвуют в обработке;",
  "примеры заявлений, счетов, уведомлений и писем о снятии заявки;",
  "информация о доступном способе обмена данными с 1C/ERP;",
  "требования по персональным данным, ролям и доступам;",
  "предпочтительные каналы уведомлений: SMS, Viber, e-mail."
];

const visualNodes = [
  { label: "1C/ERP", note: "источник данных" },
  { label: "Модуль статусов", note: "правила и сроки" },
  { label: "Сайт", note: "статус для клиента" },
  { label: "Уведомления", note: "SMS, Viber, e-mail" },
  { label: "Панель", note: "контроль и отчеты" }
];
---

<Layout
  title="Цифровизация заявлений Chișinău-Gaz | AlfaRank"
  description="Клиентское обоснование проекта цифровизации подачи, мониторинга и контроля заявлений Единого окна Chișinău-Gaz."
  locale={locale}
  robots="noindex, nofollow"
>
  <div class="mgas-brief-page" data-no-translate>
    <section class="mgas-brief-hero">
      <div class="mgas-brief-hero__copy">
        <p class="eyebrow">SRL Chișinău-Gaz · Единое окно</p>
        <h1>Цифровизация подачи и мониторинга заявлений</h1>
        <p>
          Предлагается создать цифровой модуль, который не заменяет 1C/ERP, а делает путь заявления
          прозрачным для клиента и управляемым для руководства.
        </p>
        <div class="mgas-brief-actions" aria-label="Навигация по странице">
          <a href="#summary">Что предлагается</a>
          <a href="#timeline">Сроки и бюджет</a>
          <a href="#work">Состав работ</a>
        </div>
      </div>
      <div class="mgas-brief-flow" aria-label="Общая схема решения">
        {visualNodes.map((node, index) => (
          <div class="mgas-brief-flow__node">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{node.label}</strong>
            <small>{node.note}</small>
          </div>
        ))}
      </div>
    </section>

    <section class="mgas-brief-section" id="summary">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">Кратко</p>
        <h2>Что предлагается</h2>
        <p>
          Система должна убрать ситуацию, когда заявление принято, но клиент не понимает, где оно находится,
          а руководство видит проблему только после звонков, жалоб или просрочки.
        </p>
      </div>
      <div class="mgas-summary-grid">
        {overview.map((item) => (
          <article class="mgas-summary-item">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mgas-brief-section" id="timeline">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">Сроки и бюджет</p>
        <h2>Ориентировочная оценка</h2>
        <p>
          Оценка указана как верхний ориентир для первого рабочего запуска. После обследования можно
          уточнить состав работ и уменьшить бюджет, если часть интеграций или процессов окажется проще.
        </p>
      </div>
      <div class="mgas-timeline-grid">
        {timeline.map((item, index) => (
          <article class="mgas-timeline-card">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.name}</h3>
            <dl>
              <div>
                <dt>Срок</dt>
                <dd>{item.time}</dd>
              </div>
              <div>
                <dt>Бюджет</dt>
                <dd>{item.cost}</dd>
              </div>
            </dl>
            <p>{item.scope}</p>
          </article>
        ))}
      </div>
      <div class="mgas-note-band">
        <strong>Рекомендуемый вариант:</strong>
        <p>
          сначала провести обследование до 3 недель, затем согласовать первый рабочий запуск до 16 недель
          с бюджетом до 110 000 EUR. Это оставляет пространство уточнить стоимость после проверки данных и правил в 1C/ERP.
        </p>
      </div>
    </section>

    <section class="mgas-brief-section" id="work">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">Состав работ</p>
        <h2>Что нужно сделать</h2>
        <p>
          Ниже перечислены основные блоки проекта. Каждый блок можно раскрыть и увидеть, какие работы
          требуется выполнить и какой результат должен получить заказчик.
        </p>
      </div>
      <div class="mgas-details-list">
        {workBlocks.map((block, index) => (
          <details class="mgas-detail" open={index === 0}>
            <summary>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{block.title}</strong>
              <small>{block.short}</small>
            </summary>
            <div class="mgas-detail__body">
              <p><b>Результат:</b> {block.result}</p>
              <ul>
                {block.details.map((detail) => <li>{detail}</li>)}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="mgas-brief-section" id="risks">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">Сложные места</p>
        <h2>Где потребуется внимание</h2>
        <p>
          Основная сложность проекта не в самой странице проверки статуса, а в корректности данных,
          правил сроков, уведомлений и ответственности между подразделениями.
        </p>
      </div>
      <div class="mgas-details-list mgas-details-list--two">
        {riskBlocks.map((block) => (
          <details class="mgas-detail">
            <summary>
              <strong>{block.title}</strong>
              <small>{block.text}</small>
            </summary>
            <div class="mgas-detail__body">
              <ul>
                {block.checks.map((check) => <li>{check}</li>)}
              </ul>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="mgas-brief-section" id="assumptions">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">Условия оценки</p>
        <h2>Что включено в допущения</h2>
        <p>
          Эти условия важно проговорить до коммерческого предложения, чтобы бюджет не воспринимался как
          стоимость любых будущих расширений.
        </p>
      </div>
      <ul class="mgas-check-list">
        {assumptions.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="mgas-brief-section" id="client-input">
      <div class="mgas-brief-section__head">
        <p class="eyebrow">Что нужно от заказчика</p>
        <h2>Данные для точной оценки</h2>
        <p>
          После получения этих материалов можно подготовить точную архитектуру, календарный план и фиксированный
          состав первого запуска.
        </p>
      </div>
      <ul class="mgas-check-list mgas-check-list--columns">
        {needFromClient.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  </div>
</Layout>

<style>
  .mgas-brief-page {
    --mgas-surface: rgba(5, 22, 43, 0.82);
    --mgas-surface-strong: rgba(8, 34, 58, 0.92);
    --mgas-line: rgba(190, 230, 255, 0.22);
    --mgas-line-strong: rgba(216, 251, 255, 0.38);
    --mgas-text: #f6fbff;
    --mgas-muted: rgba(238, 248, 255, 0.76);
    --mgas-faint: rgba(238, 248, 255, 0.58);
    --mgas-accent: #8de9ff;
    --mgas-good: #8ff0b3;
    --mgas-warn: #ffd166;
    width: min(1280px, calc(100vw - 32px));
    margin: 0 auto clamp(72px, 8vw, 118px);
    color: var(--mgas-text);
  }

  .mgas-brief-page :where(h1, h2, h3, p, li, summary, a, span, strong, small, dd, dt) {
    letter-spacing: 0;
    overflow-wrap: break-word;
    word-break: normal;
    hyphens: none;
  }

  .mgas-brief-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(360px, 0.72fr);
    gap: clamp(22px, 4vw, 56px);
    align-items: stretch;
    min-height: 520px;
    margin-bottom: clamp(58px, 7vw, 96px);
    padding: clamp(28px, 5vw, 64px);
    border: 1px solid var(--mgas-line);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgba(10, 47, 78, 0.9), rgba(4, 19, 37, 0.9)),
      var(--mgas-surface);
