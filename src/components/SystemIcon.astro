---
type Props = {
  name?: string;
};

const { name = "system" } = Astro.props;

const common = {
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
  "vector-effect": "non-scaling-stroke"
} as const;
---

<span class="system-icon" aria-hidden="true" data-icon={name}>
  <svg viewBox="0 0 64 64" role="img">
    <rect class="icon-glass" x="6" y="6" width="52" height="52" rx="4" />
    <circle class="icon-glow" cx="32" cy="32" r="25" />

    {name === "ai" && (
      <g class="icon-lines" {...common}>
        <path d="M20 22h16l8 8v14H20z" />
        <path d="M25 29h14M25 36h9" />
        <circle cx="44" cy="18" r="4" />
        <path d="M39 21l-5 5M44 14v-4M48 18h4" />
      </g>
    )}

    {name === "web" && (
      <g class="icon-lines" {...common}>
        <rect x="16" y="18" width="32" height="26" rx="2" />
        <path d="M16 25h32M23 32h8M23 38h18M37 32h5" />
      </g>
    )}

    {name === "content" && (
      <g class="icon-lines" {...common}>
        <path d="M20 16h18l6 6v26H20z" />
        <path d="M38 16v8h8M26 30h14M26 36h11M26 42h16" />
        <path d="M17 25h-4v17h4" />
      </g>
    )}

    {name === "data" && (
      <g class="icon-lines" {...common}>
        <path d="M18 22c0-4 28-4 28 0s-28 4-28 0Z" />
        <path d="M18 22v18c0 4 28 4 28 0V22" />
        <path d="M18 31c0 4 28 4 28 0" />
        <path d="M18 40c0 4 28 4 28 0" />
      </g>
    )}

    {name === "commerce" && (
      <g class="icon-lines" {...common}>
        <path d="M18 20h6l4 22h18" />
        <path d="M27 25h21l-4 12H30" />
        <circle cx="32" cy="47" r="2.5" />
        <circle cx="44" cy="47" r="2.5" />
        <path d="M33 30h8" />
      </g>
    )}

    {name === "media" && (
      <g class="icon-lines" {...common}>
        <rect x="16" y="19" width="32" height="24" rx="3" />
        <path d="M29 27l10 5-10 5z" />
        <path d="M18 49c5-4 9-4 14 0s9 4 14 0" />
      </g>
    )}

    {name === "api" && (
      <g class="icon-lines" {...common}>
        <rect x="16" y="20" width="14" height="14" rx="2" />
        <rect x="34" y="30" width="14" height="14" rx="2" />
        <path d="M30 27h8M34 37h-8M23 20v-6M41 44v6" />
      </g>
    )}

    {name === "lead" && (
      <g class="icon-lines" {...common}>
        <circle cx="25" cy="24" r="6" />
        <path d="M15 45c2-8 18-8 20 0" />
        <path d="M39 20h9v18h-9zM39 27h9M34 33h5" />
      </g>
    )}

    {name === "tools" && (
      <g class="icon-lines" {...common}>
        <path d="M19 22h26M19 32h26M19 42h26" />
        <circle cx="28" cy="22" r="3" />
        <circle cx="38" cy="32" r="3" />
        <circle cx="25" cy="42" r="3" />
      </g>
    )}

    {name === "product" && (
      <g class="icon-lines" {...common}>
        <path d="M20 20h24v24H20z" />
        <path d="M26 20v-5h12v5M26 44v5h12v-5M20 26h-5v12h5M44 26h5v12h-5" />
        <path d="M27 31h10M27 37h6" />
      </g>
    )}

    {name === "monitor" && (
      <g class="icon-lines" {...common}>
        <path d="M15 21h34v23H15zM26 49h12" />
        <path d="M21 36l6-6 6 5 9-11" />
        <circle cx="42" cy="24" r="2" />
      </g>
    )}

    {name === "scale" && (
      <g class="icon-lines" {...common}>
        <path d="M18 44h28M22 44V30M32 44V22M42 44V16" />
        <path d="M20 22l8-6 8 6 8-6" />
      </g>
    )}

    {name === "space" && (
      <g class="icon-lines" {...common}>
        <path d="M17 17h30v30H17z" />
        <path d="M25 17v30M39 17v30M17 25h30M17 39h30" opacity="0.55" />
        <path d="M25 25h14v14H25z" />
      </g>
    )}

    {name === "lens" && (
      <g class="icon-lines" {...common}>
        <circle cx="30" cy="30" r="13" />
        <path d="M40 40l9 9M21 30c3-5 15-5 18 0-3 5-15 5-18 0Z" />
        <circle cx="30" cy="30" r="3" />
      </g>
    )}

    {name === "flow" && (
      <g class="icon-lines" {...common}>
        <rect x="15" y="18" width="13" height="13" rx="2" />
        <rect x="36" y="18" width="13" height="13" rx="2" />
        <rect x="25" y="38" width="14" height="10" rx="2" />
        <path d="M28 25h8M42 31v6l-7 4M22 31v6l7 4" />
      </g>
    )}

    {name === "ranking" && (
      <g class="icon-lines" {...common}>
        <path d="M18 45h28" />
        <path d="M22 45V31h6v14M31 45V21h6v24M40 45V27h6v18" />
        <path d="M20 20h10M20 25h6" />
      </g>
    )}

    {name === "map" && (
      <g class="icon-lines" {...common}>
        <path d="M22 16l-7 4v28l11-5 12 5 11-5V15l-11 5-12-5z" />
        <path d="M26 15v28M38 20v28" />
      </g>
    )}

    {name === "local" && (
      <g class="icon-lines" {...common}>
        <path d="M20 29c0-8 6-13 12-13s12 5 12 13c0 9-12 20-12 20S20 38 20 29Z" />
        <circle cx="32" cy="29" r="4" />
        <path d="M18 50h28" />
      </g>
    )}

    {![
      "ai",
      "web",
      "content",
      "data",
      "commerce",
      "media",
      "api",
      "lead",
      "tools",
      "product",
      "monitor",
      "scale",
      "space",
      "lens",
      "flow",
      "ranking",
      "map",
      "local"
    ].includes(name) && (
      <g class="icon-lines" {...common}>
        <path d="M18 18h28v28H18zM25 25h14v14H25z" />
      </g>
    )}
  </svg>
</span>
