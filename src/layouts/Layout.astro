---
import LiquidBackground from "@/components/LiquidBackground.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import "@/styles/global.css";

type Props = {
  title?: string;
  description?: string;
  image?: string;
};

const {
  title = "AlfaRank | Digital Systems Company",
  description = "AlfaRank designs and launches digital systems for business operations, content infrastructure, automation, and growth.",
  image = "/og-image.svg"
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://alfarank.com");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const baseUrl = siteUrl.toString().replace(/\/$/, "");
const structuredData = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "AlfaRank",
    url: baseUrl,
    logo: new URL("/og-image.svg", siteUrl).toString(),
    description
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "AlfaRank",
    url: baseUrl,
    description
  }
]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="AlfaRank" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script is:inline type="application/ld+json" set:html={structuredData}></script>
    <title>{title}</title>
  </head>
  <body>
    <LiquidBackground />
    <div class="site-shell">
      <SiteHeader />
      <main>
        <slot />
      </main>
      <SiteFooter />
    </div>
    <script is:inline>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const campaignContext = () => {
          const lpMatch = window.location.pathname.match(/^\/lp\/([^/]+)\//);
          return {
            path: window.location.pathname,
            source_path: `${window.location.pathname}${window.location.search}`,
            landing_page: params.get("landing_page") || params.get("lp") || (lpMatch ? window.location.pathname : ""),
            landing_offer: params.get("landing_offer") || params.get("offer") || lpMatch?.[1] || "",
            utm_source: params.get("utm_source") || "",
            utm_medium: params.get("utm_medium") || "",
            utm_campaign: params.get("utm_campaign") || "",
            utm_term: params.get("utm_term") || "",
            utm_content: params.get("utm_content") || ""
          };
        };

        const formValue = (form, name) => form.querySelector(`[name='${name}']`)?.value || "";
        const formContext = (form) => ({
          form: form.getAttribute("data-conversion-form") || "tracked-form",
          source_path: formValue(form, "source_path") || campaignContext().source_path,
          landing_page: formValue(form, "landing_page") || campaignContext().landing_page,
          landing_offer: formValue(form, "landing_offer") || campaignContext().landing_offer,
          project_type: formValue(form, "project_type"),
          desired_output: formValue(form, "desired_output"),
          utm_source: formValue(form, "utm_source") || campaignContext().utm_source,
          utm_medium: formValue(form, "utm_medium") || campaignContext().utm_medium,
          utm_campaign: formValue(form, "utm_campaign") || campaignContext().utm_campaign,
          utm_term: formValue(form, "utm_term") || campaignContext().utm_term,
          utm_content: formValue(form, "utm_content") || campaignContext().utm_content
        });

        const track = (eventName, properties = {}) => {
          const payload = {
            event: eventName,
            alfarank: {
              ...campaignContext(),
              ...properties
            },
            timestamp: new Date().toISOString()
          };

          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push(payload);
          window.dispatchEvent(new CustomEvent("alfarank:analytics", { detail: payload }));

          if (typeof window.gtag === "function") {
            window.gtag("event", eventName, payload.alfarank);
          }

          if (typeof window.plausible === "function") {
            window.plausible(eventName, { props: payload.alfarank });
          }
        };

        window.alfaRankTrack = track;
        track("page_view");

        if (window.location.pathname === "/start-project/thank-you/") {
          track("thank_you_view");
        }

        document.addEventListener("click", (event) => {
          if (!(event.target instanceof Element)) return;
          const target = event.target.closest("a, button");
          if (!target) return;

          if (target.tagName === "A") {
            const href = target.getAttribute("href") || "";
            const isConversionLink =
              href.includes("/start-project/") ||
              href === "#landing-intake" ||
              target.classList.contains("button");

            if (isConversionLink) {
              track("cta_click", {
                label: target.textContent.trim(),
                href,
                location: target.closest("section")?.className || "unknown"
              });
            }
          }

          if (target.matches("button[type='submit']")) {
            const form = target.closest("form[data-conversion-form]");
            if (form) {
              track("form_submit_click", formContext(form));
            }
          }
        });

        document.addEventListener("input", (event) => {
          if (!(event.target instanceof Element)) return;
          const form = event.target.closest("form[data-conversion-form]");
          if (!form || form.dataset.formStarted === "true") return;
          form.dataset.formStarted = "true";
          track("form_start", formContext(form));
        });

        document.addEventListener(
          "invalid",
          (event) => {
            if (!(event.target instanceof Element)) return;
            const field = event.target;
            const form = field.closest("form[data-conversion-form]");
            if (!form) return;
            track("form_validation_error", {
              ...formContext(form),
              field: field.name || field.id || "unknown"
            });
          },
          true
        );

        document.addEventListener("submit", (event) => {
          if (!(event.target instanceof Element)) return;
          const form = event.target.closest("form[data-conversion-form]");
          if (!form) return;
          track("form_submit_attempt", formContext(form));
        });
      })();
    </script>
  </body>
</html>
