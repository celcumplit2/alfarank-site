        const cleanRoCopy = (value) => {
          const englishSignal = /\b(the|and|with|without|into|from|this|that|should|where|what|when|instead|before|after|turn|make|build|built|workflow|workflows|dashboard|landing page|operating|output|input|review|route|routes|tools|content|business|lead|system|systems|scope|solution|profiles|companies|company|rather|than|station|feature|manual|collect|visibility|source|signal)\b/i;
          let result = roExactFallback[value] || value;
          for (const [pattern, replacement] of roPhraseFallback) {
            if (pattern.test(result)) {
              result = result.replace(pattern, replacement);
              break;
            }
          }
          if (!englishSignal.test(result) && !roExactFallback[value]) return result;
          Object.entries(roTermFallback)
            .sort((a, b) => b[0].length - a[0].length)
            .forEach(([term, replacement]) => {
              result = result.replace(
                new RegExp(`\\b${term.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}\\b`, "gi"),
                replacement
              );
            });
          return result
            .replace(/[A-Za-z][A-Za-z.-]*/g, (word) => {
              const suffix = word.match(/\\.{1,3}$/)?.[0] || "";
              const normalized = word.toLowerCase().replace(/[^a-z.-]/g, "").replace(/\\.+$/, "");
              const compact = normalized.replace(/[-.]/g, "");
              const allowed = new Set(["alfarank", "ai", "seo", "crm", "cms", "api", "apis", "wordpress", "saas", "mvp", "d1", "post", "qa", "utm", "github", "cloudflare", "astro", "next", "next.js"]);
              if (allowed.has(normalized) || allowed.has(compact)) return word;
              const replacement = Object.prototype.hasOwnProperty.call(roWordFallback, normalized)
                ? roWordFallback[normalized]
                : Object.prototype.hasOwnProperty.call(roWordFallback, compact)
                  ? roWordFallback[compact]
                  : undefined;
              return replacement === undefined ? word : `${replacement}${suffix === "..." ? "" : suffix}`;
            })
            .replace(/\s+([,.:;])/g, "$1")
            .replace(/\s{2,}/g, " ")
            .trim();
        };

        const dynamicTranslate = (value) => {
          if (pageLocale === "ru") {
            return cleanRuCopy(value
              .replace(/^(.+) pressure to build path$/, "$1: путь к сборке системы")
              .replace(/^(\d+) capabilities$/, "$1 возможностей")
              .replace(/^(\d+) solutions$/, "$1 решений")
              .replace(/^(\d+) profiles$/, "$1 профилей")
              .replace(/^(\d+) connected directions$/, "$1 связанных направлений")
              .replace(/^(\d+) offer pages$/, "$1 оффер-страниц")
              .replace(/^(.+) capabilities$/, "Возможности для $1")
              .replace(/^Solution routes for (.+)$/, "Маршруты решений для $1")
              .replace(/^System profiles for (.+)$/, "Профили систем для $1")
              .replace(/^Route (.+) into the capabilities, solution pages, and reusable profiles that make sense for this market\.$/, "$1 связывается с возможностями, страницами решений и reusable-профилями, которые подходят этому рынку.")
              .replace(/^Make (.+) visible enough to scope, assign, automate, or measure\.$/, "$1 становится достаточно видимым, чтобы его можно было оценить, назначить, автоматизировать или измерить.")
              .replace(/^Start with (.+) and show how it becomes a managed digital system\.$/, "$1 становится стартовой точкой управляемой цифровой системы.")
              .replace(/^Use (.+) as the first commercial solution route\.$/, "$1 становится первым коммерческим маршрутом решения.")
              .replace(/^Make (.+) measurable instead of implied\.$/, "$1 становятся измеримыми, а не подразумеваемыми."));
          }

          if (pageLocale === "ro") {
            return value
              .replace(/^(.+) pressure to build path$/, "$1: ruta catre sistem")
              .replace(/^(\d+) capabilities$/, "$1 capabilitati")
              .replace(/^(\d+) solutions$/, "$1 solutii")
              .replace(/^(\d+) profiles$/, "$1 profiluri")
              .replace(/^(\d+) connected directions$/, "$1 directii conectate")
              .replace(/^(\d+) offer pages$/, "$1 pagini de oferta")
              .replace(/^(.+) capabilities$/, "Capabilitati pentru $1")
              .replace(/^Solution routes for (.+)$/, "Rute de solutii pentru $1")
              .replace(/^System profiles for (.+)$/, "Profiluri de sistem pentru $1")
              .replace(/^Route (.+) into the capabilities, solution pages, and reusable profiles that make sense for this market\.$/, "Transforma $1 in capabilitati, pagini de solutii si profiluri reutilizabile potrivite pentru aceasta piata.")
              .replace(/^Make (.+) visible enough to scope, assign, automate, or measure\.$/, "Fa $1 suficient de vizibil pentru a putea fi estimat, asignat, automatizat sau masurat.")
              .replace(/^Start with (.+) and show how it becomes a managed digital system\.$/, "Porneste de la $1 si arata cum devine un sistem digital gestionat.")
              .replace(/^Use (.+) as the first commercial solution route\.$/, "Foloseste $1 ca prima ruta comerciala de solutie.")
              .replace(/^Make (.+) measurable instead of implied\.$/, "Fa $1 masurabile, nu doar presupuse.");
          }

          return value;
        };

        const translateRuntimeText = (value) => {
          const leading = value.match(/^\s*/)?.[0] || "";
          const trailing = value.match(/\s*$/)?.[0] || "";
          const trimmed = value.trim();
          if (!trimmed) return value;
          const translated = runtimeTranslations[trimmed] || dynamicTranslate(trimmed);
          const cleaned =
            pageLocale === "ru" ? cleanRuCopy(translated) : pageLocale === "ro" ? cleanRoCopy(translated) : translated;
          return `${leading}${cleaned}${trailing}`;
        };

        if (pageLocale === "ro" || pageLocale === "ru") {
          const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              const parent = node.parentElement;
              if (!parent || ["SCRIPT", "STYLE", "SVG", "TEXTAREA", "CODE", "PRE"].includes(parent.tagName)) {
                return NodeFilter.FILTER_REJECT;
              }
              if (parent.closest("[data-no-translate]")) {
                return NodeFilter.FILTER_REJECT;
              }
              return node.nodeValue?.trim() ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
            }
          });
          const nodes = [];
          while (walker.nextNode()) nodes.push(walker.currentNode);
          nodes.forEach((node) => {
            node.nodeValue = translateRuntimeText(node.nodeValue || "");
          });

          document.querySelectorAll("[placeholder], [aria-label], [title]").forEach((element) => {
            if (element.closest("[data-no-translate]")) return;
            ["placeholder", "aria-label", "title"].forEach((attribute) => {
              const value = element.getAttribute(attribute);
              if (value) element.setAttribute(attribute, translateRuntimeText(value));
            });
          });
        }

        if (pageLocale === "ro" || pageLocale === "ru") {
          document.querySelectorAll("a[href^='/']").forEach((link) => {
            if (link.closest("[data-no-translate]")) return;
            const href = link.getAttribute("href") || "";
            if (
              href.startsWith(`/${pageLocale}/`) ||
              href.startsWith("/ro/") ||
              href.startsWith("/ru/") ||
              href.startsWith("/api/")
            ) {
              return;
            }

            link.setAttribute("href", `/${pageLocale}${href}`);
          });
        }
        } catch (error) {
          console.warn("Runtime localization failed", error);
        }

      })();
