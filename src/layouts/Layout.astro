                "astro",
                "next.js",
                "business-workflow-system",
                "businessworkflowsystem",
                "ai-media-production-system",
                "aimediaproductionsystem"
              ]);
              if (allowed.has(normalized) || allowed.has(compact)) return word;
              const replacement = ruWordFallback[normalized] || ruWordFallback[compact] || "";
              return replacement ? `${replacement}${suffix === "..." ? "" : suffix}` : "";
            })
            .replace(/\s+([,.:;])/g, "$1")
