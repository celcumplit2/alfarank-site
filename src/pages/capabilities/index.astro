---
import CardGrid from "@/components/CardGrid.astro";
import PageHero from "@/components/PageHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { collectionHeroVisual } from "@/data/hero";
import { getCapabilities, getSolutions, localizePath, translateCopy } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;
const capabilities = getCapabilities(locale);
const solutions = getSolutions(locale);
const siteUrl = Astro.site ?? new URL("https://alfarank.com");
const pagePath = localizePath("/capabilities/", locale);
const pageUrl = new URL(pagePath, siteUrl).toString();
const pageDescription = translateCopy(
  locale,
  "AlfaRank capabilities are organized around what the company can build, connect, automate, and launch."
);

const capabilityTags: Record<string, string[]> = {
  "ai-automation": ["AI workflows", "CRM", "Content"],
  "web-product-development": ["Platforms", "Dashboards", "MVP"],
  "seo-content-infrastructure": ["Content", "Publishing", "SEO"],
  "data-systems-scraping": ["Scraping", "Monitoring", "Audits"],
  "ecommerce-systems": ["Catalog", "Feeds", "Orders"],
  "video-media-automation": ["Video", "Media", "Pipelines"],
  "wordpress-api-integrations": ["WordPress", "APIs", "CMS"]
};

const capabilityGroups = [
  {
    title: translateCopy(locale, "Automation and operations"),
    icon: "ai",
    text: translateCopy(locale, "Repeated work, lead handling, content production, reporting, routing, and review loops."),
    slugs: ["ai-automation", "wordpress-api-integrations", "web-product-development"],
    solutionSlugs: ["automate-lead-processing", "build-internal-tools"]
  },
  {
    title: translateCopy(locale, "Content and growth systems"),
    icon: "content",
    text: translateCopy(locale, "Publishing infrastructure, programmatic pages, SEO workflows, media production, and monitoring."),
    slugs: ["seo-content-infrastructure", "video-media-automation", "ai-automation"],
    solutionSlugs: ["generate-more-content", "scale-seo-infrastructure"]
  },
  {
    title: translateCopy(locale, "Data and commerce infrastructure"),
    icon: "data",
    text: translateCopy(locale, "Collection, normalization, scoring, feeds, catalog operations, dashboards, and alerts."),
    slugs: ["data-systems-scraping", "ecommerce-systems", "wordpress-api-integrations"],
    solutionSlugs: ["build-data-monitoring-system", "upgrade-existing-website"]
  }
];

const capabilityBySlug = new Map(capabilities.map((item) => [item.slug, item]));
const solutionBySlug = new Map(solutions.map((item) => [item.slug, item]));
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: translateCopy(locale, "Capabilities | AlfaRank"),
    description: pageDescription,
    url: pageUrl,
    inLanguage: locale
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: translateCopy(locale, "AlfaRank capability directions"),
    itemListElement: capabilities.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      description: item.summary,
      url: new URL(localizePath(`/capabilities/${item.slug}/`, locale), siteUrl).toString()
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "AlfaRank",
        item: new URL(localizePath("/", locale), siteUrl).toString()
      },
      {
        "@type": "ListItem",
        position: 2,
        name: translateCopy(locale, "Capabilities"),
        item: pageUrl
      }
    ]
  }
];
---

<Layout
  title={translateCopy(locale, "Capabilities | AlfaRank")}
  description={pageDescription}
  locale={locale}
  structuredData={structuredData}
>
  <PageHero
    eyebrow={translateCopy(locale, "Capabilities")}
    title={translateCopy(locale, "Technical directions for building digital systems.")}
    text={translateCopy(locale, "AlfaRank capabilities are organized around what the company can build, connect, automate, and launch.")}
    primaryHref={localizePath("/start-project/", locale)}
    primaryLabel={translateCopy(locale, "Start a Project")}
    locale={locale}
    visual={collectionHeroVisual(capabilities, {
      mode: "capabilities",
      icon: "tools",
      label: translateCopy(locale, "Capability network"),
      state: translateCopy(locale, "Build directions online"),
      output: translateCopy(locale, "AI, web, content, data, commerce, media, integrations"),
      primaryMetric: translateCopy(locale, "Directions"),
      secondaryMetric: translateCopy(locale, "Build map")
    })}
  />

  <section class="section capability-foundation">
    <div class="section-header">
      <div>
        <p class="eyebrow">{translateCopy(locale, "Capability foundation")}</p>
        <h2>{translateCopy(locale, "Capabilities are grouped by operating layer.")}</h2>
      </div>
      <p>{translateCopy(locale, "Each group combines build directions with the solution routes where that capability usually becomes a working system.")}</p>
    </div>

    <div class="capability-lanes">
      {capabilityGroups.map((group) => (
        <article class="capability-lane">
          <div class="capability-lane__header">
            <SystemIcon name={group.icon} />
            <div>
              <h3>{group.title}</h3>
              <p>{group.text}</p>
            </div>
          </div>

          <div class="capability-lane__stack">
            {group.slugs.map((slug, index) => {
              const item = capabilityBySlug.get(slug);
              return item && (
                <a href={localizePath(`/capabilities/${item.slug}/`, locale)} style={`--lane-level: ${72 + index * 8}%;`}>
                  <strong>{item.title}</strong>
                  <span>{capabilityTags[item.slug]?.map((tag) => translateCopy(locale, tag)).join(" / ")}</span>
                  <b></b>
                </a>
              );
            })}
          </div>

          <div class="capability-lane__routes">
            {group.solutionSlugs.map((slug) => {
              const item = solutionBySlug.get(slug);
              return item && <a href={localizePath(`/solutions/${item.slug}/`, locale)}>{item.title}</a>;
            })}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">{translateCopy(locale, "Catalog")}</p>
        <h2>{translateCopy(locale, "All build directions")}</h2>
      </div>
      <p>{translateCopy(locale, "Use the full catalog when the system is already clear, or start from the layer groups above when the problem still needs routing.")}</p>
    </div>
    <CardGrid
      variant="glyph"
      items={capabilities.map((item) => ({
        title: item.title,
        icon: item.icon,
        summary: item.summary,
        tags: capabilityTags[item.slug]?.map((tag) => translateCopy(locale, tag)),
        href: localizePath(`/capabilities/${item.slug}/`, locale)
      }))}
    />
  </section>
</Layout>
