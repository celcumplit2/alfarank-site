---
import PageHero from "@/components/PageHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { capabilities } from "@/data/site";
import { itemHeroVisual } from "@/data/hero";
import { localizePath, translateCopy } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
  item: (typeof capabilities)[number];
};

export function getStaticPaths() {
  return capabilities.map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item, locale = "en" } = Astro.props as Props;
const isDataCapability = item.slug === "data-systems-scraping";
const isAutomationCapability = item.slug === "ai-automation";
const isMediaCapability = item.slug === "video-media-automation";
const dataSignalNodes = [
  { title: "Web sources", state: "Clean", icon: "web", detail: "Pages, listings, catalogs" },
  { title: "APIs", state: "Match", icon: "api", detail: "Structured external data" },
  { title: "Feeds", state: "Rank", icon: "commerce", detail: "Products and updates" },
  { title: "SERP signals", state: "Alert", icon: "ranking", detail: "Visibility and movement" },
  { title: "Files", state: "Clean", icon: "content", detail: "CSV, exports, sheets" },
  { title: "Dashboards", state: "Live", icon: "monitor", detail: "Operational output" }
];
const automationTowerSteps = [
  { title: "Capture", text: "Collect requests, prompts, records, source data, or tasks.", icon: "lead" },
  { title: "Enrich", text: "Add context, entities, rules, metadata, and missing fields.", icon: "data" },
  { title: "Score", text: "Classify fit, urgency, confidence, risk, or priority.", icon: "ranking" },
  { title: "Route", text: "Send work to CRM, CMS, dashboard, owner, or queue.", icon: "flow" },
  { title: "Follow-up", text: "Trigger notifications, updates, reports, and next actions.", icon: "monitor" }
];
const aiReviewStages = [
  { title: "Brief", state: "Input", detail: "Offer, audience, source assets, and constraints enter one queue.", icon: "content", href: "/lp/ai-content-workflow/" },
  { title: "Generate", state: "Draft", detail: "Scripts, scenes, variants, captions, and metadata are produced.", icon: "ai", href: "/capabilities/ai-automation/" },
  { title: "Review", state: "Gate", detail: "Human checks approve quality, facts, tone, rights, and brand fit.", icon: "tools", href: "/solutions/generate-more-content/" },
  { title: "Render", state: "Output", detail: "Assets are exported into ready formats for publishing channels.", icon: "media", href: "/systems/content-automation-workflows/" },
  { title: "Report", state: "Loop", detail: "Performance and production status feed the next batch.", icon: "ranking", href: "/solutions/scale-seo-infrastructure/" }
];
const aiReviewMetrics = ["Rights clear", "Brand fit", "Ready to publish"];
const genericCapabilityModules = (item.modules ?? []).map((module, index) => ({
  ...module,
  icon: ["data", item.icon ?? "tools", "api", "monitor", "ranking", "flow"][index] ?? "tools",
  state: ["Input", "Build", "Connect", "Operate", "Improve", "Scale"][index] ?? "Module",
  level: `${76 + index * 5}%`
}));
const capabilitySystemSignals = (item.outputs ?? []).slice(0, 3);
const capabilityIntakeHref = localizePath(`/start-project/?offer=capability-${item.slug}&landing_page=/capabilities/${item.slug}/`, locale);
const capabilityLowerTitle = item.title.toLowerCase();
const primaryOutput = (item.outputs ?? [item.summary])[0];
const moduleIntro = item.modules?.[0]?.title.toLowerCase() ?? capabilityLowerTitle;
const capabilityHeadings = {
  en: {
    buildableModules: "Buildable modules",
    implementationTitle: "Working system logic",
    useCasesTitle: "Best-fit use cases"
  },
  ro: {
    buildableModules: "Module de build",
    implementationTitle: "Logica sistemului",
    useCasesTitle: "Cazuri potrivite"
  },
  ru: {
    buildableModules: "Собираемые модули",
    implementationTitle: "Логика рабочей системы",
    useCasesTitle: "Подходящие сценарии"
  }
}[locale];
const capabilityCopy = {
  systemModules: translateCopy(locale, "System modules"),
  buildableModules: capabilityHeadings.buildableModules,
  moduleIntro:
    locale === "en"
      ? `This capability becomes useful when ${moduleIntro} connects to real inputs, review states, integrations, and a visible output such as ${primaryOutput.toLowerCase()}.`
      : translateCopy(locale, "A capability becomes useful when it connects real inputs, review states, integrations, and a visible business output."),
  implementationTitle: capabilityHeadings.implementationTitle,
  implementationText:
    locale === "en"
      ? `The build starts with the business process behind ${primaryOutput.toLowerCase()}, then chooses the stack, review points, and integrations that make the workflow reliable.`
      : translateCopy(locale, "The build starts with the business process, then chooses the stack, review points, and integrations that make the workflow reliable."),
  useCasesTitle: capabilityHeadings.useCasesTitle,
  useCasesText:
    locale === "en"
      ? `Look for repeated work around ${moduleIntro}, clear ownership, and output that can be reviewed, routed, published, monitored, or improved.`
      : translateCopy(locale, "Look for repeated work, clear ownership, and output that can be reviewed, routed, published, monitored, or improved.")
};
---

<Layout title={`${item.title} | AlfaRank`} description={item.summary} locale={locale}>
  <PageHero
    eyebrow="Capability"
    title={item.title}
    text={item.summary}
    primaryHref={capabilityIntakeHref}
    primaryLabel={translateCopy(locale, "Start a Project")}
    secondaryHref={localizePath("/solutions/", locale)}
    secondaryLabel={translateCopy(locale, "View Solutions")}
    locale={locale}
    visual={itemHeroVisual(item, "capability")}
  />

  <section class="section split-panel">
    <div class="glass-panel">
      <h2>{translateCopy(locale, "What this covers")}</h2>
      {item.intro && <p>{item.intro}</p>}
      <ul class="feature-list">
        {(item.details ?? []).map((detail) => <li>{detail}</li>)}
      </ul>
    </div>
    <div class="glass-panel">
      <h2>{translateCopy(locale, "Business output")}</h2>
      <div class="tag-grid">
        {(item.outputs ?? []).map((output) => <span class="tag">{output}</span>)}
      </div>
      {item.related && (
        <>
          <h3>{translateCopy(locale, "Related solutions")}</h3>
          <div class="tag-grid">
            {item.related.map((related) => <span class="tag">{related}</span>)}
          </div>
        </>
      )}
    </div>
  </section>

  {item.modules && (
    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">{capabilityCopy.systemModules}</p>
          <h2>{capabilityCopy.buildableModules}</h2>
        </div>
        <p>{capabilityCopy.moduleIntro}</p>
      </div>
      {isDataCapability ? (
        <div class="data-signal-map">
          <article class="data-signal-map__core">
            <SystemIcon name="data" />
            <span>{translateCopy(locale, "Signal processor")}</span>
            <strong>{translateCopy(locale, "Collect. Normalize. Decide.")}</strong>
            <p>{translateCopy(locale, "Raw sources become clean records, matched entities, ranked signals, alerts, reports, and operational dashboards.")}</p>
          </article>
          {dataSignalNodes.map((node, index) => (
            <article class:list={["data-signal-node", `data-signal-node--${index + 1}`]}>
              <SystemIcon name={node.icon} />
              <span>{translateCopy(locale, node.state)}</span>
              <h3>{translateCopy(locale, node.title)}</h3>
              <p>{translateCopy(locale, node.detail)}</p>
            </article>
          ))}
        </div>
      ) : isAutomationCapability ? (
        <div class="automation-tower">
          <article class="automation-tower__copy">
            <SystemIcon name="ai" />
            <span>{translateCopy(locale, "Automation tower")}</span>
            <strong>{translateCopy(locale, "Build the flow")}</strong>
            <p>{translateCopy(locale, "AI automation becomes valuable when the whole operating path is visible: capture, enrich, score, route, and follow up.")}</p>
            <a class="button secondary" href={capabilityIntakeHref}>{translateCopy(locale, "Start automation scope")}</a>
          </article>
          <div class="automation-tower__stack">
            {automationTowerSteps.map((step, index) => (
              <article class:list={["automation-floor", `automation-floor--${index + 1}`]}>
                <SystemIcon name={step.icon} />
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{translateCopy(locale, step.title)}</h3>
                <p>{translateCopy(locale, step.text)}</p>
              </article>
            ))}
          </div>
        </div>
      ) : isMediaCapability ? (
        <div class="ai-review-console">
          <article class="ai-review-console__preview">
            <div class="ai-review-console__bar">
              <span>{translateCopy(locale, "AI Review Console")}</span>
              <small>{translateCopy(locale, "Batch 04 / Ready for review")}</small>
            </div>
            <div class="ai-review-console__frame">
              <SystemIcon name="media" />
              <strong>{translateCopy(locale, "Media workflow preview")}</strong>
              <p>{translateCopy(locale, "Creative production becomes a visible queue: brief, generate, review, render, publish, and learn.")}</p>
            </div>
            <div class="ai-review-console__timeline" aria-label="Review quality checks">
              {aiReviewMetrics.map((metric) => <span>{translateCopy(locale, metric)}</span>)}
            </div>
          </article>

          <div class="ai-review-console__queue">
            {aiReviewStages.map((stage, index) => (
              <a class:list={["ai-review-step", `ai-review-step--${index + 1}`]} href={localizePath(stage.href, locale)}>
                <SystemIcon name={stage.icon} />
                <span>{translateCopy(locale, stage.state)}</span>
                <strong>{translateCopy(locale, stage.title)}</strong>
                <p>{translateCopy(locale, stage.detail)}</p>
              </a>
            ))}
          </div>
        </div>
      ) : (
        <div class:list={["capability-module-system", "ar-system-block", "ar-system-layer", `capability-module-system--${item.slug}`]}>
          <div class="ar-connector-field" aria-hidden="true"></div>
          <article class="capability-module-system__core ar-system-core">
            <SystemIcon name={item.icon} />
            <span>{translateCopy(locale, "Capability system")}</span>
            <strong>{item.title}</strong>
            <p>{item.summary}</p>
            <a class="button secondary" href={capabilityIntakeHref}>{translateCopy(locale, "Scope this capability")}</a>
          </article>

          {genericCapabilityModules.map((module, index) => (
            <article class:list={["capability-module-node", "ar-system-node", `capability-module-node--${index + 1}`]}>
              <SystemIcon name={module.icon} />
              <span>{translateCopy(locale, module.state)}</span>
              <h3>{module.title}</h3>
              <p>{module.text}</p>
              <b class="ar-metric-bar" style={`--ar-level: ${module.level};`}></b>
            </article>
          ))}
          <div class="capability-module-system__signals ar-signal-strip">
            {capabilitySystemSignals.map((signal) => <span class="ar-signal">{signal}</span>)}
          </div>
        </div>
      )}
    </section>
  )}

  {item.workflow && (
    <section class="section split-panel">
      <div class="glass-panel">
        <p class="eyebrow">{translateCopy(locale, "Implementation logic")}</p>
        <h2>{capabilityCopy.implementationTitle}</h2>
        <p>{capabilityCopy.implementationText}</p>
      </div>
      <div class="glass-panel">
        <ul class="feature-list">
          {item.workflow.map((step) => <li>{step}</li>)}
        </ul>
      </div>
    </section>
  )}

  {item.useCases && (
    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">{translateCopy(locale, "Use cases")}</p>
          <h2>{capabilityCopy.useCasesTitle}</h2>
        </div>
        <p>{capabilityCopy.useCasesText}</p>
      </div>
      <ul class="feature-list">
        {item.useCases.map((useCase) => <li>{useCase}</li>)}
      </ul>
    </section>
  )}
</Layout>
