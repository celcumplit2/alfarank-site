---
import Layout from "@/layouts/Layout.astro";
import { translateNewsText } from "@/data/nova-news-translations";
import {
  articleCategory,
  articleDate,
  articleDescription,
  articleTitle,
  formatArticleDate,
  getNovaArticleSummaries,
  newsPath
} from "@/lib/nova";
import type { NewsLocale } from "@/lib/nova";

export function getStaticPaths() {
  return (["ro", "ru"] as const).map((locale) => ({ params: { locale }, props: { locale } }));
}

type Props = {
  locale: NewsLocale;
};

const { locale } = Astro.props;
const articles = await getNovaArticleSummaries(locale);
const title = `${translateNewsText("AlfaRank News Analysis", locale)} | AlfaRank`;
const description = translateNewsText(
  "Source-backed AlfaRank news analysis on automation, AI workflows, data systems, web platforms, and digital operations.",
  locale
);
const conciseHeading = (value: string) => {
  if (value.length <= 60) return value;
  const candidates = [
    value.split(/[—–-]/)[0]?.trim(),
    value.split(":")[0]?.trim()
  ].filter((candidate) => candidate && candidate.length >= 18 && candidate.length <= 60);
  if (candidates[0]) return candidates[0];
  const trimmed = value.slice(0, 57).replace(/\s+\S*$/, "");
  return `${trimmed}...`;
};
---

<Layout title={title} description={description} locale={locale}>
  <section class="section nova-news-index">
    <header class="nova-news-index__hero">
      <p class="eyebrow">{translateNewsText("News Analysis", locale)}</p>
      <h1>{translateNewsText("AlfaRank intelligence for digital operators.", locale)}</h1>
      <p>
        {translateNewsText("Analytical coverage from the NOVA monitoring engine: source-backed market signals, operational consequences, data points, and decision context for teams building automation and digital systems.", locale)}
      </p>
      <nav class="nova-news-index__trust" aria-label={translateNewsText("News trust pages", locale)}>
        <a href={newsPath("/news/about/", locale)}>{translateNewsText("About AlfaRank News", locale)}</a>
        <a href={newsPath("/news/editorial-policy/", locale)}>{translateNewsText("Editorial Policy", locale)}</a>
        <a href={newsPath("/news/authors/andrei/", locale)}>{translateNewsText("Author", locale)}</a>
      </nav>
    </header>

    <div class="nova-news-grid">
      {articles.map((article) => (
        <article class="nova-news-card">
          <a href={newsPath(`/news/${article.slug}/`, locale)}>
            <time datetime={articleDate(article)}>{formatArticleDate(articleDate(article), locale)}</time>
            {article.category && <span class="nova-news-card__category">{articleCategory(article, locale)}</span>}
            <h2>{conciseHeading(articleTitle(article))}</h2>
            <p>{articleDescription(article)}</p>
            {article.seo?.tags && (
              <ul>
                {article.seo.tags.slice(0, 4).map((tag) => <li>{translateNewsText(tag, locale)}</li>)}
              </ul>
            )}
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
