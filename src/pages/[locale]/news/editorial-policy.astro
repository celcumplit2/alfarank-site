---
import Layout from "@/layouts/Layout.astro";
import { normalizeSentenceStarts } from "@/data/nova-news-translations";
import { newsPath } from "@/lib/nova";
import type { NewsLocale } from "@/lib/nova";

export function getStaticPaths() {
  return (["ro", "ru"] as const).map((locale) => ({ params: { locale }, props: { locale } }));
}

type Props = {
  locale: NewsLocale;
};

const { locale } = Astro.props;
const copy = {
  ro: {
    title: "Politica editoriala | AlfaRank News",
    description:
      "Cum foloseste AlfaRank NOVA pentru monitorizarea surselor, verificarea faptelor, pregatirea materialelor si publicarea analizelor.",
    eyebrow: "Standarde editoriale",
    h1: "Cum este produsa analiza AlfaRank News.",
    intro:
      "AlfaRank publica materiale analitice pentru operatori digitali, echipe de automatizare si constructori de business. NOVA ajuta la monitorizarea surselor si la pregatirea materialelor. Publicarea trece prin verificarea surselor, verificare editoriala si evaluarea valorii pentru cititor.",
    cards: [
      ["Monitorizarea surselor", "NOVA urmareste fluxuri de stiri, directii de cautare si pagini ale surselor pentru subiectele AlfaRank News. Evenimentele duplicate, vechi sau slab sustinute nu devin articole."],
      ["Gestionarea faptelor", "Cifrele sunt verificate in materialele sursa si folosite doar cand dovezile sunt clare. Estimarile si afirmatiile de piata fara suport nu sunt publicate."],
      ["Asistenta AI", "NOVA poate ajuta la gruparea subiectelor, structurarea materialului, extragerea graficelor si formatare. Articolul final trebuie sa adauge context, consecinte si semnale utile pentru decizii."],
      ["Responsabilitate editoriala", "Publicarea ramane sub responsabilitatea editoriala AlfaRank. Redactia verifica materialul si il trimite la corectura cand este nevoie."]
    ],
    checksTitle: "Verificari inainte de publicare",
    checks: [
      "Materialul se bazeaza pe sursa principala si pe context relevant.",
      "Cifrele si graficele sunt verificate pe baza datelor confirmate.",
      "In articol raman doar fapte, concluzii si trimiteri utile pentru cititor.",
      "Titlurile sunt scrise intr-un limbaj editorial clar.",
      "Fiecare sectiune explica evenimentul, relevanta lui si posibilele consecinte pentru decizii."
    ],
    contactTitle: "Corecturi si contact",
    contact: "Daca este identificata o problema factuala, un numar depasit sau o cerere de corectare, AlfaRank revizuieste articolul si il actualizeaza, retrage sau republica atunci cand este necesar."
  },
  ru: {
    title: "Редакционная политика | AlfaRank News",
    description:
      "Как AlfaRank использует NOVA для мониторинга источников, проверки фактов, подготовки материалов и публикации аналитических новостей.",
    eyebrow: "Редакционные стандарты",
    h1: "Как создается новостная аналитика AlfaRank.",
    intro:
      "AlfaRank публикует аналитические материалы для операторов цифровых систем, команд автоматизации и бизнес-билдеров. NOVA помогает с мониторингом источников и подготовкой материалов. Публикация проходит через проверку источников, редакционную вычитку и оценку пользы для читателя.",
    cards: [
      ["Мониторинг источников", "NOVA отслеживает новостные ленты, поисковые направления и страницы источников по темам AlfaRank News. Дубли, устаревшие события и слабые материалы не становятся статьями."],
      ["Работа с фактами", "Цифры сверяются с источниками и используются только тогда, когда подтверждение понятно. Оценки и рыночные заявления без опоры на источник не публикуются."],
      ["AI-помощь", "NOVA может помогать с группировкой тем, структурой материала, извлечением графиков и форматированием. Итоговая статья должна добавлять контекст, последствия и полезные сигналы для решений."],
      ["Ответственность редакции", "Публикация остается под редакционной ответственностью AlfaRank. Редакция проверяет материал и при необходимости возвращает его на доработку."]
    ],
    checksTitle: "Проверки перед публикацией",
    checks: [
      "Материал опирается на основной источник и полезный контекст.",
      "Цифры и графики сверены с подтвержденными данными.",
      "В статье остаются только факты, выводы и ссылки, понятные читателю.",
      "Заголовки написаны ясным редакционным языком.",
      "Каждый раздел объясняет, что произошло, почему это важно и что может измениться дальше."
    ],
    contactTitle: "Исправления и контакт",
    contact: "Если найдена фактическая ошибка, устаревшая цифра, проблема атрибуции или запрос на исправление, AlfaRank пересматривает материал и обновляет, снимает или публикует его заново при необходимости."
  }
}[locale];

const clean = (value: string) => normalizeSentenceStarts(value, locale);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: copy.title,
  description: copy.description,
  url: `https://alfarank.com${newsPath("/news/editorial-policy/", locale)}`,
  publisher: {
    "@type": "Organization",
    name: "AlfaRank",
    url: "https://alfarank.com"
  }
};
---

<Layout title={copy.title} description={copy.description} locale={locale} structuredData={structuredData}>
  <article class="section nova-trust-page">
    <header class="nova-trust-page__hero">
      <p class="eyebrow">{clean(copy.eyebrow)}</p>
      <h1>{clean(copy.h1)}</h1>
      <p>{clean(copy.intro)}</p>
    </header>

    <section class="nova-trust-grid">
      {copy.cards.map(([title, body]) => (
        <article>
          <h2>{clean(title)}</h2>
          <p>{clean(body)}</p>
        </article>
      ))}
    </section>

    <section class="nova-trust-panel">
      <h2>{clean(copy.checksTitle)}</h2>
      <ul>
        {copy.checks.map((item) => <li>{clean(item)}</li>)}
      </ul>
    </section>

    <section class="nova-trust-panel">
      <h2>{clean(copy.contactTitle)}</h2>
      <p>{clean(copy.contact)}</p>
      <p>
        <a href="mailto:andrei@alfarank.com">andrei@alfarank.com</a>
      </p>
    </section>
  </article>
</Layout>
