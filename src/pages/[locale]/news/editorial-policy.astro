---
import Layout from "@/layouts/Layout.astro";
import { newsPath } from "@/lib/nova";
import type { NewsLocale } from "@/lib/nova";

export function getStaticPaths() {
  return (["ro", "ru"] as const).map((locale) => ({ params: { locale }, props: { locale } }));
}

type Props = {
  locale: NewsLocale;
};

const { locale } = Astro.props;
const copy = {
  ro: {
    title: "Politica editoriala | AlfaRank News",
    description:
      "Cum foloseste AlfaRank NOVA pentru monitorizarea surselor, verificarea faptelor, pregatirea materialelor si publicarea analizelor.",
    eyebrow: "Standarde editoriale",
    h1: "Cum este produsa analiza AlfaRank News.",
    intro:
      "AlfaRank publica materiale analitice pentru operatori digitali, echipe de automatizare si constructori de business. NOVA ajuta la monitorizarea surselor si la pregatirea materialelor, iar publicarea trece prin verificarea surselor, revizie editoriala si evaluarea valorii pentru cititor.",
    cards: [
      ["Monitorizarea surselor", "NOVA urmareste fluxuri de stiri, directii de cautare si pagini ale surselor pentru subiectele AlfaRank News. Evenimentele duplicate, vechi sau slab sustinute nu ajung in pregatirea materialului."],
      ["Gestionarea faptelor", "Cifrele sunt extrase separat, comparate si folosite doar cand exista in materialul sursa. Estimarile sintetice si afirmatiile de piata fara suport nu sunt publicate."],
      ["Asistenta AI", "NOVA poate ajuta la gruparea subiectelor, structurarea materialului, extragerea graficelor si formatare. Sistemul adauga context, consecinte si semnale, nu copiaza articolul sursa."],
      ["Responsabilitate editoriala", "Publicarea ramane sub responsabilitatea editoriala AlfaRank. Materialele care nu trec verificarea calitatii revin la corectura."]
    ],
    checksTitle: "Verificari inainte de publicare",
    checks: [
      "Sursa principala si sursele de context sunt separate.",
      "Cifrele din grafice trebuie sa provina din fapte sustinute de surse.",
      "Materialele publicate pastreaza doar informatii verificate si trimiteri clare catre surse.",
      "Titlurile sunt redactate pentru cititor, nu lasate ca denumiri de lucru.",
      "Fiecare parte a materialului trebuie sa adauge valoare clara: context, date, consecinta, comparatie, scenariu sau semnal decizional."
    ],
    contactTitle: "Corecturi si contact",
    contact: "Daca este identificata o problema factuala, un numar depasit sau o cerere de corectare, AlfaRank revizuieste articolul si il actualizeaza, retrage sau republica atunci cand este necesar."
  },
  ru: {
    title: "Редакционная политика | AlfaRank News",
    description:
      "Как AlfaRank использует NOVA для мониторинга источников, проверки фактов, подготовки материалов и публикации аналитических новостей.",
    eyebrow: "Редакционные стандарты",
    h1: "Как создается новостная аналитика AlfaRank.",
    intro:
      "AlfaRank публикует аналитические материалы для операторов цифровых систем, команд автоматизации и бизнес-билдеров. NOVA помогает с мониторингом источников и подготовкой материалов. Публикация проходит через проверку источников, редакционную вычитку и оценку пользы для читателя.",
    cards: [
      ["Мониторинг источников", "NOVA отслеживает новостные ленты, поисковые направления и страницы источников по темам AlfaRank News. Дубли, устаревшие события и слабые источники не попадают в подготовку материала."],
      ["Работа с фактами", "Числовые утверждения извлекаются отдельно, сверяются и используются только если они есть в исходном материале. Синтетические оценки и неподтвержденные рыночные заявления не публикуются."],
      ["AI-помощь", "NOVA может помогать с группировкой тем, структурой материала, извлечением графиков и форматированием. Система добавляет контекст, последствия и сигналы, а не копирует исходную статью."],
      ["Ответственность редакции", "Публикация остается под редакционной ответственностью AlfaRank. Материалы, которые не проходят проверку качества, возвращаются на доработку."]
    ],
    checksTitle: "Проверки перед публикацией",
    checks: [
      "Основной источник и контекстные источники разделены.",
      "Цифры в графиках должны происходить из фактов, подтвержденных источниками.",
      "В опубликованном материале остаются только проверенные сведения и понятные ссылки на источники.",
      "Заголовки редактируются для читателя, а не остаются рабочими названиями.",
      "Каждая часть материала должна давать понятную пользу: контекст, данные, последствия, сравнение, сценарий или сигнал для решения."
    ],
    contactTitle: "Исправления и контакт",
    contact: "Если найдена фактическая ошибка, устаревшая цифра, проблема атрибуции или запрос на исправление, AlfaRank пересматривает материал и обновляет, снимает или публикует его заново при необходимости."
  }
}[locale];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: copy.title,
  description: copy.description,
  url: `https://alfarank.com${newsPath("/news/editorial-policy/", locale)}`,
  publisher: {
    "@type": "Organization",
    name: "AlfaRank",
    url: "https://alfarank.com"
  }
};
---

<Layout title={copy.title} description={copy.description} locale={locale} structuredData={structuredData}>
  <article class="section nova-trust-page">
    <header class="nova-trust-page__hero">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.h1}</h1>
      <p>{copy.intro}</p>
    </header>

    <section class="nova-trust-grid">
      {copy.cards.map(([title, body]) => (
        <article>
          <h2>{title}</h2>
          <p>{body}</p>
        </article>
      ))}
    </section>

    <section class="nova-trust-panel">
      <h2>{copy.checksTitle}</h2>
      <ul>
        {copy.checks.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="nova-trust-panel">
      <h2>{copy.contactTitle}</h2>
      <p>{copy.contact}</p>
      <p>
        <a href="mailto:andrei@alfarank.com">andrei@alfarank.com</a>
      </p>
    </section>
  </article>
</Layout>
