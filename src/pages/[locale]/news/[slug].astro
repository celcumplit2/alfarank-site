---
import NovaArticle from "@/components/NovaArticle.astro";
import Layout from "@/layouts/Layout.astro";
import {
  articleDescription,
  articleImage,
  articleTitle,
  getNovaArticle,
  getNovaArticleSummaries,
  newsArticleSchema,
  newsPath
} from "@/lib/nova";
import type { NewsLocale } from "@/lib/nova";

export async function getStaticPaths() {
  const paths = [];
  for (const locale of ["ro", "ru"] as const) {
    const articles = await getNovaArticleSummaries(locale);
    paths.push(...articles.map((article) => ({ params: { locale, slug: article.slug }, props: { locale } })));
  }
  return paths;
}

type Props = {
  locale: NewsLocale;
};

const { locale } = Astro.props;
const { slug } = Astro.params;
const article = slug ? await getNovaArticle(slug, locale) : undefined;

if (!article) {
  return Astro.redirect(newsPath("/news/", locale));
}
---

<Layout
  title={`${articleTitle(article)} | AlfaRank`}
  description={articleDescription(article)}
  image={articleImage(article) || undefined}
  locale={locale}
  ogType="article"
  structuredData={newsArticleSchema(article, locale)}
>
  <NovaArticle article={article} locale={locale} />
</Layout>
