---
import MoldovagazApplicationsPresentation from "@/components/MoldovagazApplicationsPresentation.astro";
import { translatedLocales, type Locale } from "@/data/i18n";

export function getStaticPaths() {
  return translatedLocales.map((locale) => ({
    params: { locale }
  }));
}

const locale = Astro.params.locale as Locale;
---

<MoldovagazApplicationsPresentation locale={locale} />
