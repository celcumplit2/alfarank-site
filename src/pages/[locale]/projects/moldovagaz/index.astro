---
import MoldovagazProjectPage from "@/pages/projects/moldovagaz/index.astro";
import { translatedLocales } from "@/data/i18n";

export function getStaticPaths() {
  return translatedLocales.map((locale) => ({
    params: { locale },
    props: { locale }
  }));
}

const { locale } = Astro.props;
---

<MoldovagazProjectPage locale={locale} />
