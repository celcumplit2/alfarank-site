---
import IndustriesPage from "@/pages/industries.astro";
import { translatedLocales } from "@/data/i18n";

export function getStaticPaths() {
  return translatedLocales.map((locale) => ({
    params: { locale },
    props: { locale }
  }));
}

const { locale } = Astro.props;
---

<IndustriesPage locale={locale} />
