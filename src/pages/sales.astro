          grid-template-columns: 1fr;
        }
      }
    </style>

    <script is:inline>
      (() => {
        const root = document.querySelector("[data-sales-app]");
        if (!root) return;

        const state = {
          user: null,
          users: [],
          overview: null,
          clients: [],
          actions: [],
          documents: [],
          pendingActionDocuments: [],
          activeTab: "dashboard"
        };

        const elements = {
          loginPanel: root.querySelector("[data-login-panel]"),
          loginForm: root.querySelector("[data-login-form]"),
          loginStatus: root.querySelector("[data-login-status]"),
          workspace: root.querySelector("[data-workspace]"),
          sessionName: root.querySelector("[data-session-name]"),
          logout: root.querySelector("[data-logout]"),
          globalStatus: root.querySelector("[data-global-status]"),
          mobileFilterToggle: root.querySelector("[data-mobile-filter-toggle]"),
          mobileFilterbar: root.querySelector("[data-mobile-filterbar]"),
          mobileFilterSummary: root.querySelector("[data-mobile-filter-summary]"),
          today: root.querySelector("[data-today]"),
          refresh: root.querySelector("[data-refresh]"),
          actionMode: root.querySelector("[data-action-mode]"),
          actionFilterStatus: root.querySelector("[data-action-filter-status]"),
          actionFilterType: root.querySelector("[data-action-filter-type]"),
          actionFilterCompany: root.querySelector("[data-action-filter-company]"),
          metrics: root.querySelector("[data-metrics]"),
          planDays: root.querySelector("[data-plan-days]"),
          upcomingActions: root.querySelector("[data-upcoming-actions]"),
          auditList: root.querySelector("[data-audit-list]"),
          quickAddForm: root.querySelector("[data-quick-add-form]"),
          quickToggle: root.querySelector("[data-quick-toggle]"),
          quickOwnerField: root.querySelector("[data-quick-owner-field]"),
          quickOwnerSelect: root.querySelector("[data-quick-owner-select]"),
          clientForm: root.querySelector("[data-client-form]"),
          clientFormTitle: root.querySelector("[data-client-form-title]"),
          clientSubmit: root.querySelector("[data-client-submit]"),
          clientOwnerField: root.querySelector("[data-client-owner-field]"),
          clientOwnerSelect: root.querySelector("[data-client-owner-select]"),
          clientReset: root.querySelector("[data-client-reset]"),
          clientSearch: root.querySelector("[data-client-search]"),
          clientStatus: root.querySelector("[data-client-status]"),
          clientSegment: root.querySelector("[data-client-segment]"),
          clientsTable: root.querySelector("[data-clients-table]"),
          actionForm: root.querySelector("[data-action-form]"),
          actionFormTitle: root.querySelector("[data-action-form-title]"),
          actionToggle: root.querySelector("[data-action-toggle]"),
          actionReset: root.querySelector("[data-action-reset]"),
          actionCompletionFields: root.querySelectorAll("[data-action-completion-field]"),
          actionClientSelect: root.querySelector("[data-action-client-select]"),
          actionClientSummary: root.querySelector("[data-action-client-summary]"),
          actionDocumentTrigger: root.querySelector("[data-action-form-document-trigger]"),
          actionDocumentInput: root.querySelector("[data-action-form-document-input]"),
          actionDocumentList: root.querySelector("[data-action-form-document-list]"),
          actionSubmit: root.querySelector("[data-action-submit]"),
          actionsTable: root.querySelector("[data-actions-table]"),
          weeklyTable: root.querySelector("[data-weekly-table]"),
          exportXlsx: root.querySelector("[data-export-xlsx]"),
          importPrototype: root.querySelector("[data-import-prototype]")
        };

        const scrollbarState = {
          frame: 0,
          page: null,
          horizontal: new WeakMap()
        };

        const clampNumber = (value, min, max) => Math.min(Math.max(value, min), max);

        const updatePageScrollbar = () => {
          const rail = scrollbarState.page;
          if (!rail) return;
          const thumb = rail.querySelector(".sales-page-scrollbar__thumb");
          const scrollable = Math.max(0, document.documentElement.scrollHeight - window.innerHeight);
          rail.hidden = scrollable <= 2;
          if (rail.hidden || !thumb) return;

          const railHeight = rail.clientHeight;
          const thumbHeight = clampNumber((window.innerHeight / document.documentElement.scrollHeight) * railHeight, 36, railHeight);
          const maxThumbTop = Math.max(0, railHeight - thumbHeight - 2);
          const thumbTop = scrollable ? (window.scrollY / scrollable) * maxThumbTop : 0;
          thumb.style.height = `${thumbHeight}px`;
          thumb.style.transform = `translateY(${thumbTop}px)`;
        };

        const updateHorizontalScrollbar = (wrap) => {
          const rail = scrollbarState.horizontal.get(wrap);
          if (!rail) return;
          const thumb = rail.querySelector(".sales-custom-scrollbar__thumb");
          const scrollable = Math.max(0, wrap.scrollWidth - wrap.clientWidth);
          rail.hidden = scrollable <= 2;
          if (rail.hidden || !thumb) return;

          const railWidth = rail.clientWidth;
          const thumbWidth = clampNumber((wrap.clientWidth / wrap.scrollWidth) * railWidth, 36, railWidth);
          const maxThumbLeft = Math.max(0, railWidth - thumbWidth - 2);
          const thumbLeft = scrollable ? (wrap.scrollLeft / scrollable) * maxThumbLeft : 0;
          thumb.style.width = `${thumbWidth}px`;
          thumb.style.transform = `translateX(${thumbLeft}px)`;
        };

        const queueCustomScrollbarUpdate = () => {
          if (scrollbarState.frame) cancelAnimationFrame(scrollbarState.frame);
          scrollbarState.frame = requestAnimationFrame(() => {
            scrollbarState.frame = 0;
            updatePageScrollbar();
            root.querySelectorAll(".sales-table-wrap").forEach(updateHorizontalScrollbar);
          });
        };

        const dragScrollbar = (event, axis, getRail, onMove) => {
          event.preventDefault();
          const rail = getRail();
          if (!rail) return;
          const move = (moveEvent) => {
            const rect = rail.getBoundingClientRect();
            const size = axis === "x" ? rect.width : rect.height;
            const point = axis === "x" ? moveEvent.clientX - rect.left : moveEvent.clientY - rect.top;
            onMove(clampNumber(point / Math.max(1, size), 0, 1));
          };
          const stop = () => {
            window.removeEventListener("pointermove", move);
            window.removeEventListener("pointerup", stop);
          };
          move(event);
          window.addEventListener("pointermove", move);
          window.addEventListener("pointerup", stop, { once: true });
        };

        const setupPageScrollbar = () => {
          if (scrollbarState.page) return;
          const rail = document.createElement("div");
          rail.className = "sales-page-scrollbar";
          rail.innerHTML = `<div class="sales-page-scrollbar__thumb"></div>`;
          document.body.appendChild(rail);
          scrollbarState.page = rail;
          rail.addEventListener("pointerdown", (event) => {
            dragScrollbar(event, "y", () => rail, (ratio) => {
              const scrollable = Math.max(0, document.documentElement.scrollHeight - window.innerHeight);
              window.scrollTo({ top: ratio * scrollable, behavior: "auto" });
            });
          });
          window.addEventListener("scroll", queueCustomScrollbarUpdate, { passive: true });
          window.addEventListener("resize", queueCustomScrollbarUpdate);
        };

        const setupHorizontalScrollbar = (wrap) => {
          if (scrollbarState.horizontal.has(wrap)) return;
          const rail = document.createElement("div");
          rail.className = "sales-custom-scrollbar sales-custom-scrollbar--x";
          rail.innerHTML = `<div class="sales-custom-scrollbar__thumb"></div>`;
          wrap.insertAdjacentElement("afterend", rail);
          scrollbarState.horizontal.set(wrap, rail);
          wrap.addEventListener("scroll", () => updateHorizontalScrollbar(wrap), { passive: true });
          rail.addEventListener("pointerdown", (event) => {
            dragScrollbar(event, "x", () => rail, (ratio) => {
              wrap.scrollLeft = ratio * Math.max(0, wrap.scrollWidth - wrap.clientWidth);
            });
          });
        };

        const setupCustomScrollbars = () => {
          setupPageScrollbar();
          root.querySelectorAll(".sales-table-wrap").forEach(setupHorizontalScrollbar);
          queueCustomScrollbarUpdate();
        };

        const localToday = () => {
          const date = new Date();
          date.setMinutes(date.getMinutes() - date.getTimezoneOffset());
          return date.toISOString().slice(0, 10);
        };

        const dateFieldNames = new Set(["action_date", "last_contact_at", "next_action_at", "next_step_date"]);
        const isoDatePattern = /^\d{4}-\d{2}-\d{2}$/;

        const isValidIsoDate = (value) => {
          if (!isoDatePattern.test(String(value || ""))) return false;
          const [year, month, day] = String(value).split("-").map(Number);
          const date = new Date(Date.UTC(year, month - 1, day));
          return date.getUTCFullYear() === year && date.getUTCMonth() === month - 1 && date.getUTCDate() === day;
        };

        const toIsoDate = (value) => {
          const text = String(value ?? "").trim();
          if (!text) return "";
          if (isValidIsoDate(text)) return text;

          const match = text.match(/^(\d{1,2})[.\-/](\d{1,2})[.\-/](\d{4})$/);
          if (!match) return text;

          const day = match[1].padStart(2, "0");
          const month = match[2].padStart(2, "0");
          const iso = `${match[3]}-${month}-${day}`;
          return isValidIsoDate(iso) ? iso : text;
        };

        const formatDate = (value, fallback = "") => {
          const iso = toIsoDate(value);
          if (!isValidIsoDate(iso)) return value ? String(value) : fallback;
          const [year, month, day] = iso.split("-");
          return `${day}.${month}.${year}`;
        };

        const setDateInput = (input, value) => {
          if (!input) return;
          input.value = formatDate(value);
        };

        const normalizeDateInput = (input) => {
          if (!input) return;
          const iso = toIsoDate(input.value);
          if (isValidIsoDate(iso)) input.value = formatDate(iso);
        };

        const normalizeDateInputs = (scope = root) => {
          scope.querySelectorAll("[data-date-field]").forEach((input) => normalizeDateInput(input));
        };

        const isoToDate = (value) => {
          const iso = toIsoDate(value);
          if (!isValidIsoDate(iso)) return null;
          const [year, month, day] = iso.split("-").map(Number);
          return new Date(year, month - 1, day);
        };

        const dateToIso = (date) => {
          const year = date.getFullYear();
          const month = String(date.getMonth() + 1).padStart(2, "0");
          const day = String(date.getDate()).padStart(2, "0");
          return `${year}-${month}-${day}`;
        };

        const monthTitle = (date) => {
          const title = date.toLocaleDateString("ru-RU", { month: "long", year: "numeric" });
          return title.charAt(0).toUpperCase() + title.slice(1);
        };

        const datePickerState = {
          input: null,
          month: null,
          picker: null
        };

        const closeDatePicker = () => {
          const { input, picker } = datePickerState;
          if (input) input.setAttribute("aria-expanded", "false");
          if (picker) picker.hidden = true;
          datePickerState.input = null;
        };

        const placeDatePicker = () => {
          const { input, picker } = datePickerState;
          if (!input || !picker || picker.hidden) return;
          const rect = input.getBoundingClientRect();
          const width = Math.min(316, window.innerWidth - 16);
          picker.style.width = `${width}px`;
          const pickerHeight = picker.offsetHeight || 360;
          const left = clampNumber(rect.left, 8, Math.max(8, window.innerWidth - width - 8));
          let top = rect.bottom + 8;
          if (top + pickerHeight > window.innerHeight - 8) top = rect.top - pickerHeight - 8;
          picker.style.left = `${left}px`;
          picker.style.top = `${Math.max(8, top)}px`;
        };

        const renderDatePicker = () => {
          const { input, picker, month } = datePickerState;
          if (!input || !picker || !month) return;
          const title = picker.querySelector("[data-date-title]");
          const days = picker.querySelector("[data-date-days]");
          const selectedIso = isValidIsoDate(toIsoDate(input.value)) ? toIsoDate(input.value) : "";
          const todayIso = localToday();
          const firstDay = new Date(month.getFullYear(), month.getMonth(), 1);
          const gridStart = new Date(firstDay);
          gridStart.setDate(1 - ((firstDay.getDay() + 6) % 7));

          title.textContent = monthTitle(month);
          days.innerHTML = "";

          for (let index = 0; index < 42; index += 1) {
            const day = new Date(gridStart);
            day.setDate(gridStart.getDate() + index);
            const iso = dateToIso(day);
            const button = document.createElement("button");
            button.type = "button";
            button.className = "sales-date-day";
            button.textContent = String(day.getDate());
            button.dataset.dateValue = iso;
            button.setAttribute("aria-label", formatDate(iso));
            button.classList.toggle("is-muted", day.getMonth() !== month.getMonth());
            button.classList.toggle("is-today", iso === todayIso);
            button.classList.toggle("is-selected", iso === selectedIso);
            if (iso === selectedIso) button.setAttribute("aria-current", "date");
            days.appendChild(button);
          }

          placeDatePicker();
        };

        const ensureDatePicker = () => {
          if (datePickerState.picker) return datePickerState.picker;

          const picker = document.createElement("div");
          picker.className = "sales-date-picker";
          picker.hidden = true;
          picker.setAttribute("role", "dialog");
          picker.setAttribute("aria-label", "Календарь");
          picker.innerHTML = `
            <div class="sales-date-picker__head">
              <button class="sales-date-picker__nav" type="button" aria-label="Предыдущий месяц" data-date-prev>&lt;</button>
              <strong class="sales-date-picker__title" data-date-title></strong>
              <button class="sales-date-picker__nav" type="button" aria-label="Следующий месяц" data-date-next>&gt;</button>
            </div>
            <div class="sales-date-picker__week" aria-hidden="true">
              <span class="sales-date-picker__weekday">Пн</span>
              <span class="sales-date-picker__weekday">Вт</span>
              <span class="sales-date-picker__weekday">Ср</span>
              <span class="sales-date-picker__weekday">Чт</span>
              <span class="sales-date-picker__weekday">Пт</span>
              <span class="sales-date-picker__weekday">Сб</span>
              <span class="sales-date-picker__weekday">Вс</span>
            </div>
            <div class="sales-date-picker__days" data-date-days></div>
            <div class="sales-date-picker__actions">
              <button class="sales-date-picker__action" type="button" data-date-today>Сегодня</button>
              <button class="sales-date-picker__action" type="button" data-date-close>Закрыть</button>
            </div>
          `;
          document.body.appendChild(picker);
          datePickerState.picker = picker;

          picker.addEventListener("click", (event) => {
            const moveMonth = event.target.closest("[data-date-prev], [data-date-next]");
            if (moveMonth) {
              const direction = moveMonth.hasAttribute("data-date-prev") ? -1 : 1;
              datePickerState.month = new Date(datePickerState.month.getFullYear(), datePickerState.month.getMonth() + direction, 1);
              renderDatePicker();
              return;
            }

            if (event.target.closest("[data-date-today]")) {
              const today = localToday();
              setDateInput(datePickerState.input, today);
              datePickerState.input.dispatchEvent(new Event("input", { bubbles: true }));
              datePickerState.input.dispatchEvent(new Event("change", { bubbles: true }));
              closeDatePicker();
              return;
            }

            if (event.target.closest("[data-date-close]")) {
              closeDatePicker();
              return;
            }

            const dayButton = event.target.closest("[data-date-value]");
            if (dayButton) {
              setDateInput(datePickerState.input, dayButton.dataset.dateValue);
              datePickerState.input.dispatchEvent(new Event("input", { bubbles: true }));
              datePickerState.input.dispatchEvent(new Event("change", { bubbles: true }));
              closeDatePicker();
            }
          });

          document.addEventListener("pointerdown", (event) => {
            if (picker.hidden) return;
            if (picker.contains(event.target) || event.target.closest(".sales-date-control")) return;
            closeDatePicker();
          });
          window.addEventListener("resize", placeDatePicker);
          window.addEventListener("scroll", placeDatePicker, true);
          return picker;
        };

        const openDatePicker = (input) => {
          const picker = ensureDatePicker();
          normalizeDateInput(input);
          const selectedDate = isoToDate(input.value) || isoToDate(localToday());
          datePickerState.input = input;
          datePickerState.month = new Date(selectedDate.getFullYear(), selectedDate.getMonth(), 1);
          input.setAttribute("aria-expanded", "true");
          picker.hidden = false;
          renderDatePicker();
          placeDatePicker();
        };

        const setupDatePickerField = (input) => {
          if (!input || input.dataset.datePickerReady === "true") return;
          input.dataset.datePickerReady = "true";
          input.setAttribute("aria-haspopup", "dialog");
          input.setAttribute("aria-expanded", "false");

          const wrapper = document.createElement("div");
          wrapper.className = "sales-date-control";
          input.insertAdjacentElement("beforebegin", wrapper);
          wrapper.appendChild(input);

          const trigger = document.createElement("button");
          trigger.className = "sales-date-trigger";
          trigger.type = "button";
          trigger.setAttribute("aria-label", "Открыть календарь");
          trigger.innerHTML = `<span aria-hidden="true"></span>`;
          wrapper.appendChild(trigger);

          input.addEventListener("focus", () => openDatePicker(input));
          input.addEventListener("click", () => openDatePicker(input));
          input.addEventListener("blur", () => normalizeDateInput(input));
          input.addEventListener("change", () => normalizeDateInput(input));
          input.addEventListener("keydown", (event) => {
            if (event.key === "ArrowDown") {
              event.preventDefault();
              openDatePicker(input);
            }
            if (event.key === "Escape") closeDatePicker();
          });
          trigger.addEventListener("click", () => {
            input.focus();
            openDatePicker(input);
          });
        };

        const setupDatePickers = () => {
          root.querySelectorAll("[data-date-field]").forEach(setupDatePickerField);
        };

        const currentToday = () => {
          normalizeDateInput(elements.today);
          const iso = toIsoDate(elements.today.value);
          return isValidIsoDate(iso) ? iso : localToday();
        };

        const escapeHtml = (value) =>
          String(value ?? "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");

        const compact = (value, max = 110) => {
          const text = String(value ?? "").replace(/\s+/g, " ").trim();
          return text.length > max ? `${text.slice(0, max - 3).trimEnd()}...` : text;
        };

        const formatFileSize = (value) => {
          const bytes = Number(value || 0);
          if (bytes < 1024) return `${bytes} Б`;
          if (bytes < 1024 * 1024) return `${Math.ceil(bytes / 1024)} КБ`;
          return `${(bytes / (1024 * 1024)).toFixed(1)} МБ`;
        };

        const actionDocumentExtensions = new Set([
          "pdf", "doc", "docx", "xls", "xlsx", "csv", "txt", "rtf", "odt", "ods",
          "ppt", "pptx", "png", "jpg", "jpeg", "webp", "heic", "zip"
        ]);

        const renderPendingActionDocuments = () => {
          const files = state.pendingActionDocuments;
          elements.actionDocumentList.innerHTML = files.length
            ? files
                .map(
                  (file) => `
                    <div class="sales-action-form-document-item">
                      <strong>${escapeHtml(file.name)}</strong>
                      <span>${escapeHtml(formatFileSize(file.size))}</span>
                    </div>
                  `
                )
                .join("")
            : '<span class="sales-action-document-empty">Документы не выбраны</span>';
        };

        const validatePendingActionDocuments = (actionId) => {
          const files = state.pendingActionDocuments;
          const existingCount = actionId
            ? state.documents.filter((document) => document.action_id === actionId).length
            : 0;
          if (existingCount + files.length > 12) {
            throw new Error("К одному действию можно прикрепить не больше 12 документов.");
          }
          files.forEach((file) => {
            const extension = file.name.toLowerCase().split(".").pop() || "";
            if (!actionDocumentExtensions.has(extension)) {
              throw new Error(`Тип файла ${file.name} не поддерживается.`);
            }
            if (!file.size) {
              throw new Error(`Файл ${file.name} пустой.`);
            }
            if (file.size > 1_750_000) {
              throw new Error(`Файл ${file.name} больше 1,7 МБ.`);
            }
          });
        };

        const status = (message, mode = "") => {
          elements.globalStatus.textContent = message || "";
          elements.globalStatus.classList.toggle("is-error", mode === "error");
          elements.globalStatus.classList.toggle("is-success", mode === "success");
        };

        const updateMobileFilterSummary = () => {
          if (!elements.mobileFilterSummary || !elements.actionMode) return;
          const selectedMode = elements.actionMode.selectedOptions?.[0]?.textContent?.trim() || "";
          elements.mobileFilterSummary.textContent = selectedMode || "Все";
        };

        const setMobileFiltersOpen = (open) => {
          if (!elements.mobileFilterToggle || !elements.mobileFilterbar) return;
          elements.mobileFilterbar.classList.toggle("is-mobile-collapsed", !open);
          elements.mobileFilterToggle.setAttribute("aria-expanded", String(open));
          updateMobileFilterSummary();
        };

        const endpoint = (path, params = {}) => {
          const url = new URL(path, window.location.origin);
          Object.entries(params).forEach(([key, value]) => {
            if (value !== "" && value !== null && value !== undefined && value !== false) {
              url.searchParams.set(key, String(value));
            }
          });
          return `${url.pathname}${url.search}`;
        };

        const requestJson = async (path, options = {}) => {
          const isMultipart = typeof FormData !== "undefined" && options.body instanceof FormData;
          const response = await fetch(path, {
            cache: "no-store",
            credentials: "same-origin",
            ...options,
            headers: {
              ...(options.body && !isMultipart ? { "content-type": "application/json" } : {}),
              ...(options.headers || {})
            }
          });
          const text = await response.text();
          let payload = {};
          try {
            payload = text ? JSON.parse(text) : {};
          } catch {
            payload = { error: text || response.statusText };
          }
          if (!response.ok) throw new Error(payload.error || "Запрос не выполнен.");
          return payload;
        };

        const formData = (form) => {
          normalizeDateInputs(form);
          const payload = Object.fromEntries(new FormData(form).entries());
          dateFieldNames.forEach((key) => {
            if (key in payload) payload[key] = toIsoDate(payload[key]);
          });
          return payload;
        };

        const normalizeCheckboxes = (form, payload) => {
          form.querySelectorAll("input[type='checkbox'][name]").forEach((input) => {
            payload[input.name] = input.checked;
          });
          return payload;
        };

        const managerUsers = () => state.users.filter((user) => user.role === "manager");

        const isAdmin = () => state.user?.role === "admin";

        const userLabel = (id) => {
          const user = state.users.find((entry) => entry.id === id || entry.username === id);
          return user ? user.name : id || "-";
        };

        const ownerOptions = (selected = "") => {
          const managers = managerUsers();
          return managers
            .map((manager) => `<option value="${escapeHtml(manager.id)}" ${manager.id === selected ? "selected" : ""}>${escapeHtml(manager.name)}</option>`)
            .join("");
        };

        const renderOwnerControls = () => {
          const canAssign = state.user && state.user.role !== "manager";
          const managers = managerUsers();
          const defaultOwner = canAssign ? managers[0]?.id || "pavel" : state.user?.id || "";

          [elements.quickOwnerSelect, elements.clientOwnerSelect].forEach((select) => {
            if (!select) return;
            const selected = managers.some((manager) => manager.id === select.value) ? select.value : defaultOwner;
            select.innerHTML = ownerOptions(selected);
            select.disabled = !canAssign;
          });

          elements.quickOwnerField.hidden = !canAssign;
          elements.clientOwnerField.hidden = !canAssign;
        };

        const setAuthenticated = (session) => {
          state.user = session.user || null;
          state.users = session.users || state.users || [];
          const authenticated = Boolean(state.user);
          elements.loginPanel.hidden = authenticated;
          elements.workspace.hidden = !authenticated;
          elements.logout.hidden = !authenticated;
          elements.sessionName.textContent = authenticated
            ? `${state.user.name} / ${state.user.role}`
            : "Не выполнен вход";
          renderOwnerControls();
        };

        const metric = (label, value, hint = "") => `
          <article class="sales-metric">
            <span>${escapeHtml(label)}</span>
            <strong>${escapeHtml(value ?? 0)}</strong>
            ${hint ? `<span>${escapeHtml(hint)}</span>` : ""}
          </article>
        `;

        const renderMetrics = () => {
          const m = state.overview?.metrics || {};
          const g = state.overview?.goals || {};
          elements.metrics.innerHTML = [
            metric("Цель клиентов / 60 дней", g.clients || 10, "MVP цель"),
            metric("Клиентов факт", m.clients_count || 0),
            metric("Компаний в базе", m.companies_count || 0),
            metric("Встреч", m.meetings_count || 0),
            metric("КП отправлено", m.proposals_count || 0),
            metric("Просрочено", m.overdue_count || 0),
            metric("Сегодня", m.today_count || 0),
            metric("Без следующего шага", m.without_next_step_count || 0)
          ].join("");
        };

        const rowState = (date, statusValue) => {
          const today = currentToday();
          if (statusValue === "Сделано") return "done";
          if (date < today) return "overdue";
          if (date === today) return "today";
          return "";
        };

        const renderPlan = () => {
          elements.planDays.innerHTML = (state.overview?.plan_days || [])
            .map(
                  (row) => `
                <tr>
                  <td>${escapeHtml(formatDate(row.plan_date))}</td>
                  <td>${escapeHtml(row.focus)}</td>
                  <td>${escapeHtml(row.new_companies)}</td>
                  <td>${escapeHtml(row.contacts)}</td>
                  <td>${escapeHtml(row.meetings)}</td>
                  <td>${escapeHtml(row.proposals)}</td>
                  <td>${escapeHtml(row.main_result)}</td>
                </tr>
              `
            )
            .join("");
        };

        const renderUpcoming = () => {
          const rows = state.overview?.upcoming_actions || [];
          elements.upcomingActions.innerHTML = rows.length
            ? rows
                .map(
                  (action) => `
                    <article>
                      <strong>${escapeHtml(formatDate(action.action_date))} / ${escapeHtml(action.company_name)}</strong>
                      <span>${escapeHtml(action.priority)} · ${escapeHtml(action.action_type)} · ${escapeHtml(action.status)}</span>
                      <span>${escapeHtml(compact(action.task, 160))}</span>
                    </article>
                  `
                )
                .join("")
            : `<article><strong>Нет ближайших действий</strong><span>Очередь пуста для выбранной даты.</span></article>`;
        };

        const renderAudit = () => {
          const rows = state.overview?.recent_audit || [];
          elements.auditList.innerHTML = rows.length
            ? rows
                .map(
                  (event) => `
                    <article>
                      <strong>${escapeHtml(event.action)} · ${escapeHtml(event.entity_type)}</strong>
                      <span>${escapeHtml(event.actor_id)} / ${escapeHtml(event.created_at)}</span>
                    </article>
                  `
                )
                .join("")
            : `<article><strong>История пока пустая</strong><span>Изменения будут записываться автоматически.</span></article>`;
        };

        const renderClients = () => {
          const search = elements.clientSearch.value.trim().toLowerCase();
          const statusValue = elements.clientStatus.value;
          const segmentValue = elements.clientSegment.value;
          const rows = state.clients.filter((client) => {
            const matchesSearch = !search || [client.company_name, client.contact_name, client.city, client.source].join(" ").toLowerCase().includes(search);
            const matchesStatus = !statusValue || client.status === statusValue;
            const matchesSegment = !segmentValue || client.segment === segmentValue;
            return matchesSearch && matchesStatus && matchesSegment;
          });

          elements.clientsTable.innerHTML = rows.length
            ? rows
                .map(
                  (client) => `
                    <tr data-state="${rowState(client.next_action_at || "9999-12-31", client.status === "Клиент" ? "Сделано" : "")}">
                      <td><strong>${escapeHtml(client.company_name)}</strong><br /><span>${escapeHtml(client.contact_name || "")}</span></td>
                      <td>${escapeHtml(client.segment)}</td>
                      <td><span class="sales-pill">${escapeHtml(client.status)}</span></td>
                      <td>${escapeHtml(compact(client.next_action, 120) || "-")}</td>
                      <td>${escapeHtml(formatDate(client.next_action_at, "-"))}</td>
                      <td>${escapeHtml(client.potential)}</td>
                      <td>${escapeHtml(compact(client.source, 90) || "-")}</td>
                      <td>${escapeHtml(userLabel(client.owner_id))}</td>
                      <td>${escapeHtml(client.open_actions_count || 0)} / ${escapeHtml(client.overdue_actions_count || 0)} проср.</td>
                      <td>
                        <div class="sales-table-actions">
                          <button class="sales-button sales-button--ghost" type="button" data-edit-client="${escapeHtml(client.id)}" title="Редактировать клиента" aria-label="Редактировать клиента ${escapeHtml(client.company_name)}">Ред.</button>
                          ${isAdmin() ? `<button class="sales-button sales-button--danger" type="button" data-delete-client="${escapeHtml(client.id)}" title="Удалить клиента" aria-label="Удалить клиента ${escapeHtml(client.company_name)}">Удал.</button>` : ""}
                        </div>
                      </td>
                    </tr>
                  `
                )
                .join("")
            : `<tr><td colspan="10">Клиенты не найдены.</td></tr>`;
          queueCustomScrollbarUpdate();
        };

        const selectedActionClient = () => state.clients.find((client) => client.id === elements.actionClientSelect.value);

        const updateActionClientSummary = () => {
          const client = selectedActionClient();
          elements.actionClientSummary.textContent = client
            ? `${client.company_name}${client.contact_name ? ` / ${client.contact_name}` : ""}`
            : "Выберите клиента из базы. Компания и контакт подтянутся из карточки клиента.";
          elements.actionClientSummary.classList.toggle("is-selected", Boolean(client));
        };

        const renderClientSelect = () => {
          const selected = elements.actionClientSelect.value;
          const hasSelected = state.clients.some((client) => client.id === selected);
          elements.actionClientSelect.innerHTML = [
            `<option value="" disabled ${hasSelected ? "" : "selected"}>Выберите клиента</option>`,
            ...state.clients.map((client) => `<option value="${escapeHtml(client.id)}" ${client.id === selected ? "selected" : ""}>${escapeHtml(client.company_name)}</option>`)
          ].join("");
          updateActionClientSummary();
        };

        const renderActions = () => {
          elements.actionsTable.innerHTML = state.actions.length
            ? state.actions
                .map(
                  (action) => {
                    const documents = state.documents.filter((document) => document.action_id === action.id);
                    return `
                      <tr data-state="${rowState(action.action_date, action.status)}">
                        <td>${escapeHtml(formatDate(action.action_date))}</td>
                        <td><strong>${escapeHtml(action.company_name)}</strong><br /><span>${escapeHtml(action.contact_name || "")}</span></td>
                        <td>${escapeHtml(action.priority)}</td>
                        <td>${escapeHtml(action.action_type)}</td>
                        <td>${escapeHtml(compact(action.task, 150))}</td>
                        <td><span class="sales-pill">${escapeHtml(action.status)}</span></td>
                        <td>${escapeHtml(compact(action.next_step, 120) || "-")}<br /><span>${escapeHtml(formatDate(action.next_step_date, "-"))}</span></td>
                        <td>
                          <div class="sales-action-documents">
                            <div class="sales-action-document-list">
                              ${documents.length
                                ? documents
                                    .map(
                                      (document) => `
                                        <a class="sales-action-document" href="${endpoint("/api/sales/documents", { id: document.id })}" download title="Скачать ${escapeHtml(document.file_name)}">
                                          <strong>${escapeHtml(document.file_name)}</strong>
                                          <span>${escapeHtml(formatFileSize(document.byte_size))}</span>
                                        </a>
                                      `
                                    )
                                    .join("")
                                : '<span class="sales-action-document-empty">Документов пока нет</span>'}
                            </div>
                            <button class="sales-button sales-button--ghost" type="button" data-upload-action="${escapeHtml(action.id)}">Загрузить документ</button>
                            <input class="sales-file-input" type="file" data-action-document-input="${escapeHtml(action.id)}" accept=".pdf,.doc,.docx,.xls,.xlsx,.csv,.txt,.rtf,.odt,.ods,.ppt,.pptx,.png,.jpg,.jpeg,.webp,.heic,.zip" multiple />
                          </div>
                        </td>
                        <td>${escapeHtml(userLabel(action.owner_id))}</td>
                        <td>
                          <div class="sales-table-actions">
                            <button class="sales-button sales-button--ghost" type="button" data-edit-action="${escapeHtml(action.id)}" title="Редактировать действие" aria-label="Редактировать действие по ${escapeHtml(action.company_name)}">Ред.</button>
                            ${isAdmin() ? `<button class="sales-button sales-button--danger" type="button" data-delete-action="${escapeHtml(action.id)}" title="Удалить действие" aria-label="Удалить действие по ${escapeHtml(action.company_name)}">Удал.</button>` : ""}
                          </div>
                        </td>
                      </tr>
                    `;
                  }
                )
                .join("")
            : `<tr><td colspan="10">Нет действий для выбранного режима.</td></tr>`;
          queueCustomScrollbarUpdate();
        };

        const renderWeekly = () => {
          const rows = state.overview?.weekly_reviews || [];
          elements.weeklyTable.innerHTML = rows.length
            ? rows
                .map(
                  (week) => `
                    <tr data-week-id="${escapeHtml(week.id)}" data-week-start="${escapeHtml(week.week_start)}" data-manager-id="${escapeHtml(week.manager_id)}">
                      <td>${escapeHtml(formatDate(week.week_start))}</td>
                      <td>${escapeHtml(userLabel(week.manager_id))}</td>
                      <td>${escapeHtml(week.new_companies || 0)}</td>
                      <td>${escapeHtml(week.done_actions || 0)}</td>
                      <td>${escapeHtml(week.meetings || 0)}</td>
                      <td>${escapeHtml(week.proposals || 0)}</td>
                      <td>${escapeHtml(week.new_clients || 0)}</td>
                      <td>${escapeHtml(week.overdue_actions || 0)}</td>
                      <td><textarea data-week-manager>${escapeHtml(week.manager_comment || "")}</textarea></td>
                      <td><textarea data-week-director>${escapeHtml(week.director_comment || "")}</textarea></td>
                      <td><button class="sales-button sales-button--ghost" type="button" data-save-week>Сохранить</button></td>
                    </tr>
                  `
                )
                .join("")
            : `<tr><td colspan="10">Недельные итоги не найдены.</td></tr>`;
        };

        const renderAll = () => {
          renderMetrics();
          renderPlan();
          renderUpcoming();
          renderAudit();
          renderClients();
          renderClientSelect();
          renderActions();
          renderWeekly();
          setupCustomScrollbars();
        };

        const loadOverview = async () => {
          state.overview = await requestJson(endpoint("/api/sales/overview", { today: currentToday() }));
        };

        const loadClients = async () => {
          const payload = await requestJson("/api/sales/clients");
          state.clients = payload.clients || [];
        };

        const actionParams = () => ({
          today: currentToday(),
          mode: elements.actionMode.value,
          status: elements.actionFilterStatus.value,
          action_type: elements.actionFilterType.value,
          company: elements.actionFilterCompany.value
        });

        const loadActions = async () => {
          const payload = await requestJson(endpoint("/api/sales/actions", actionParams()));
          state.actions = payload.actions || [];
        };

        const loadDocuments = async () => {
          const payload = await requestJson("/api/sales/documents");
          state.documents = payload.documents || [];
        };

        const loadAll = async () => {
          status("Загружаю данные...");
          await Promise.all([loadOverview(), loadClients(), loadActions(), loadDocuments()]);
          renderAll();
          status(`Обновлено: ${new Date().toLocaleTimeString("ru-RU")}`, "success");
        };

        const setCollapsibleFormExpanded = (form, toggle, expanded) => {
          form.classList.toggle("is-collapsed", !expanded);
          if (toggle) {
            toggle.setAttribute("aria-expanded", String(expanded));
            toggle.textContent = expanded ? "Свернуть" : "Развернуть";
          }
          queueCustomScrollbarUpdate();
        };

        const setQuickFormExpanded = (expanded) => {
          setCollapsibleFormExpanded(elements.quickAddForm, elements.quickToggle, expanded);
        };

        const setActionFormExpanded = (expanded) => {
          setCollapsibleFormExpanded(elements.actionForm, elements.actionToggle, expanded);
        };

        const updateActionCompletionFields = () => {
          const isDone = elements.actionForm.elements.status.value === "Сделано";
          elements.actionCompletionFields.forEach((field) => {
            field.hidden = !isDone;
          });
          queueCustomScrollbarUpdate();
        };

        const resetClientForm = ({ close = false } = {}) => {
          elements.clientForm.reset();
          elements.clientForm.elements.id.value = "";
          elements.clientForm.elements.status.value = "Новый";
          elements.clientForm.elements.potential.value = "Средний";
          renderOwnerControls();
          elements.clientFormTitle.textContent = "Новый клиент";
          elements.clientSubmit.textContent = "Создать клиента";
          if (close) setQuickFormExpanded(false);
        };

        const resetActionForm = () => {
          elements.actionForm.reset();
          elements.actionForm.elements.id.value = "";
          state.pendingActionDocuments = [];
          elements.actionDocumentInput.value = "";
          setDateInput(elements.actionForm.elements.action_date, currentToday());
          elements.actionForm.elements.priority.value = "Средний";
          elements.actionForm.elements.action_type.value = "Звонок";
          elements.actionForm.elements.status.value = "Запланировано";
          elements.actionFormTitle.textContent = "Новое действие";
          renderPendingActionDocuments();
          updateActionClientSummary();
          updateActionCompletionFields();
        };

        const fillClientForm = (client) => {
          resetClientForm();
          Object.entries(client).forEach(([key, value]) => {
            if (elements.clientForm.elements[key]) {
              elements.clientForm.elements[key].value = dateFieldNames.has(key) ? formatDate(value) : value || "";
            }
          });
          elements.clientFormTitle.textContent = client.company_name || "Клиент";
          elements.clientSubmit.textContent = "Сохранить клиента";
          setQuickFormExpanded(true);
          elements.clientForm.scrollIntoView({ block: "start", behavior: "smooth" });
          setTab("clients");
        };

        const fillActionForm = (action) => {
          resetActionForm();
          Object.entries(action).forEach(([key, value]) => {
            if (elements.actionForm.elements[key]) {
              if (elements.actionForm.elements[key].type === "checkbox") {
                elements.actionForm.elements[key].checked = Boolean(value);
              } else {
                elements.actionForm.elements[key].value = dateFieldNames.has(key) ? formatDate(value) : value || "";
              }
            }
          });
          elements.actionFormTitle.textContent = `${action.company_name} / ${formatDate(action.action_date)}`;
          updateActionClientSummary();
          updateActionCompletionFields();
          setTab("actions");
          setActionFormExpanded(true);
          requestAnimationFrame(() => {
            elements.actionForm.scrollIntoView({ block: "start", behavior: "smooth" });
            elements.actionFormTitle.focus({ preventScroll: true });
          });
          status(`Открыто редактирование действия: ${action.company_name}`, "success");
        };

        const setTab = (tab) => {
          state.activeTab = tab;
          root.querySelectorAll("[data-tab]").forEach((button) => button.classList.toggle("is-active", button.dataset.tab === tab));
          root.querySelectorAll("[data-view]").forEach((view) => view.classList.toggle("is-active", view.dataset.view === tab));
          queueCustomScrollbarUpdate();
        };

        const saveClient = async (form) => {
          const payload = formData(form);
          await requestJson("/api/sales/clients", {
            method: "POST",
            body: JSON.stringify(payload)
          });
          resetClientForm({ close: true });
          await loadAll();
        };

        const saveAction = async (form) => {
          const payload = normalizeCheckboxes(form, formData(form));
          if (!payload.client_id) {
            throw new Error("Выберите клиента для действия.");
          }
          validatePendingActionDocuments(payload.id);

          const files = [...state.pendingActionDocuments];
          const originalSubmitText = elements.actionSubmit.textContent;
          let savedAction = null;
          elements.actionSubmit.disabled = true;
          elements.actionSubmit.textContent = files.length ? "Сохраняю и загружаю..." : "Сохраняю...";

          try {
            const response = await requestJson("/api/sales/actions", {
              method: "POST",
              body: JSON.stringify(payload)
            });
            savedAction = response.action;
            if (!savedAction?.id) throw new Error("Сервер не вернул созданное действие.");

            form.elements.id.value = savedAction.id;
            for (const file of files) {
              await uploadActionDocument(savedAction.id, file);
              state.pendingActionDocuments = state.pendingActionDocuments.filter((entry) => entry !== file);
              renderPendingActionDocuments();
            }

            resetActionForm();
            setActionFormExpanded(false);
            await loadAll();
            status(
              files.length
                ? `Действие сохранено. Документы загружены: ${files.length}`
                : "Действие сохранено.",
              "success"
            );
          } catch (error) {
            if (savedAction?.id && state.pendingActionDocuments.length) {
              try {
                await Promise.all([loadActions(), loadDocuments()]);
                renderActions();
              } catch {
                // Keep the original upload error visible.
              }
              elements.actionFormTitle.textContent = `${savedAction.company_name || "Действие"} / ${formatDate(savedAction.action_date)}`;
              throw new Error(`Действие сохранено, но не все документы загрузились: ${error.message}`);
            }
            throw error;
          } finally {
            elements.actionSubmit.disabled = false;
            elements.actionSubmit.textContent = originalSubmitText;
          }
        };

        const uploadActionDocument = async (actionId, file) => {
          const payload = new FormData();
          payload.append("action_id", actionId);
          payload.append("file", file);
          await requestJson("/api/sales/documents", {
            method: "POST",
            body: payload
          });
        };

        const uploadActionDocuments = async (action, input) => {
          const files = Array.from(input.files || []);
          if (!files.length) return;

          const button = input.closest(".sales-action-documents")?.querySelector("[data-upload-action]");
          if (button) {
            button.disabled = true;
            button.textContent = "Загружаю...";
          }

          try {
            for (const file of files) {
              await uploadActionDocument(action.id, file);
            }
            await loadDocuments();
            renderActions();
            status(`Документы загружены: ${files.length}`, "success");
          } finally {
            input.value = "";
            if (button) {
              button.disabled = false;
              button.textContent = "Загрузить документ";
            }
          }
        };

        const login = async (form) => {
          elements.loginStatus.textContent = "Проверяю доступ...";
          elements.loginStatus.dataset.mode = "";
          try {
            const session = await requestJson("/api/sales/session", {
              method: "POST",
              body: JSON.stringify(formData(form))
            });
            setAuthenticated(session);
            await loadAll();
          } catch (error) {
            elements.loginStatus.textContent = error.message || "Не удалось войти.";
            elements.loginStatus.dataset.mode = "error";
          }
        };

        const logout = async () => {
          await fetch("/api/sales/session", { method: "DELETE", credentials: "same-origin" });
          setAuthenticated({ user: null });
          status("");
        };

        const saveWeek = async (row) => {
          await requestJson("/api/sales/weekly", {
            method: "POST",
            body: JSON.stringify({
              id: row.dataset.weekId,
              week_start: row.dataset.weekStart,
              manager_id: row.dataset.managerId,
              manager_comment: row.querySelector("[data-week-manager]").value,
              director_comment: row.querySelector("[data-week-director]").value
            })
          });
          await loadOverview();
          renderWeekly();
          status("Итоги недели сохранены.", "success");
        };

        const exportXlsx = () => {
          window.location.href = endpoint("/api/sales/export", { today: currentToday() });
        };

        const importPrototype = async () => {
          await requestJson("/api/sales/import-prototype", { method: "POST", body: "{}" });
          await loadAll();
          status("Прототип импортирован без дублей.", "success");
        };

        const deleteClient = async (client) => {
          if (!window.confirm(`Удалить клиента "${client.company_name}"?\nВсе связанные действия по этому клиенту тоже будут удалены.\nЭто действие нельзя отменить.`)) return;

          await requestJson(endpoint("/api/sales/clients", { id: client.id }), { method: "DELETE" });
          if (elements.clientForm.elements.id.value === client.id) resetClientForm({ close: true });
          await loadAll();
          status(`Клиент удалён: ${client.company_name}`, "success");
        };

        const deleteAction = async (action) => {
          if (!window.confirm(`Удалить действие по "${action.company_name}" от ${formatDate(action.action_date)}?\nЭто действие нельзя отменить.`)) return;

          await requestJson(endpoint("/api/sales/actions", { id: action.id }), { method: "DELETE" });
          if (elements.actionForm.elements.id.value === action.id) resetActionForm();
          await loadAll();
          status(`Действие удалено: ${action.company_name}`, "success");
        };

        root.addEventListener("click", (event) => {
          const tab = event.target.closest("[data-tab]");
          if (tab) {
            setTab(tab.dataset.tab);
            return;
          }

          const editClient = event.target.closest("[data-edit-client]");
          if (editClient) {
            const client = state.clients.find((entry) => entry.id === editClient.dataset.editClient);
            if (client) fillClientForm(client);
            return;
          }

          const editAction = event.target.closest("[data-edit-action]");
          if (editAction) {
            const action = state.actions.find((entry) => entry.id === editAction.dataset.editAction);
            if (action) fillActionForm(action);
            return;
          }

          const uploadActionButton = event.target.closest("[data-upload-action]");
          if (uploadActionButton) {
            const input = uploadActionButton.closest(".sales-action-documents")?.querySelector("[data-action-document-input]");
            input?.click();
            return;
          }

          const deleteClientButton = event.target.closest("[data-delete-client]");
          if (deleteClientButton) {
            const client = state.clients.find((entry) => entry.id === deleteClientButton.dataset.deleteClient);
            if (client) deleteClient(client).catch((error) => status(error.message, "error"));
            return;
          }

          const deleteActionButton = event.target.closest("[data-delete-action]");
          if (deleteActionButton) {
            const action = state.actions.find((entry) => entry.id === deleteActionButton.dataset.deleteAction);
            if (action) deleteAction(action).catch((error) => status(error.message, "error"));
            return;
          }

          const saveWeekButton = event.target.closest("[data-save-week]");
          if (saveWeekButton) {
            saveWeek(saveWeekButton.closest("tr")).catch((error) => status(error.message, "error"));
          }
        });

        root.addEventListener("change", (event) => {
          const formInput = event.target.closest("[data-action-form-document-input]");
          if (formInput) {
            state.pendingActionDocuments = Array.from(formInput.files || []);
            try {
              validatePendingActionDocuments(elements.actionForm.elements.id.value);
              renderPendingActionDocuments();
              if (state.pendingActionDocuments.length) {
                status(`Документы выбраны: ${state.pendingActionDocuments.length}. Сохраните действие для загрузки.`, "success");
              }
            } catch (error) {
              state.pendingActionDocuments = [];
              formInput.value = "";
              renderPendingActionDocuments();
              status(error.message, "error");
            }
            return;
          }

          const input = event.target.closest("[data-action-document-input]");
          if (!input) return;
          const action = state.actions.find((entry) => entry.id === input.dataset.actionDocumentInput);
          if (!action) return;
          uploadActionDocuments(action, input).catch((error) => status(error.message, "error"));
        });

        elements.loginForm.addEventListener("submit", (event) => {
          event.preventDefault();
          login(elements.loginForm);
        });
        elements.logout.addEventListener("click", logout);
        elements.refresh.addEventListener("click", () => loadAll().catch((error) => status(error.message, "error")));
        elements.clientForm.addEventListener("submit", (event) => {
          event.preventDefault();
          saveClient(elements.clientForm).catch((error) => status(error.message, "error"));
        });
        elements.actionForm.addEventListener("submit", (event) => {
          event.preventDefault();
          saveAction(elements.actionForm).catch((error) => status(error.message, "error"));
        });
        elements.quickToggle.addEventListener("click", () => {
          setQuickFormExpanded(elements.quickAddForm.classList.contains("is-collapsed"));
        });
        elements.clientReset.addEventListener("click", () => resetClientForm());
        elements.actionToggle.addEventListener("click", () => {
          setActionFormExpanded(elements.actionForm.classList.contains("is-collapsed"));
        });
        elements.actionReset.addEventListener("click", resetActionForm);
        elements.actionDocumentTrigger.addEventListener("click", () => elements.actionDocumentInput.click());
        elements.actionClientSelect.addEventListener("change", updateActionClientSummary);
        elements.actionForm.elements.status.addEventListener("change", updateActionCompletionFields);
        elements.exportXlsx.addEventListener("click", exportXlsx);
        elements.importPrototype.addEventListener("click", () => importPrototype().catch((error) => status(error.message, "error")));
        elements.mobileFilterToggle?.addEventListener("click", () => {
          setMobileFiltersOpen(elements.mobileFilterbar?.classList.contains("is-mobile-collapsed"));
          queueCustomScrollbarUpdate();
        });

        [elements.actionMode, elements.actionFilterStatus, elements.actionFilterType, elements.actionFilterCompany].forEach((element) => {
          element.addEventListener("change", () => {
            updateMobileFilterSummary();
            loadActions().then(renderActions).catch((error) => status(error.message, "error"));
          });
          element.addEventListener("input", () => {
            updateMobileFilterSummary();
            loadActions().then(renderActions).catch((error) => status(error.message, "error"));
          });
        });

        [elements.clientSearch, elements.clientStatus, elements.clientSegment].forEach((element) => {
          element.addEventListener("input", renderClients);
          element.addEventListener("change", renderClients);
        });

        setupDatePickers();
        elements.today.addEventListener("change", () => loadAll().catch((error) => status(error.message, "error")));

        setDateInput(elements.today, localToday());
        updateMobileFilterSummary();
        resetClientForm({ close: true });
        resetActionForm();
        setQuickFormExpanded(false);
        setActionFormExpanded(false);
        setupCustomScrollbars();

        requestJson("/api/sales/session")
          .then(async (session) => {
            setAuthenticated(session);
            if (session.authenticated) await loadAll();
          })
          .catch(() => setAuthenticated({ user: null }));
      })();
    </script>
  </body>
</html>
