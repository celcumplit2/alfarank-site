    <script is:inline>
      (() => {
        const root = document.querySelector("[data-sales-app]");
        if (!root) return;

        const state = {
          user: null,
          users: [],
          overview: null,
          clients: [],
          actions: [],
          activeTab: "dashboard"
        };

        const elements = {
          loginPanel: root.querySelector("[data-login-panel]"),
          loginForm: root.querySelector("[data-login-form]"),
          loginStatus: root.querySelector("[data-login-status]"),
          workspace: root.querySelector("[data-workspace]"),
          sessionName: root.querySelector("[data-session-name]"),
          logout: root.querySelector("[data-logout]"),
          globalStatus: root.querySelector("[data-global-status]"),
          mobileFilterToggle: root.querySelector("[data-mobile-filter-toggle]"),
          mobileFilterbar: root.querySelector("[data-mobile-filterbar]"),
          mobileFilterSummary: root.querySelector("[data-mobile-filter-summary]"),
          today: root.querySelector("[data-today]"),
          refresh: root.querySelector("[data-refresh]"),
          actionMode: root.querySelector("[data-action-mode]"),
          actionFilterStatus: root.querySelector("[data-action-filter-status]"),
          actionFilterType: root.querySelector("[data-action-filter-type]"),
          actionFilterCompany: root.querySelector("[data-action-filter-company]"),
          metrics: root.querySelector("[data-metrics]"),
          planDays: root.querySelector("[data-plan-days]"),
          upcomingActions: root.querySelector("[data-upcoming-actions]"),
          auditList: root.querySelector("[data-audit-list]"),
          quickAddForm: root.querySelector("[data-quick-add-form]"),
          quickOwnerField: root.querySelector("[data-quick-owner-field]"),
          quickOwnerSelect: root.querySelector("[data-quick-owner-select]"),
          clientForm: root.querySelector("[data-client-form]"),
          clientFormTitle: root.querySelector("[data-client-form-title]"),
          clientOwnerField: root.querySelector("[data-client-owner-field]"),
          clientOwnerSelect: root.querySelector("[data-client-owner-select]"),
          clientReset: root.querySelector("[data-client-reset]"),
          clientSearch: root.querySelector("[data-client-search]"),
          clientStatus: root.querySelector("[data-client-status]"),
          clientSegment: root.querySelector("[data-client-segment]"),
          clientsTable: root.querySelector("[data-clients-table]"),
          actionForm: root.querySelector("[data-action-form]"),
          actionFormTitle: root.querySelector("[data-action-form-title]"),
          actionReset: root.querySelector("[data-action-reset]"),
          actionClientSelect: root.querySelector("[data-action-client-select]"),
          actionClientSummary: root.querySelector("[data-action-client-summary]"),
          actionsTable: root.querySelector("[data-actions-table]"),
          weeklyTable: root.querySelector("[data-weekly-table]"),
          exportXlsx: root.querySelector("[data-export-xlsx]"),
          importPrototype: root.querySelector("[data-import-prototype]")
        };

        const localToday = () => {
          const date = new Date();
          date.setMinutes(date.getMinutes() - date.getTimezoneOffset());
          return date.toISOString().slice(0, 10);
        };

        const escapeHtml = (value) =>
          String(value ?? "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#39;");

        const compact = (value, max = 110) => {
          const text = String(value ?? "").replace(/\s+/g, " ").trim();
          return text.length > max ? `${text.slice(0, max - 3).trimEnd()}...` : text;
        };

        const status = (message, mode = "") => {
          elements.globalStatus.textContent = message || "";
          elements.globalStatus.classList.toggle("is-error", mode === "error");
          elements.globalStatus.classList.toggle("is-success", mode === "success");
        };

        const updateMobileFilterSummary = () => {
          if (!elements.mobileFilterSummary || !elements.actionMode) return;
          const selectedMode = elements.actionMode.selectedOptions?.[0]?.textContent?.trim() || "";
          elements.mobileFilterSummary.textContent = selectedMode || "Все";
        };

        const setMobileFiltersOpen = (open) => {
          if (!elements.mobileFilterToggle || !elements.mobileFilterbar) return;
          elements.mobileFilterbar.classList.toggle("is-mobile-collapsed", !open);
          elements.mobileFilterToggle.setAttribute("aria-expanded", String(open));
          updateMobileFilterSummary();
        };

        const endpoint = (path, params = {}) => {
          const url = new URL(path, window.location.origin);
          Object.entries(params).forEach(([key, value]) => {
            if (value !== "" && value !== null && value !== undefined && value !== false) {
              url.searchParams.set(key, String(value));
            }
          });
          return `${url.pathname}${url.search}`;
        };

        const requestJson = async (path, options = {}) => {
          const response = await fetch(path, {
            cache: "no-store",
            credentials: "same-origin",
            ...options,
            headers: {
              ...(options.body ? { "content-type": "application/json" } : {}),
              ...(options.headers || {})
            }
          });
          const text = await response.text();
          let payload = {};
          try {
            payload = text ? JSON.parse(text) : {};
          } catch {
            payload = { error: text || response.statusText };
          }
          if (!response.ok) throw new Error(payload.error || "Запрос не выполнен.");
          return payload;
        };

        const formData = (form) => Object.fromEntries(new FormData(form).entries());

        const normalizeCheckboxes = (form, payload) => {
          form.querySelectorAll("input[type='checkbox'][name]").forEach((input) => {
            payload[input.name] = input.checked;
          });
          return payload;
        };

        const managerUsers = () => state.users.filter((user) => user.role === "manager");

        const userLabel = (id) => {
          const user = state.users.find((entry) => entry.id === id || entry.username === id);
          return user ? user.name : id || "-";
        };

        const ownerOptions = (selected = "") => {
          const managers = managerUsers();
          return managers
            .map((manager) => `<option value="${escapeHtml(manager.id)}" ${manager.id === selected ? "selected" : ""}>${escapeHtml(manager.name)}</option>`)
            .join("");
        };

        const renderOwnerControls = () => {
          const canAssign = state.user && state.user.role !== "manager";
          const managers = managerUsers();
          const defaultOwner = canAssign ? managers[0]?.id || "pavel" : state.user?.id || "";

          [elements.quickOwnerSelect, elements.clientOwnerSelect].forEach((select) => {
            if (!select) return;
            const selected = managers.some((manager) => manager.id === select.value) ? select.value : defaultOwner;
            select.innerHTML = ownerOptions(selected);
            select.disabled = !canAssign;
          });

          elements.quickOwnerField.hidden = !canAssign;
          elements.clientOwnerField.hidden = !canAssign;
        };

        const setAuthenticated = (session) => {
          state.user = session.user || null;
          state.users = session.users || state.users || [];
          const authenticated = Boolean(state.user);
          elements.loginPanel.hidden = authenticated;
          elements.workspace.hidden = !authenticated;
          elements.logout.hidden = !authenticated;
          elements.sessionName.textContent = authenticated
            ? `${state.user.name} / ${state.user.role}`
            : "Не выполнен вход";
          renderOwnerControls();
        };

        const metric = (label, value, hint = "") => `
          <article class="sales-metric">
            <span>${escapeHtml(label)}</span>
            <strong>${escapeHtml(value ?? 0)}</strong>
            ${hint ? `<span>${escapeHtml(hint)}</span>` : ""}
          </article>
        `;

        const renderMetrics = () => {
          const m = state.overview?.metrics || {};
          const g = state.overview?.goals || {};
          elements.metrics.innerHTML = [
            metric("Цель клиентов / 60 дней", g.clients || 10, "MVP цель"),
            metric("Клиентов факт", m.clients_count || 0),
            metric("Компаний в базе", m.companies_count || 0),
            metric("Встреч", m.meetings_count || 0),
            metric("КП отправлено", m.proposals_count || 0),
            metric("Просрочено", m.overdue_count || 0),
            metric("Сегодня", m.today_count || 0),
            metric("Без следующего шага", m.without_next_step_count || 0)
          ].join("");
        };

        const rowState = (date, statusValue) => {
          const today = elements.today.value;
          if (statusValue === "Сделано") return "done";
          if (date < today) return "overdue";
          if (date === today) return "today";
          return "";
        };

        const renderPlan = () => {
          elements.planDays.innerHTML = (state.overview?.plan_days || [])
            .map(
              (row) => `
                <tr>
                  <td>${escapeHtml(row.plan_date)}</td>
                  <td>${escapeHtml(row.focus)}</td>
                  <td>${escapeHtml(row.new_companies)}</td>
                  <td>${escapeHtml(row.contacts)}</td>
                  <td>${escapeHtml(row.meetings)}</td>
                  <td>${escapeHtml(row.proposals)}</td>
                  <td>${escapeHtml(row.main_result)}</td>
                </tr>
              `
            )
            .join("");
        };

        const renderUpcoming = () => {
          const rows = state.overview?.upcoming_actions || [];
          elements.upcomingActions.innerHTML = rows.length
            ? rows
                .map(
                  (action) => `
                    <article>
                      <strong>${escapeHtml(action.action_date)} / ${escapeHtml(action.company_name)}</strong>
                      <span>${escapeHtml(action.priority)} · ${escapeHtml(action.action_type)} · ${escapeHtml(action.status)}</span>
                      <span>${escapeHtml(compact(action.task, 160))}</span>
                    </article>
                  `
                )
                .join("")
            : `<article><strong>Нет ближайших действий</strong><span>Очередь пуста для выбранной даты.</span></article>`;
        };

        const renderAudit = () => {
          const rows = state.overview?.recent_audit || [];
          elements.auditList.innerHTML = rows.length
            ? rows
                .map(
                  (event) => `
                    <article>
                      <strong>${escapeHtml(event.action)} · ${escapeHtml(event.entity_type)}</strong>
                      <span>${escapeHtml(event.actor_id)} / ${escapeHtml(event.created_at)}</span>
                    </article>
                  `
                )
                .join("")
            : `<article><strong>История пока пустая</strong><span>Изменения будут записываться автоматически.</span></article>`;
        };

        const renderClients = () => {
          const search = elements.clientSearch.value.trim().toLowerCase();
          const statusValue = elements.clientStatus.value;
          const segmentValue = elements.clientSegment.value;
          const rows = state.clients.filter((client) => {
            const matchesSearch = !search || [client.company_name, client.contact_name, client.city].join(" ").toLowerCase().includes(search);
            const matchesStatus = !statusValue || client.status === statusValue;
            const matchesSegment = !segmentValue || client.segment === segmentValue;
            return matchesSearch && matchesStatus && matchesSegment;
          });

          elements.clientsTable.innerHTML = rows.length
            ? rows
                .map(
                  (client) => `
                    <tr data-state="${rowState(client.next_action_at || "9999-12-31", client.status === "Клиент" ? "Сделано" : "")}">
                      <td><strong>${escapeHtml(client.company_name)}</strong><br /><span>${escapeHtml(client.contact_name || "")}</span></td>
                      <td>${escapeHtml(client.segment)}</td>
                      <td><span class="sales-pill">${escapeHtml(client.status)}</span></td>
                      <td>${escapeHtml(compact(client.next_action, 120))}</td>
                      <td>${escapeHtml(client.next_action_at || "-")}</td>
                      <td>${escapeHtml(client.potential)}</td>
                      <td>${escapeHtml(userLabel(client.owner_id))}</td>
                      <td>${escapeHtml(client.open_actions_count || 0)} / ${escapeHtml(client.overdue_actions_count || 0)} проср.</td>
                      <td><button class="sales-button sales-button--ghost" type="button" data-edit-client="${escapeHtml(client.id)}">Ред.</button></td>
                    </tr>
                  `
                )
                .join("")
            : `<tr><td colspan="9">Клиенты не найдены.</td></tr>`;
        };

        const selectedActionClient = () => state.clients.find((client) => client.id === elements.actionClientSelect.value);

        const updateActionClientSummary = () => {
          const client = selectedActionClient();
          elements.actionClientSummary.textContent = client
            ? `${client.company_name}${client.contact_name ? ` / ${client.contact_name}` : ""}`
            : "Выберите клиента из базы. Компания и контакт подтянутся из карточки клиента.";
          elements.actionClientSummary.classList.toggle("is-selected", Boolean(client));
        };

        const renderClientSelect = () => {
          const selected = elements.actionClientSelect.value;
          const hasSelected = state.clients.some((client) => client.id === selected);
          elements.actionClientSelect.innerHTML = [
            `<option value="" disabled ${hasSelected ? "" : "selected"}>Выберите клиента</option>`,
            ...state.clients.map((client) => `<option value="${escapeHtml(client.id)}" ${client.id === selected ? "selected" : ""}>${escapeHtml(client.company_name)}</option>`)
          ].join("");
          updateActionClientSummary();
        };

        const renderActions = () => {
          elements.actionsTable.innerHTML = state.actions.length
            ? state.actions
                .map(
                  (action) => `
                    <tr data-state="${rowState(action.action_date, action.status)}">
                      <td>${escapeHtml(action.action_date)}</td>
                      <td><strong>${escapeHtml(action.company_name)}</strong><br /><span>${escapeHtml(action.contact_name || "")}</span></td>
                      <td>${escapeHtml(action.priority)}</td>
                      <td>${escapeHtml(action.action_type)}</td>
                      <td>${escapeHtml(compact(action.task, 150))}</td>
                      <td><span class="sales-pill">${escapeHtml(action.status)}</span></td>
                      <td>${escapeHtml(compact(action.next_step, 120))}<br /><span>${escapeHtml(action.next_step_date || "")}</span></td>
                      <td>${escapeHtml(userLabel(action.owner_id))}</td>
                      <td><button class="sales-button sales-button--ghost" type="button" data-edit-action="${escapeHtml(action.id)}">Ред.</button></td>
                    </tr>
                  `
                )
                .join("")
            : `<tr><td colspan="9">Нет действий для выбранного режима.</td></tr>`;
        };

        const renderWeekly = () => {
          const rows = state.overview?.weekly_reviews || [];
          elements.weeklyTable.innerHTML = rows.length
            ? rows
                .map(
                  (week) => `
                    <tr data-week-id="${escapeHtml(week.id)}" data-week-start="${escapeHtml(week.week_start)}" data-manager-id="${escapeHtml(week.manager_id)}">
                      <td>${escapeHtml(week.week_start)}</td>
                      <td>${escapeHtml(userLabel(week.manager_id))}</td>
                      <td>${escapeHtml(week.new_companies || 0)}</td>
                      <td>${escapeHtml(week.done_actions || 0)}</td>
                      <td>${escapeHtml(week.meetings || 0)}</td>
                      <td>${escapeHtml(week.proposals || 0)}</td>
                      <td>${escapeHtml(week.new_clients || 0)}</td>
                      <td>${escapeHtml(week.overdue_actions || 0)}</td>
                      <td><textarea data-week-manager>${escapeHtml(week.manager_comment || "")}</textarea></td>
                      <td><textarea data-week-director>${escapeHtml(week.director_comment || "")}</textarea></td>
                      <td><button class="sales-button sales-button--ghost" type="button" data-save-week>Сохранить</button></td>
                    </tr>
                  `
                )
                .join("")
            : `<tr><td colspan="10">Недельные итоги не найдены.</td></tr>`;
        };

        const renderAll = () => {
          renderMetrics();
          renderPlan();
          renderUpcoming();
          renderAudit();
          renderClients();
          renderClientSelect();
          renderActions();
          renderWeekly();
        };

        const loadOverview = async () => {
          state.overview = await requestJson(endpoint("/api/sales/overview", { today: elements.today.value }));
        };

        const loadClients = async () => {
          const payload = await requestJson("/api/sales/clients");
          state.clients = payload.clients || [];
        };

        const actionParams = () => ({
          today: elements.today.value,
          mode: elements.actionMode.value,
          status: elements.actionFilterStatus.value,
          action_type: elements.actionFilterType.value,
          company: elements.actionFilterCompany.value
        });

        const loadActions = async () => {
          const payload = await requestJson(endpoint("/api/sales/actions", actionParams()));
          state.actions = payload.actions || [];
        };

        const loadAll = async () => {
          status("Загружаю данные...");
          await Promise.all([loadOverview(), loadClients(), loadActions()]);
          renderAll();
          status(`Обновлено: ${new Date().toLocaleTimeString("ru-RU")}`, "success");
        };

        const loadAllSafely = async () => {
          try {
            await loadAll();
          } catch (error) {
            renderAll();
            status(error.message || "Не удалось загрузить данные.", "error");
          }
        };

        const resetClientForm = () => {
          elements.clientForm.reset();
          elements.clientForm.elements.id.value = "";
          elements.clientForm.elements.status.value = "Новый";
          elements.clientForm.elements.potential.value = "Средний";
          renderOwnerControls();
          elements.clientFormTitle.textContent = "Новый клиент";
        };

        const resetActionForm = () => {
          elements.actionForm.reset();
          elements.actionForm.elements.id.value = "";
          elements.actionForm.elements.action_date.value = elements.today.value;
          elements.actionForm.elements.priority.value = "Средний";
          elements.actionForm.elements.action_type.value = "Звонок";
          elements.actionForm.elements.status.value = "Запланировано";
          elements.actionFormTitle.textContent = "Новое действие";
          updateActionClientSummary();
        };

        const fillClientForm = (client) => {
          resetClientForm();
          Object.entries(client).forEach(([key, value]) => {
            if (elements.clientForm.elements[key]) elements.clientForm.elements[key].value = value || "";
          });
          elements.clientFormTitle.textContent = client.company_name || "Клиент";
          setTab("clients");
        };

        const fillActionForm = (action) => {
          resetActionForm();
          Object.entries(action).forEach(([key, value]) => {
            if (elements.actionForm.elements[key]) {
              if (elements.actionForm.elements[key].type === "checkbox") {
                elements.actionForm.elements[key].checked = Boolean(value);
              } else {
                elements.actionForm.elements[key].value = value || "";
              }
            }
          });
          elements.actionFormTitle.textContent = `${action.company_name} / ${action.action_date}`;
          updateActionClientSummary();
          setTab("actions");
        };

        const setTab = (tab) => {
          state.activeTab = tab;
          root.querySelectorAll("[data-tab]").forEach((button) => button.classList.toggle("is-active", button.dataset.tab === tab));
          root.querySelectorAll("[data-view]").forEach((view) => view.classList.toggle("is-active", view.dataset.view === tab));
        };

        const saveClient = async (form) => {
          const payload = formData(form);
          await requestJson("/api/sales/clients", {
            method: "POST",
            body: JSON.stringify(payload)
          });
          resetClientForm();
          await loadAll();
        };

        const saveAction = async (form) => {
          const payload = normalizeCheckboxes(form, formData(form));
          if (!payload.client_id) {
            throw new Error("Выберите клиента для действия.");
          }
          await requestJson("/api/sales/actions", {
            method: "POST",
            body: JSON.stringify(payload)
          });
          resetActionForm();
          await loadAll();
        };

        const quickAdd = async (form) => {
          const payload = formData(form);
          const client = await requestJson("/api/sales/clients", {
            method: "POST",
            body: JSON.stringify({
              company_name: payload.company_name,
              segment: payload.segment,
              contact_name: payload.contact_name,
              status: "Новый",
              potential: payload.potential,
              next_action: payload.task,
              next_action_at: payload.action_date,
              source: "Ручное добавление"
            })
          });
          await requestJson("/api/sales/actions", {
            method: "POST",
            body: JSON.stringify({
              action_date: payload.action_date,
              client_id: client.client.id,
              priority: payload.potential,
              action_type: "Звонок",
              task: payload.task,
              status: "Запланировано"
            })
          });
          form.reset();
          form.elements.action_date.value = elements.today.value;
          renderOwnerControls();
          await loadAll();
          status("Компания и первое действие добавлены.", "success");
        };

        const login = async (form) => {
          elements.loginStatus.textContent = "Проверяю доступ...";
          elements.loginStatus.dataset.mode = "";
          try {
            const session = await requestJson("/api/sales/session", {
              method: "POST",
              body: JSON.stringify(formData(form))
            });
            setAuthenticated(session);
          } catch (error) {
            elements.loginStatus.textContent = error.message || "Не удалось войти.";
            elements.loginStatus.dataset.mode = "error";
            return;
          }

          await loadAllSafely();
        };

        const logout = async () => {
          await fetch("/api/sales/session", { method: "DELETE", credentials: "same-origin" });
          setAuthenticated({ user: null });
          status("");
        };

        const saveWeek = async (row) => {
          await requestJson("/api/sales/weekly", {
            method: "POST",
            body: JSON.stringify({
              id: row.dataset.weekId,
              week_start: row.dataset.weekStart,
              manager_id: row.dataset.managerId,
              manager_comment: row.querySelector("[data-week-manager]").value,
              director_comment: row.querySelector("[data-week-director]").value
            })
          });
          await loadOverview();
          renderWeekly();
          status("Итоги недели сохранены.", "success");
        };

        const exportXlsx = () => {
          window.location.href = endpoint("/api/sales/export", { today: elements.today.value });
        };

        const importPrototype = async () => {
          await requestJson("/api/sales/import-prototype", { method: "POST", body: "{}" });
          await loadAll();
          status("Прототип импортирован без дублей.", "success");
        };

        root.addEventListener("click", (event) => {
          const tab = event.target.closest("[data-tab]");
          if (tab) {
            setTab(tab.dataset.tab);
            return;
          }

          const editClient = event.target.closest("[data-edit-client]");
          if (editClient) {
            const client = state.clients.find((entry) => entry.id === editClient.dataset.editClient);
            if (client) fillClientForm(client);
            return;
          }

          const editAction = event.target.closest("[data-edit-action]");
          if (editAction) {
            const action = state.actions.find((entry) => entry.id === editAction.dataset.editAction);
            if (action) fillActionForm(action);
            return;
          }

          const saveWeekButton = event.target.closest("[data-save-week]");
          if (saveWeekButton) {
            saveWeek(saveWeekButton.closest("tr")).catch((error) => status(error.message, "error"));
          }
        });

        elements.loginForm.addEventListener("submit", (event) => {
          event.preventDefault();
          login(elements.loginForm);
        });
        elements.logout.addEventListener("click", logout);
        elements.refresh.addEventListener("click", loadAllSafely);
        elements.quickAddForm.addEventListener("submit", (event) => {
          event.preventDefault();
          quickAdd(elements.quickAddForm).catch((error) => status(error.message, "error"));
        });
        elements.clientForm.addEventListener("submit", (event) => {
          event.preventDefault();
          saveClient(elements.clientForm).catch((error) => status(error.message, "error"));
        });
        elements.actionForm.addEventListener("submit", (event) => {
          event.preventDefault();
          saveAction(elements.actionForm).catch((error) => status(error.message, "error"));
        });
        elements.clientReset.addEventListener("click", resetClientForm);
        elements.actionReset.addEventListener("click", resetActionForm);
        elements.actionClientSelect.addEventListener("change", updateActionClientSummary);
        elements.exportXlsx.addEventListener("click", exportXlsx);
        elements.importPrototype.addEventListener("click", () => importPrototype().catch((error) => status(error.message, "error")));
        elements.mobileFilterToggle?.addEventListener("click", () => {
          setMobileFiltersOpen(elements.mobileFilterbar?.classList.contains("is-mobile-collapsed"));
        });

        [elements.actionMode, elements.actionFilterStatus, elements.actionFilterType, elements.actionFilterCompany].forEach((element) => {
          element.addEventListener("change", () => {
            updateMobileFilterSummary();
            loadActions().then(renderActions).catch((error) => status(error.message, "error"));
          });
          element.addEventListener("input", () => {
            updateMobileFilterSummary();
            loadActions().then(renderActions).catch((error) => status(error.message, "error"));
          });
        });

        [elements.clientSearch, elements.clientStatus, elements.clientSegment].forEach((element) => {
          element.addEventListener("input", renderClients);
          element.addEventListener("change", renderClients);
        });

        elements.today.value = localToday();
        elements.quickAddForm.elements.action_date.value = elements.today.value;
        updateMobileFilterSummary();
        resetClientForm();
        resetActionForm();

        requestJson("/api/sales/session")
          .then(async (session) => {
            setAuthenticated(session);
            if (session.authenticated) await loadAllSafely();
          })
          .catch(() => setAuthenticated({ user: null }));
      })();
    </script>
  </body>
</html>
