---
import BrandLogo from "@/components/BrandLogo.astro";
import LiquidBackground from "@/components/LiquidBackground.astro";
import globalStylesUrl from "@/styles/global.css?url";
import nativeSelectsUrl from "@/scripts/native-selects.js?url";

const segments = ["B2B услуги", "Локальный бизнес", "E-commerce", "Образование", "Медицина", "Другое"];
const clientStatuses = ["Новый", "Контакт", "Встреча назначена", "Встреча проведена", "КП отправлено", "Переговоры", "Клиент", "Отказ", "Пауза"];
const actionTypes = ["Поиск контакта", "Звонок", "Сообщение", "Встреча", "Повторный контакт", "КП отправлено", "Переговоры", "Другое"];
const actionStatuses = ["Запланировано", "В работе", "Сделано", "Перенесено", "Отменено"];
const priorities = ["Высокий", "Средний", "Низкий"];
const terminalStatuses = ["", "Клиент", "Отказ", "Пауза"];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Внутренний AlfaRank Sales Tracker." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href={globalStylesUrl} />
    <script type="module" src={nativeSelectsUrl}></script>
    <title>Sales Tracker | AlfaRank</title>
  </head>
  <body class="sales-body">
    <LiquidBackground />
    <main class="sales-app" data-sales-app data-no-translate>
      <header class="sales-topbar">
        <a class="sales-brand" href="/sales/" aria-label="AlfaRank Sales Tracker">
          <BrandLogo />
          <span>Sales Tracker</span>
        </a>
        <div class="sales-session" data-session-panel>
          <span data-session-name>Не выполнен вход</span>
          <button class="sales-button sales-button--ghost" type="button" data-logout hidden>Выйти</button>
        </div>
      </header>

      <section class="sales-login" data-login-panel>
        <div>
          <span class="sales-eyebrow">Внутренний контур</span>
          <h1>Ежедневные действия по компаниям</h1>
          <p>
            Быстрый рабочий слой поверх Excel-модели: кто следующий, что сделать сегодня,
            где просрочка и какие контакты закрыты результатом.
          </p>
        </div>
        <form class="sales-login-card" data-login-form>
          <label>
            <span>Пользователь</span>
            <select name="username">
              <option value="pavel">pavel / Павел</option>
              <option value="slava">slava / Слава</option>
              <option value="andrey">andrey / Андрей</option>
            </select>
          </label>
          <label>
            <span>Пароль</span>
            <input name="pin" type="password" autocomplete="current-password" placeholder="локальный пароль" />
          </label>
          <button class="sales-button sales-button--primary" type="submit">Открыть трекер</button>
          <p class="sales-status" data-login-status>Для продакшена пароли задаются через Cloudflare env.</p>
        </form>
      </section>

      <section class="sales-workspace" data-workspace hidden>
        <div class="sales-tabs" role="tablist" aria-label="Разделы sales tracker">
          <button class="sales-tab is-active" type="button" data-tab="dashboard">Панель</button>
          <button class="sales-tab" type="button" data-tab="clients">Клиенты</button>
          <button class="sales-tab" type="button" data-tab="actions">Действия</button>
          <button class="sales-tab" type="button" data-tab="weekly">Итоги недели</button>
          <button class="sales-tab" type="button" data-tab="guide">Регламент</button>
          <button class="sales-tab" type="button" data-tab="settings">Настройки</button>
        </div>

        <button
          class="sales-filter-toggle"
          type="button"
          aria-controls="sales-filterbar"
          aria-expanded="false"
          data-mobile-filter-toggle
        >
          <span>Сортировка</span>
          <strong data-mobile-filter-summary>Сегодня</strong>
        </button>

        <div class="sales-filterbar is-mobile-collapsed" id="sales-filterbar" data-mobile-filterbar>
          <label>
            <span>Рабочая дата</span>
            <input type="date" data-today />
          </label>
          <label>
            <span>Режим действий</span>
            <select data-action-mode>
              <option value="today">Сегодня</option>
              <option value="overdue">Просрочено</option>
              <option value="week">Следующие 7 дней</option>
              <option value="all">Все</option>
            </select>
          </label>
          <label>
            <span>Статус</span>
            <select data-action-filter-status>
              <option value="">Все</option>
              {actionStatuses.map((status) => <option value={status}>{status}</option>)}
            </select>
          </label>
          <label>
            <span>Тип</span>
            <select data-action-filter-type>
              <option value="">Все</option>
              {actionTypes.map((type) => <option value={type}>{type}</option>)}
            </select>
          </label>
          <label>
            <span>Компания</span>
            <input data-action-filter-company placeholder="поиск" />
          </label>
          <button class="sales-button" type="button" data-refresh>Обновить</button>
        </div>

        <section class="sales-view is-active" data-view="dashboard">
          <div class="sales-metrics" data-metrics></div>
          <div class="sales-grid sales-grid--dashboard">
            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">План первой недели</span>
                  <h2>Фокус по дням</h2>
                </div>
              </div>
              <div class="sales-table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Дата</th>
                      <th>Фокус</th>
                      <th>Новые</th>
                      <th>Контакты</th>
                      <th>Встречи</th>
                      <th>КП</th>
                      <th>Результат</th>
                    </tr>
                  </thead>
                  <tbody data-plan-days></tbody>
                </table>
              </div>
            </section>

            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Ближайшие</span>
                  <h2>Следующие действия</h2>
                </div>
              </div>
              <div class="sales-list" data-upcoming-actions></div>
            </section>
          </div>

          <section class="sales-panel">
            <div class="sales-panel-head">
              <div>
                <span class="sales-eyebrow">История</span>
                <h2>Последние изменения</h2>
              </div>
            </div>
            <div class="sales-list sales-list--compact" data-audit-list></div>
          </section>
        </section>

        <section class="sales-view" data-view="clients">
          <div class="sales-grid sales-grid--forms">
            <form class="sales-panel sales-form" data-quick-add-form>
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">30 секунд</span>
                  <h2>Компания + первое действие</h2>
                </div>
              </div>
              <label>
                <span>Компания</span>
                <input name="company_name" required />
              </label>
              <label>
                <span>Сегмент</span>
                <select name="segment">{segments.map((segment) => <option value={segment}>{segment}</option>)}</select>
              </label>
              <label>
                <span>Контакт</span>
                <input name="contact_name" />
              </label>
              <label>
                <span>Что сделать</span>
                <input name="task" required placeholder="Позвонить и назначить встречу" />
              </label>
              <label>
                <span>Дата</span>
                <input name="action_date" type="date" required />
              </label>
              <label>
                <span>Потенциал</span>
                <select name="potential">{priorities.map((priority) => <option value={priority}>{priority}</option>)}</select>
              </label>
              <label data-quick-owner-field hidden>
                <span>Менеджер</span>
                <select name="owner_id" data-quick-owner-select></select>
              </label>
              <button class="sales-button sales-button--primary" type="submit">Добавить</button>
            </form>

            <form class="sales-panel sales-form" data-client-form>
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Карточка</span>
                  <h2 data-client-form-title>Новый клиент</h2>
                </div>
                <button class="sales-button sales-button--ghost" type="button" data-client-reset>Очистить</button>
              </div>
              <input name="id" type="hidden" />
              <label>
                <span>Компания</span>
                <input name="company_name" required />
              </label>
              <label>
                <span>Сегмент</span>
                <select name="segment">{segments.map((segment) => <option value={segment}>{segment}</option>)}</select>
              </label>
              <label>
                <span>Статус</span>
                <select name="status">{clientStatuses.map((status) => <option value={status}>{status}</option>)}</select>
              </label>
              <label>
                <span>Потенциал</span>
                <select name="potential">{priorities.map((priority) => <option value={priority}>{priority}</option>)}</select>
              </label>
              <label data-client-owner-field hidden>
                <span>Менеджер</span>
                <select name="owner_id" data-client-owner-select></select>
              </label>
              <label>
                <span>Сайт</span>
                <input name="website" />
              </label>
              <label>
                <span>Город</span>
                <input name="city" />
              </label>
              <label>
                <span>Контакт</span>
                <input name="contact_name" />
              </label>
              <label>
                <span>Должность</span>
                <input name="contact_role" />
              </label>
              <label class="sales-wide">
                <span>Телефон / Email</span>
                <input name="contact_details" />
              </label>
              <label>
                <span>Следующее действие</span>
                <input name="next_action" required />
              </label>
              <label>
                <span>Дата следующего</span>
                <input name="next_action_at" type="date" required />
              </label>
              <label class="sales-wide">
                <span>Комментарий</span>
                <textarea name="comment"></textarea>
              </label>
              <button class="sales-button sales-button--primary" type="submit">Сохранить клиента</button>
            </form>
          </div>

          <section class="sales-panel">
            <div class="sales-panel-head">
              <div>
                <span class="sales-eyebrow">База</span>
                <h2>Клиенты</h2>
              </div>
              <div class="sales-inline-filters">
                <input data-client-search placeholder="поиск клиента" />
                <select data-client-status>
                  <option value="">Все статусы</option>
                  {clientStatuses.map((status) => <option value={status}>{status}</option>)}
                </select>
                <select data-client-segment>
                  <option value="">Все сегменты</option>
                  {segments.map((segment) => <option value={segment}>{segment}</option>)}
                </select>
              </div>
            </div>
            <div class="sales-table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Компания</th>
                    <th>Сегмент</th>
                    <th>Статус</th>
                    <th>Следующий шаг</th>
                    <th>Дата</th>
                    <th>Потенциал</th>
                    <th>Менеджер</th>
                    <th>Открыто</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody data-clients-table></tbody>
              </table>
            </div>
          </section>
        </section>

        <section class="sales-view" data-view="actions">
          <div class="sales-grid sales-grid--forms">
            <form class="sales-panel sales-form sales-form--action" data-action-form>
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Действие</span>
                  <h2 data-action-form-title>Новое действие</h2>
                </div>
                <button class="sales-button sales-button--ghost" type="button" data-action-reset>Очистить</button>
              </div>
              <input name="id" type="hidden" />
              <label>
                <span>Дата</span>
                <input name="action_date" type="date" required />
              </label>
              <label>
                <span>Клиент</span>
                <select name="client_id" data-action-client-select required>
                  <option value="" disabled selected>Выберите клиента</option>
                </select>
              </label>
              <div class="sales-client-lock sales-wide" data-action-client-summary>
                Выберите клиента из базы. Компания и контакт подтянутся из карточки клиента.
              </div>
              <label>
                <span>Приоритет</span>
                <select name="priority">{priorities.map((priority) => <option value={priority}>{priority}</option>)}</select>
              </label>
              <label>
                <span>Тип</span>
                <select name="action_type">{actionTypes.map((type) => <option value={type}>{type}</option>)}</select>
              </label>
              <label>
                <span>Статус</span>
                <select name="status">{actionStatuses.map((status) => <option value={status}>{status}</option>)}</select>
              </label>
              <label class="sales-wide">
                <span>Что конкретно сделать</span>
                <textarea name="task" required></textarea>
              </label>
              <label class="sales-wide">
                <span>Результат</span>
                <textarea name="result" placeholder="Обязательно для статуса Сделано"></textarea>
              </label>
              <label>
                <span>Следующий шаг</span>
                <input name="next_step" />
              </label>
              <label>
                <span>Дата следующего шага</span>
                <input name="next_step_date" type="date" />
              </label>
              <label>
                <span>Если завершено</span>
                <select name="final_client_status">{terminalStatuses.map((status) => <option value={status}>{status || "Не завершать клиента"}</option>)}</select>
              </label>
              <label class="sales-check">
                <input name="help_required" type="checkbox" />
                <span>Нужна помощь</span>
              </label>
              <label class="sales-wide">
                <span>Два варианта решения</span>
                <textarea name="solution_options" placeholder={"1. ...\n2. ..."}></textarea>
              </label>
              <button class="sales-button sales-button--primary" type="submit">Сохранить действие</button>
            </form>

            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Рабочая очередь</span>
                  <h2>Действия</h2>
                </div>
              </div>
              <div class="sales-table-wrap sales-table-wrap--tall">
                <table>
                  <thead>
                    <tr>
                      <th>Дата</th>
                      <th>Компания</th>
                      <th>Приоритет</th>
                      <th>Тип</th>
                      <th>Задача</th>
                      <th>Статус</th>
                      <th>Следующий шаг</th>
                      <th>Менеджер</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody data-actions-table></tbody>
                </table>
              </div>
            </section>
          </div>
        </section>

        <section class="sales-view" data-view="weekly">
          <section class="sales-panel">
            <div class="sales-panel-head">
              <div>
                <span class="sales-eyebrow">Контроль</span>
                <h2>Итоги недели</h2>
              </div>
            </div>
            <div class="sales-table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Неделя с</th>
                    <th>Менеджер</th>
                    <th>Новые компании</th>
                    <th>Действия</th>
                    <th>Встречи</th>
                    <th>КП</th>
                    <th>Клиенты</th>
                    <th>Просрочено</th>
                    <th>Комментарий менеджера</th>
                    <th>Комментарий руководителя</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody data-weekly-table></tbody>
              </table>
            </div>
          </section>
        </section>

        <section class="sales-view" data-view="guide">
          <div class="sales-guide-layout">
            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Рабочий цикл</span>
                  <h2>Как вести день</h2>
                </div>
              </div>
              <ol class="sales-guide-steps">
                <li>
                  <strong>Открой рабочую дату.</strong>
                  <span>В начале дня поставь сегодняшнюю дату и режим действий “Сегодня”. Сначала разбираются просроченные, затем сегодняшние.</span>
                </li>
                <li>
                  <strong>Проверь панель.</strong>
                  <span>Смотри количество компаний, встреч, КП, просрочек и ближайшие действия. Это короткий снимок состояния на день.</span>
                </li>
                <li>
                  <strong>Работай из вкладки “Действия”.</strong>
                  <span>Для нового действия сначала выбери клиента из базы. Компания и контакт берутся из карточки, а в действии фиксируются дата, тип, задача и результат.</span>
                </li>
                <li>
                  <strong>Закрывай действие только с результатом.</strong>
                  <span>Для статуса “Сделано” обязательно запиши результат. Затем укажи следующий шаг и дату либо заверши компанию статусом “Клиент”, “Отказ” или “Пауза”.</span>
                </li>
                <li>
                  <strong>В конце дня обнови очередь.</strong>
                  <span>У активных компаний не должно оставаться пустого следующего шага. Если нужна помощь руководителя, отметь это и добавь два варианта решения.</span>
                </li>
              </ol>
            </section>

            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Быстрый ввод</span>
                  <h2>Новая компания</h2>
                </div>
              </div>
              <div class="sales-guide-cards">
                <article>
                  <strong>Минимум для старта</strong>
                  <span>Компания, сегмент, первое действие, дата и потенциал. Действия по этой компании дальше ведутся только через выбор клиента из списка.</span>
                </article>
                <article>
                  <strong>Карточка клиента</strong>
                  <span>Используй её, когда уже есть контакт, роль, телефон/email, сайт, город, комментарий и понятный следующий шаг.</span>
                </article>
                <article>
                  <strong>Нельзя оставлять активного клиента без шага</strong>
                  <span>Если статус не финальный, система требует следующий шаг и дату следующего действия.</span>
                </article>
              </div>
            </section>

            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Контроль</span>
                  <h2>Неделя и руководитель</h2>
                </div>
              </div>
              <div class="sales-guide-cards">
                <article>
                  <strong>Менеджер</strong>
                  <span>В конце недели добавляет короткий комментарий: что сработало, где стопор, какие компании требуют решения.</span>
                </article>
                <article>
                  <strong>Руководитель</strong>
                  <span>Смотрит итоговые цифры, просрочки, комментарии и фиксирует решение или приоритет на следующую неделю.</span>
                </article>
                <article>
                  <strong>Audit log</strong>
                  <span>Изменения пишутся в историю без отдельного интерфейса: кто создал, обновил, закрыл, импортировал или изменил регламентные данные.</span>
                </article>
              </div>
            </section>

            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Файл</span>
                  <h2>Экспорт XLSX</h2>
                </div>
              </div>
              <div class="sales-guide-cards">
                <article>
                  <strong>Когда выгружать</strong>
                  <span>Перед созвоном, недельным разбором или передачей статуса. Экспорт собирает панель, клиентов, действия, итоги недели и историю.</span>
                </article>
                <article>
                  <strong>Что не делать</strong>
                  <span>Не вести параллельный CSV как основную базу. Источником правды для MVP является трекер, XLSX нужен для передачи и анализа.</span>
                </article>
              </div>
            </section>
          </div>
        </section>

        <section class="sales-view" data-view="settings">
          <div class="sales-grid sales-grid--settings">
            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Excel</span>
                  <h2>Импорт / экспорт</h2>
                </div>
              </div>
              <div class="sales-actions-stack">
                <button class="sales-button sales-button--primary" type="button" data-export-xlsx>Экспортировать XLSX</button>
                <button class="sales-button" type="button" data-import-prototype>Импортировать прототип ещё раз</button>
                <p>Импорт прототипа идемпотентный: повторный запуск не создаёт дубликаты базовых строк.</p>
              </div>
            </section>
            <section class="sales-panel">
              <div class="sales-panel-head">
                <div>
                  <span class="sales-eyebrow">Пользователи MVP</span>
                  <h2>Павел, Слава, Андрей</h2>
                </div>
              </div>
              <div class="sales-list">
                <article><strong>pavel</strong><span>Павел: менеджер, видит и ведёт только свои компании и действия.</span></article>
                <article><strong>slava</strong><span>Слава: менеджер, видит и ведёт только свои компании и действия.</span></article>
                <article><strong>andrey</strong><span>Андрей: руководитель и админ, видит всё и назначает клиентов менеджерам.</span></article>
              </div>
            </section>
          </div>
        </section>

        <p class="sales-status sales-status--global" data-global-status></p>
      </section>
