---
import PageHero from "@/components/PageHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { requestReceivedHeroVisual } from "@/data/hero";

const nextRoutes = [
  { title: "Capabilities", text: "Review possible build directions", href: "/capabilities/", icon: "tools" },
  { title: "Solutions", text: "Map the business problem", href: "/solutions/", icon: "flow" },
  { title: "Systems", text: "Explore operating patterns", href: "/systems/", icon: "product" }
];

const reviewStages = [
  { title: "Received", text: "Request context and source tracking are stored.", icon: "lead" },
  { title: "Mapped", text: "The workflow, system type, and expected output are reviewed.", icon: "flow" },
  { title: "Scoped", text: "A first launch path can be shaped from the submitted details.", icon: "ranking" }
];
---

<Layout title="Project Request Received | AlfaRank">
  <PageHero
    eyebrow="Request received"
    title="Your project request has been submitted."
    text="AlfaRank will review the project type, business problem, current system, and desired result before the next step."
    primaryHref="/"
    primaryLabel="Back to Home"
    secondaryHref="/capabilities/"
    secondaryLabel="Explore Capabilities"
    visual={requestReceivedHeroVisual}
  />

  <section class="section">
    <div class="request-next-dock ar-system-block">
      <article class="request-next-dock__core ar-system-core">
        <SystemIcon name="monitor" />
        <span>Request workflow</span>
        <strong>Review, map, scope.</strong>
        <p>The request is reviewed against system type, current workflow, feasibility, timeline, and implementation path.</p>
      </article>

      <div class="request-next-dock__timeline">
        {reviewStages.map((stage, index) => (
          <article class:list={["request-review-stage", `request-review-stage--${index + 1}`]}>
            <SystemIcon name={stage.icon} />
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{stage.title}</h3>
            <p>{stage.text}</p>
          </article>
        ))}
      </div>

      {nextRoutes.map((route) => (
        <a class="request-next-route ar-system-node" href={route.href}>
          <SystemIcon name={route.icon} />
          <span>Next route</span>
          <h3>{route.title}</h3>
          <p>{route.text}</p>
        </a>
      ))}

      <div class="request-next-dock__signals ar-signal-strip">
        <span class="ar-signal">System type</span>
        <span class="ar-signal">Existing workflow</span>
        <span class="ar-signal">First launch scope</span>
      </div>
    </div>
  </section>
</Layout>
