---
import SystemHero from "@/components/SystemHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { getLocalizedCollections, localizePath, translateCopy } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;
const { capabilities, home, industries, solutions, systems, technologies } = getLocalizedCollections(locale);

const industryRouteCopy: Record<Locale, Record<string, { title: string; text: string }>> = {
  en: {
    "service-businesses": { title: "Services", text: "Leads, CRM, sites." },
    ecommerce: { title: "Catalogs", text: "Feeds, prices, content." },
    "media-content-projects": { title: "Media", text: "Content and publishing." },
    travel: { title: "Travel", text: "Availability and SEO." },
    "local-business": { title: "Local", text: "Landing pages, reviews." },
    "saas-mvp": { title: "SaaS/MVP", text: "Portals and dashboards." },
    agencies: { title: "Agencies", text: "Reports and delivery." },
    "data-heavy-businesses": { title: "Data", text: "Checks, alerts, reports." }
  },
  ro: {
    "service-businesses": { title: "Servicii", text: "Leaduri, CRM, site-uri." },
    ecommerce: { title: "Cataloguri", text: "Feeduri, preturi, continut." },
    "media-content-projects": { title: "Media", text: "Continut si publicare." },
    travel: { title: "Travel", text: "Disponibilitate si SEO." },
    "local-business": { title: "Local", text: "Landinguri si review-uri." },
    "saas-mvp": { title: "SaaS/MVP", text: "Portaluri si dashboarduri." },
    agencies: { title: "Agentii", text: "Rapoarte si livrare." },
    "data-heavy-businesses": { title: "Date", text: "Verificari, alerte." }
  },
  ru: {
    "service-businesses": { title: "Сервисы", text: "Лиды, CRM, сайты." },
    ecommerce: { title: "Каталоги", text: "Фиды, цены, контент." },
    "media-content-projects": { title: "Медиа", text: "Контент, выпуск." },
    travel: { title: "Туризм", text: "Доступность, SEO." },
    "local-business": { title: "Локальный", text: "Посадки, заявки, отзывы." },
    "saas-mvp": { title: "SaaS/MVP", text: "Порталы, панели." },
    agencies: { title: "Агентства", text: "Отчеты, доставка." },
    "data-heavy-businesses": { title: "Данные", text: "Сбор, проверки, алерты." }
  }
};

const industryTrajectorySlugs = new Set([
  "service-businesses",
  "ecommerce",
  "media-content-projects",
  "travel",
  "local-business",
  "saas-mvp",
  "data-heavy-businesses"
]);

const industryTrajectoryItems = industries.filter((item) => industryTrajectorySlugs.has(item.slug)).map((item) => ({
  ...item,
  routeCopy: industryRouteCopy[locale][item.slug] ?? { title: item.title, text: item.summary }
}));

const decisionRoutes = [
  {
    title: "Automate repeated work",
    icon: "ai",
    signal: "Manual workflow",
    text: "AI, rules, review states, and connected actions for content, leads, reports, or internal operations.",
    primaryLabel: "AI Automation",
    primaryHref: "/capabilities/ai-automation/",
    secondaryLabel: "Lead Processing",
    secondaryHref: "/solutions/automate-lead-processing/",
    output: "Automation flow"
  },
  {
    title: "Launch or rebuild a web platform",
    icon: "web",
    signal: "Website / product layer",
    text: "Structured pages, product interfaces, dashboards, portals, MVPs, and integration-ready frontend systems.",
    primaryLabel: "Web Development",
    primaryHref: "/capabilities/web-product-development/",
    secondaryLabel: "Upgrade Website",
    secondaryHref: "/solutions/upgrade-existing-website/",
    output: "Launchable platform"
  },
  {
    title: "Scale content or SEO",
    icon: "content",
    signal: "Publishing engine",
    text: "Topic data, templates, editorial QA, metadata, CMS publishing, and performance monitoring.",
    primaryLabel: "Content Infrastructure",
    primaryHref: "/capabilities/seo-content-infrastructure/",
    secondaryLabel: "Generate Content",
    secondaryHref: "/solutions/generate-more-content/",
    output: "Publishing system"
  },
  {
    title: "Track data, competitors, or rankings",
    icon: "data",
    signal: "Market signal",
    text: "Scraping, APIs, normalization, scoring, dashboards, alerts, exports, and recurring reports.",
    primaryLabel: "Data Systems",
    primaryHref: "/capabilities/data-systems-scraping/",
    secondaryLabel: "Monitoring System",
    secondaryHref: "/solutions/build-data-monitoring-system/",
    output: "Signal dashboard"
  },
  {
    title: "Improve e-commerce operations",
    icon: "commerce",
    signal: "Catalog operations",
    text: "Product data, feeds, stock and price monitoring, catalog content, marketplaces, and analytics.",
    primaryLabel: "E-commerce Systems",
    primaryHref: "/capabilities/ecommerce-systems/",
    secondaryLabel: "E-commerce Profile",
    secondaryHref: "/systems/ecommerce-system/",
    output: "Catalog system"
  },
  {
    title: "Connect WordPress, APIs, and tools",
    icon: "api",
    signal: "Integration layer",
    text: "Custom CMS structures, CRM connections, publishing workflows, business automations, and admin tools.",
    primaryLabel: "WordPress & APIs",
    primaryHref: "/capabilities/wordpress-api-integrations/",
    secondaryLabel: "WordPress Tools",
    secondaryHref: "/systems/wordpress-tools/",
    output: "Connected CMS"
  }
];

const systemPath = [
  { title: "Capabilities", text: "what can be built", href: "/capabilities/", icon: "tools" },
  { title: "Solutions", text: "which problem it solves", href: "/solutions/", icon: "flow" },
  { title: "Systems", text: "how it operates", href: "/systems/", icon: "product" },
  { title: "Technologies", text: "what connects it", href: "/technologies/", icon: "api" },
  { title: "Start Project", text: "what to scope first", href: "/start-project/", icon: "lead" }
];

const capabilityBySlug = new Map(capabilities.map((item) => [item.slug, item]));

const commandFieldNodes = [
  {
    slug: "ai-automation",
    title: "AI Automation",
    detail: "Workflows that run while you sleep",
    state: "Automate"
  },
  {
    slug: "web-product-development",
    title: "Web Platforms",
    detail: "Scalable websites and apps that perform",
    state: "Interface"
  },
  {
    slug: "seo-content-infrastructure",
    title: "Content Engine",
    detail: "From idea to publish at machine speed",
    state: "Publish"
  },
  {
    slug: "video-media-automation",
    title: "Media Flow",
    detail: "Create. Distribute. Amplify.",
    state: "Media"
  },
  {
    slug: "wordpress-api-integrations",
    title: "API Layer",
    detail: "Connect systems. Expose capabilities",
    state: "Connect"
  },
  {
    slug: "data-systems-scraping",
    title: "Data Signals",
    detail: "Collect, normalize, turn into insight",
    state: "Signal"
  },
  {
    slug: "ecommerce-systems",
    title: "Commerce Ops",
    detail: "Operations that drive revenue",
    state: "Catalog"
  }
].map((node, index) => ({
  ...node,
  source: capabilityBySlug.get(node.slug),
  metric: `${74 + index * 3}%`,
  slot: index + 1
}));

const technologyLinks: Record<string, string> = {
  WordPress: "/capabilities/wordpress-api-integrations/",
  Astro: "/technologies/",
  "Next.js": "/capabilities/web-product-development/",
  APIs: "/capabilities/wordpress-api-integrations/",
  "AI models": "/capabilities/ai-automation/",
  "Automation tools": "/capabilities/ai-automation/",
  Scraping: "/capabilities/data-systems-scraping/",
  "Data processing": "/capabilities/data-systems-scraping/",
  "Video generation": "/capabilities/video-media-automation/",
  Analytics: "/solutions/build-data-monitoring-system/",
  "CRM integrations": "/solutions/automate-lead-processing/",
  "Cloudflare Pages": "/technologies/"
};

const technologyIcons: Record<string, string> = {
  WordPress: "content",
  Astro: "space",
  "Next.js": "web",
  APIs: "api",
  "AI models": "ai",
  "Automation tools": "tools",
  Scraping: "monitor",
  "Data processing": "data",
  "Video generation": "media",
  Analytics: "ranking",
  "CRM integrations": "lead",
  "Cloudflare Pages": "product"
};

const technologyRadar = technologies.slice(0, 12).map((tech, index) => ({
  tech,
  slot: index + 1,
  href: technologyLinks[tech] ?? "/technologies/",
  icon: technologyIcons[tech] ?? "api"
}));

const routeEngine = [
  {
    input: "Slow leads",
    inputHref: "/solutions/automate-lead-processing/",
    output: "Qualified pipeline",
    outputHref: "/lp/automate-lead-processing/",
    icon: "lead"
  },
  {
    input: "Manual content",
    inputHref: "/solutions/generate-more-content/",
    output: "Publishing engine",
    outputHref: "/lp/ai-content-workflow/",
    icon: "content"
  },
  {
    input: "Broken data",
    inputHref: "/solutions/build-data-monitoring-system/",
    output: "Live monitoring",
    outputHref: "/capabilities/data-systems-scraping/",
    icon: "data"
  },
  {
    input: "Disconnected tools",
    inputHref: "/solutions/build-internal-tools/",
    output: "Connected workflow",
    outputHref: "/capabilities/wordpress-api-integrations/",
    icon: "api"
  },
  {
    input: "Unclear project scope",
    inputHref: "/start-project/",
    output: "Scoped implementation route",
    outputHref: "/solutions/",
    icon: "flow"
  }
];

const blueprintStations = [
  { title: "Input", text: "Lead, content, catalog, or source data enters one controlled model.", stat: "12 sources", icon: "data" },
  { title: "Rules + AI", text: "Automation classifies, enriches, routes, drafts, and checks work.", stat: "logic layer", icon: "ai" },
  { title: "Human Review", text: "Approvals, corrections, owner decisions, and fallback states stay visible.", stat: "QA ready", icon: "tools" },
  { title: "Output", text: "CRM actions, published pages, dashboards, feeds, or reports leave the system.", stat: "CRM ready", icon: "ranking" }
];
---

<Layout locale={locale}>
  <SystemHero
    eyebrow="Digital systems company"
    title={home.heroTitle}
    text={home.heroText}
    primaryHref={localizePath("/start-project/", locale)}
    primaryLabel={translateCopy(locale, "Start a Project")}
    secondaryHref={localizePath("/capabilities/", locale)}
    secondaryLabel={translateCopy(locale, "Explore Capabilities")}
    locale={locale}
  />

  <section class="section home-decision" aria-labelledby="decision-title">
    <div class="section-header">
      <div>
        <p class="eyebrow">{translateCopy(locale, "Decision hub")}</p>
        <h2 id="decision-title">{translateCopy(locale, "What system do you need?")}</h2>
      </div>
      <p>{translateCopy(locale, "Start from the operational need. Each route points to the most relevant capability, solution, or system profile so the home page works like a map of the company.")}</p>
    </div>

    <div class="decision-board">
      <div class="decision-board__core">
        <SystemIcon name="product" />
        <strong>{translateCopy(locale, "Need -> System")}</strong>
        <p>{translateCopy(locale, "Choose the pressure point, then follow the route into the section with the right level of detail.")}</p>
        <div class="decision-board__stats">
          <span><b>{capabilities.length}</b> {translateCopy(locale, "capabilities")}</span>
          <span><b>{solutions.length}</b> {translateCopy(locale, "solutions")}</span>
          <span><b>{systems.length}</b> {translateCopy(locale, "profiles")}</span>
        </div>
      </div>

      <div class="decision-grid">
        {decisionRoutes.map((route) => (
          <article class="decision-route decision-route--glyph">
            <div class="card-glyph decision-route__glyph" aria-hidden="true">
              <SystemIcon name={route.icon} />
            </div>
            <div class="decision-route__body">
              <span>{translateCopy(locale, route.signal)}</span>
              <h3>{translateCopy(locale, route.title)}</h3>
              <p>{translateCopy(locale, route.text)}</p>
              <div class="decision-route__links">
                <a href={localizePath(route.primaryHref, locale)}>{translateCopy(locale, route.primaryLabel)}</a>
                <a href={localizePath(route.secondaryHref, locale)}>{translateCopy(locale, route.secondaryLabel)}</a>
              </div>
            </div>
            <small>{translateCopy(locale, route.output)}</small>
          </article>
        ))}
      </div>
    </div>

    <nav class="home-flow" aria-label="Homepage system routes">
      {systemPath.map((step, index) => (
        <a href={localizePath(step.href, locale)}>
          <span>{index + 1}</span>
          <strong>{translateCopy(locale, step.title)}</strong>
          <small>{translateCopy(locale, step.text)}</small>
        </a>
      ))}
    </nav>
  </section>

  <section class="section home-spectrum" aria-labelledby="capability-spectrum-title">
    <div class="section-header">
      <div>
        <p class="eyebrow">{translateCopy(locale, "Capabilities")}</p>
        <h2 id="capability-spectrum-title">{translateCopy(locale, "What AlfaRank builds")}</h2>
      </div>
      <p>{home.buildText}</p>
    </div>

    <div class="command-field">
      <div class="command-field__paths" aria-hidden="true"></div>
      <div class="command-core">
        <SystemIcon name="tools" />
        <span>{translateCopy(locale, "ALFARANK CORE")}</span>
        <strong>{translateCopy(locale, `${capabilities.length} connected directions`)}</strong>
        <p>{translateCopy(locale, "Capabilities are not a menu of services. They are a set of technical forces that can be combined into one operating system.")}</p>
      </div>
      {commandFieldNodes.map((item) => item.source && (
        <a class:list={["command-node", `command-node--${item.slot}`]} href={localizePath(`/capabilities/${item.slug}/`, locale)}>
          <SystemIcon name={item.source.icon} />
          <span>{translateCopy(locale, item.state)}</span>
          <h3>{translateCopy(locale, item.title)}</h3>
          <p>{translateCopy(locale, item.detail)}</p>
          <small style={`--command-level: ${item.metric};`}></small>
        </a>
      ))}
    </div>
  </section>

  <section class="section home-solution-field" id="solution-routes" aria-labelledby="home-solution-title">
    <div class="section-header">
      <div>
        <p class="eyebrow">{translateCopy(locale, "Solutions")}</p>
        <h2 id="home-solution-title">{translateCopy(locale, "Business problems mapped to systems")}</h2>
      </div>
      <p>{home.solutionsText}</p>
    </div>

    <div class="route-engine">
      <div class="route-engine__links" aria-hidden="true">
        {routeEngine.map((_, index) => (
          <span class:list={["route-engine__link", `route-engine__link--${index + 1}`]}></span>
        ))}
      </div>
      <div class="route-engine__column">
        <span class="route-engine__label">{translateCopy(locale, "Business pressure")}</span>
        {routeEngine.map((item, index) => (
          <a class="route-pulse" data-route-pair={index + 1} href={localizePath(item.inputHref, locale)}>
            <SystemIcon name={item.icon} />
            <strong>{translateCopy(locale, item.input)}</strong>
          </a>
        ))}
      </div>
      <div class="route-engine__core">
        <SystemIcon name="flow" />
        <span>{translateCopy(locale, "Route engine")}</span>
        <strong>{translateCopy(locale, "Problem to system")}</strong>
        <p>{translateCopy(locale, "Inputs are converted into scoped implementation paths, then into measurable business outputs.")}</p>
        <a class="button secondary" href={localizePath("/solutions/", locale)}>{translateCopy(locale, "View solution routes")}</a>
      </div>
      <div class="route-engine__column route-engine__column--output">
        <span class="route-engine__label">{translateCopy(locale, "System output")}</span>
        {routeEngine.map((item, index) => (
          <a class="route-output" data-route-pair={index + 1} href={localizePath(item.outputHref, locale)}>
            <strong>{translateCopy(locale, item.output)}</strong>
            <small>{translateCopy(locale, "Open route")}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" aria-labelledby="home-blueprint-title">
    <div class="section-header">
      <div>
        <p class="eyebrow">{translateCopy(locale, "System blueprint")}</p>
        <h2 id="home-blueprint-title">{translateCopy(locale, "From client workflow to operating system")}</h2>
      </div>
      <p>{home.systemsText}</p>
    </div>
    <div class="client-blueprint">
      <div class="client-blueprint__track" aria-hidden="true"></div>
      {blueprintStations.map((station, index) => (
        <article class:list={["client-blueprint__stage", `client-blueprint__stage--${index + 1}`]}>
          <div class="client-blueprint__platform">
            <SystemIcon name={station.icon} />
          </div>
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{translateCopy(locale, station.title)}</h3>
          <p>{translateCopy(locale, station.text)}</p>
          <small>{translateCopy(locale, station.stat)}</small>
        </article>
      ))}
    </div>
  </section>

  <section class="section tech-radar-showcase" aria-labelledby="home-tech-title">
    <div class="tech-radar-copy">
      <p class="eyebrow">{translateCopy(locale, "Technology layer")}</p>
      <h2 id="home-tech-title">{translateCopy(locale, "Built with practical, integration-ready technology.")}</h2>
      <p>{translateCopy(locale, "AlfaRank uses established web, automation, AI, data, and CMS technologies to create systems that can be launched, reviewed, integrated, and improved without locking the business into a fragile stack.")}</p>
      <div class="section-actions">
        <a class="button secondary" href={localizePath("/technologies/", locale)}>{translateCopy(locale, "View Technologies")}</a>
      </div>
    </div>
    <div class="tech-radar" aria-label="Technology radar">
      <div class="tech-radar__ring tech-radar__ring--outer"></div>
      <div class="tech-radar__ring tech-radar__ring--inner"></div>
      <div class="tech-radar__core">
        <SystemIcon name="api" />
        <strong>{translateCopy(locale, "Stack logic")}</strong>
        <span>{translateCopy(locale, "CMS / AI / Data / APIs / Deploy")}</span>
      </div>
      {technologyRadar.map((item) => (
        <a class:list={["tech-radar__chip", `tech-radar__chip--${item.slot}`]} href={localizePath(item.href, locale)}>
          <SystemIcon name={item.icon} />
          <span>{item.tech}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="section industry-trajectory" aria-labelledby="industry-trajectory-title">
    <div class="section-header">
      <div>
        <p class="eyebrow">{translateCopy(locale, "Industries")}</p>
        <h2 id="industry-trajectory-title">{translateCopy(locale, "Where the systems apply")}</h2>
      </div>
      <p>{translateCopy(locale, "The same system approach works across service businesses, e-commerce, media, travel, local businesses, SaaS, and data-heavy operations.")}</p>
    </div>

    <div class="market-trajectory">
      <div class="market-trajectory__line"></div>
      {industryTrajectoryItems.map((item, index) => (
        <a class:list={["market-node", `market-node--${index + 1}`]} href={localizePath(`/industries/${item.slug}/`, locale)}>
          <SystemIcon name={item.icon} />
          <h3>{item.routeCopy.title}</h3>
          <p>{item.routeCopy.text}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section split-panel">
    <div class="glass-panel">
      <p class="eyebrow">{translateCopy(locale, "Project flow")}</p>
      <h2>{translateCopy(locale, "How projects start")}</h2>
      <p>{translateCopy(locale, "Every project begins with a concrete operational problem. The first goal is to define the system that should exist, not to force the business into a predefined service package.")}</p>
      <div class="section-actions">
        <a class="button primary" href={localizePath("/start-project/", locale)}>{translateCopy(locale, "Start a Project")}</a>
      </div>
    </div>
    <div class="glass-panel">
      <ul class="feature-list">
        {home.process.map((step) => <li>{step}</li>)}
      </ul>
    </div>
  </section>
</Layout>
