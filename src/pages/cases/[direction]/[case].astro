---
import CaseHeroVisual from "@/components/CaseHeroVisual.astro";
import {
  caseDirections,
  getCaseDirection,
  getCaseExample,
  getCaseUi,
  getPublicCaseTitle,
  getPublicCaseMetrics,
  getPublicCasePresentation,
  getPublicCaseEvidence,
  getPublicCaseNext,
  getPublicCaseShift,
  getPublicCaseShow,
  getPublicCaseSummary,
  getPublicCaseTags,
  getPublicDirectionTitle
} from "@/data/case-examples";
import { localizePath } from "@/data/i18n";
import type { Locale } from "@/data/i18n";
import Layout from "@/layouts/Layout.astro";

type Direction = NonNullable<ReturnType<typeof getCaseDirection>>;
type Example = NonNullable<ReturnType<typeof getCaseExample>>;

type Props = {
  locale?: Locale;
  direction: Direction;
  example: Example;
};

export function getStaticPaths() {
  return caseDirections.flatMap((direction) =>
    direction.examples.map((example) => ({
      params: { direction: direction.slug, case: example.slug },
      props: { direction, example }
    }))
  );
}

const { locale = "en", direction, example } = Astro.props as Props;
const caseUi = getCaseUi(locale);
const caseAlternateLocales: Locale[] = ["en", "ro", "ru"];
const presentation = getPublicCasePresentation(example, locale);
const publicExampleTitle = getPublicCaseTitle(example, locale);
const publicDirectionTitle = getPublicDirectionTitle(direction, locale);
const publicSummary = getPublicCaseSummary(example, locale);
const publicShift = getPublicCaseShift(example, locale);
const publicShow = getPublicCaseShow(example, locale);
const publicEvidence = getPublicCaseEvidence(example, locale);
const publicNext = getPublicCaseNext(example, locale);
const publicTags = getPublicCaseTags(example, locale);
const presentationMetrics = getPublicCaseMetrics(example, locale);
const heroHasMetrics = presentationMetrics.length > 0;
const heroVariant = heroHasMetrics ? "scoreboard" : "timeline";
const heroFlow = presentation
  ? presentation.flow
  : [publicShift, ...publicShow, ...publicEvidence].filter(Boolean);
const heroBuyerValue = presentation
  ? presentation.buyerValue
  : [publicSummary, ...publicNext].filter(Boolean);

const pageCopy = {
  projectEssence: locale === "en" ? "Project essence" : locale === "ro" ? "Esenta proiectului" : "Суть проекта",
  builtTitle: locale === "en" ? "What was built" : locale === "ro" ? "Ce a fost construit" : "Что было построено",
  task: locale === "en" ? "Task" : locale === "ro" ? "Sarcina" : "Задача",
  problemTitle: locale === "en" ? "What problem was solved" : locale === "ro" ? "Ce problema a fost rezolvata" : "Какую проблему закрывали",
  result: locale === "en" ? "Result" : locale === "ro" ? "Rezultat" : "Результат",
  resultTitle: locale === "en" ? "What changed" : locale === "ro" ? "Ce s-a schimbat" : "Что получилось",
  metricsLabel: locale === "en" ? "Key project numbers" : locale === "ro" ? "Cifre cheie ale proiectului" : "Ключевые цифры проекта",
  systemFlow: locale === "en" ? "How the system works" : locale === "ro" ? "Cum functioneaza sistemul" : "Как работает система",
  workflowTitle: locale === "en" ? "Working chain" : locale === "ro" ? "Lantul de lucru" : "Рабочая цепочка",
  proof: locale === "en" ? "Proof" : locale === "ro" ? "Dovezi" : "Доказательства",
  proofTitle: locale === "en" ? "How the result is confirmed" : locale === "ro" ? "Cum este confirmat rezultatul" : "Как подтверждается результат",
  value: locale === "en" ? "Value" : locale === "ro" ? "Valoare" : "Ценность",
  businessTitle: locale === "en" ? "What the business gets" : locale === "ro" ? "Ce primeste businessul" : "Что получает бизнес",
  shiftTitle: locale === "en" ? "How the presentation changes" : locale === "ro" ? "Cum se schimba prezentarea" : "Как меняется подача",
  showTitle: locale === "en" ? "What should be on the page" : locale === "ro" ? "Ce trebuie sa fie pe pagina" : "Что должно быть на странице",
  evidenceTitle: locale === "en" ? "What the proof is based on" : locale === "ro" ? "Pe ce se bazeaza dovada" : "На чем строим доказательство",
  nextTitle: locale === "en" ? "Before the public version" : locale === "ro" ? "Inainte de versiunea publica" : "Перед публичной версией"
};

---

<Layout
  title={`${publicExampleTitle} | ${caseUi.title} | AlfaRank`}
  description={publicSummary}
  locale={locale}
  alternateLocales={caseAlternateLocales}
  robots="noindex, follow"
>
  <div class="case-library-page" data-no-translate>
    <section class="section case-library-hero case-library-hero--example">
      <div class="case-library-hero__content">
        <a class="case-back-link" href={localizePath(`/cases/${direction.slug}/`, locale)}>{caseUi.backToDirection}</a>
        <p class="eyebrow">{publicDirectionTitle}</p>
        <h1>{publicExampleTitle}</h1>
        <p>{publicSummary}</p>
        {publicTags.length > 0 && (
          <div class="case-library-hero__tags">
            {publicTags.map((tag) => <span>{tag}</span>)}
          </div>
        )}
      </div>
      <CaseHeroVisual
        variant={heroVariant}
        locale={locale}
        icon={direction.icon}
        metrics={presentationMetrics}
        flow={heroFlow}
        buyerValue={heroBuyerValue}
      />
    </section>

    {presentation && (
      <div class="case-presentation-stack">
        <section class="section case-presentation-lead">
          <article class="case-detail-panel case-detail-panel--lead">
            <p class="eyebrow">{pageCopy.projectEssence}</p>
            <h2>{pageCopy.builtTitle}</h2>
            <p>{presentation.lead}</p>
          </article>

          <article class="case-detail-panel">
            <p class="eyebrow">{pageCopy.task}</p>
            <h2>{pageCopy.problemTitle}</h2>
            <p>{presentation.problem}</p>
          </article>

          <article class="case-detail-panel">
            <p class="eyebrow">{pageCopy.result}</p>
            <h2>{pageCopy.resultTitle}</h2>
            <p>{presentation.result}</p>
          </article>
        </section>

        {presentationMetrics.length > 0 && (
          <section class="section case-metric-grid" aria-label={pageCopy.metricsLabel}>
            {presentationMetrics.map((metric) => (
              <article class="case-metric">
                <strong>{metric.value}</strong>
                <span>{metric.label}</span>
                {metric.note && <p>{metric.note}</p>}
              </article>
            ))}
          </section>
        )}

        <section class="section case-story-grid">
          {presentation.story.map((block) => (
            <article class="case-detail-panel">
              <p class="eyebrow">{block.eyebrow}</p>
              <h2>{block.title}</h2>
              <p>{block.body}</p>
            </article>
          ))}
        </section>

        <section class="section case-presentation-flow">
          <article class="case-detail-panel case-detail-panel--wide">
            <p class="eyebrow">{pageCopy.systemFlow}</p>
            <h2>{pageCopy.workflowTitle}</h2>
            <ol class="case-flow-list">
              {presentation.flow.map((item) => <li>{item}</li>)}
            </ol>
          </article>
        </section>

        <section class="section case-proof-grid">
          <article class="case-detail-panel">
            <p class="eyebrow">{pageCopy.proof}</p>
            <h2>{pageCopy.proofTitle}</h2>
            <ul class="case-check-list">
              {presentation.proof.map((item) => <li>{item}</li>)}
            </ul>
          </article>

          <article class="case-detail-panel">
            <p class="eyebrow">{pageCopy.value}</p>
            <h2>{pageCopy.businessTitle}</h2>
            <ul class="case-check-list">
              {presentation.buyerValue.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </section>
      </div>
    )}

    {!presentation && (
    <section class="section case-example-layout">
      <article class="case-detail-panel case-detail-panel--lead">
        <p class="eyebrow">{caseUi.conceptShift}</p>
        <h2>{pageCopy.shiftTitle}</h2>
        <p>{publicShift}</p>
      </article>

      <article class="case-detail-panel">
        <p class="eyebrow">{caseUi.whatToShow}</p>
        <h2>{pageCopy.showTitle}</h2>
        <ul class="case-check-list">
          {publicShow.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="case-detail-panel">
        <p class="eyebrow">{caseUi.proofBase}</p>
        <h2>{pageCopy.evidenceTitle}</h2>
        <ul class="case-check-list">
          {publicEvidence.map((item) => <li>{item}</li>)}
        </ul>
      </article>

      <article class="case-detail-panel">
        <p class="eyebrow">{caseUi.nextWork}</p>
        <h2>{pageCopy.nextTitle}</h2>
        <ul class="case-check-list">
          {publicNext.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </section>
    )}
  </div>
</Layout>
