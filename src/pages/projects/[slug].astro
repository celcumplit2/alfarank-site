---
import PageHero from "@/components/PageHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { getPrivateProjects, privateUi } from "@/data/private-projects";
import { localizePath } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
  project: ReturnType<typeof getPrivateProjects>[number];
};

export function getStaticPaths() {
  return getPrivateProjects("en").map((project) => ({
    params: { slug: project.slug },
    props: { project, locale: "en" }
  }));
}

const { project, locale = "en" } = Astro.props as Props;
const ui = privateUi[locale];
const cardDescription = (value: string, limit = 160) => {
  const normalized = value.replace(/\s+/g, " ").trim();
  if (normalized.length <= limit) {
    return normalized;
  }

  const clipped = normalized.slice(0, limit - 3);
  const lastSpace = clipped.lastIndexOf(" ");
  return `${clipped.slice(0, lastSpace > 90 ? lastSpace : limit - 3).trim()}...`;
};
const moduleCardDescription = (module: Props["project"]["modules"][number]) => {
  const normalized = module.positioning.replace(/\s+/g, " ").trim();
  if (normalized.length >= 145) {
    return cardDescription(normalized);
  }

  return cardDescription(`${normalized} ${module.outputs[0] ?? ""}.`);
};
const projectNarrative = {
  en: {
    architecture:
      "The modules are separated by role: detect market movement, discover external surplus, build opportunity hypotheses, preserve decision memory, and move learning across verticals.",
    core:
      "One route from signal to reviewed opportunity: detect, qualify, remember, and reuse.",
    valueHeading: "What changes for the trading team"
  },
  ro: {
    architecture:
      "Modulele sunt separate dupa rol: detecteaza miscarea pietei, gasesc surplus extern, construiesc ipoteze de oportunitate, pastreaza memoria deciziilor si muta invatarea intre verticale.",
    core:
      "Un traseu de la semnal la oportunitate verificata: detectare, calificare, memorie si reutilizare.",
    valueHeading: "Ce se schimba pentru echipa de trading"
  },
  ru: {
    architecture:
      "Модули разделены по роли: заметить движение рынка, найти внешние товарные возможности, собрать гипотезы, сохранить память решений и перенести опыт между вертикалями.",
    core:
      "Один маршрут от сигнала к проверенной возможности: обнаружить, оценить, запомнить и использовать снова.",
    valueHeading: "Что меняется для торговой команды"
  }
}[locale];

const moduleSignals = project.modules.map((module, index) => ({
  title: module.title,
  state: module.outputs[0] ?? ui.outputs,
  icon: module.icon,
  detail: moduleCardDescription(module),
  meter: `${72 + index * 4}%`
}));

const projectVisual = {
  mode: "private-project",
  icon: project.icon,
  label: project.client,
  state: project.status,
  output: project.outputs.join(", "),
  nodes: moduleSignals,
  metrics: [
    { value: String(project.modules.length).padStart(2, "0"), label: ui.modules },
    { value: String(project.outputs.length).padStart(2, "0"), label: ui.outputs },
    { value: ui.pilot, label: ui.pilot }
  ]
};
---

<Layout title={`${project.title} | AlfaRank`} description={project.summary} locale={locale} robots="noindex, nofollow">
  <div class="private-project-page" data-no-translate>
    <PageHero
      eyebrow={project.eyebrow}
      title={project.title}
      text={project.summary}
      primaryHref={`/projects/${project.slug}/${project.modules[0]?.slug ?? ""}/`}
      primaryLabel={ui.openModule}
      secondaryHref="/projects/"
      secondaryLabel={ui.allProjects}
      locale={locale}
      visual={projectVisual}
    />

    <section class="section split-panel private-pitch-split">
      <article class="glass-panel private-slide-card private-slide-card--lead">
        <p class="eyebrow">{ui.projectOverview}</p>
        <h2>{ui.projectOverview}</h2>
        <p>{project.thesis.text}</p>
      </article>
      <article class="glass-panel private-slide-card">
        <p class="eyebrow">{ui.outputs}</p>
        <div class="tag-grid">
          {project.outputs.map((output) => <span class="tag">{output}</span>)}
        </div>
        <h3>{project.client}</h3>
        <p>{project.status}</p>
      </article>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">{ui.projectMap}</p>
          <h2>{ui.moduleMap}</h2>
        </div>
        <p>{projectNarrative.architecture}</p>
      </div>

      <div class="systems-navigation-console private-module-console ar-system-block">
        <article class="systems-navigation-console__core ar-system-core">
          <SystemIcon name={project.icon} />
          <span>{project.client}</span>
          <strong>{project.title}</strong>
          <p>{projectNarrative.core}</p>
        </article>

        {project.modules.map((module, index) => (
          <a class:list={["systems-navigation-node", "ar-system-node", `systems-navigation-node--${index + 1}`]} href={localizePath(`/projects/${project.slug}/${module.slug}/`, locale)} style={`--ar-level: ${72 + index * 5}%;`}>
            <SystemIcon name={module.icon} />
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{module.title}</h3>
            <p>{moduleCardDescription(module)}</p>
            <b class="ar-metric-bar"></b>
          </a>
        ))}
      </div>
    </section>

    <section class="section split-panel">
      <article class="glass-panel private-slide-card">
        <p class="eyebrow">{ui.strategicLayer}</p>
        <h2>{projectNarrative.valueHeading}</h2>
        <ul class="feature-list">
          {project.thesis.items.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="glass-panel private-slide-card">
        <p class="eyebrow">{ui.guardrails}</p>
        <h2>{project.guardrail.title}</h2>
        <p>{project.guardrail.text}</p>
        <ul class="feature-list">
          {project.guardrail.items.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">{ui.implementationPlan}</p>
          <h2>{project.implementation.title}</h2>
        </div>
        <p>{project.implementation.text}</p>
      </div>
      <ol class="private-step-list">
        {project.implementation.steps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <p>{step}</p>
          </li>
        ))}
      </ol>
    </section>
  </div>
</Layout>
