---
import Layout from "@/layouts/Layout.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import { localizePath } from "@/data/i18n";
import type { Locale } from "@/data/i18n";
import {
  formatNoviqEur,
  noviqCompanyName,
  noviqFunnelModes,
  noviqOffers,
  noviqRisks,
  noviqRoutes
} from "@/data/noviq-launch";

type Props = {
  locale?: Locale;
};

const { locale = "ru" } = Astro.props;
const projectHref = localizePath(noviqRoutes.root, locale);
const investmentHref = localizePath(noviqRoutes.investmentModel, locale);
---

<Layout
  title={`Sales Engine | ${noviqCompanyName} | AlfaRank`}
  description="Детализация sales engine: офферы, воронка, unit economics, риски и контроль продаж для запуска Noviq Systems."
  locale={locale}
  robots="noindex, nofollow"
>
  <div class="private-project-page noviq-detail-page" data-no-translate>
    <section class="section noviq-detail-hero">
      <div>
        <p class="eyebrow">Noviq Systems / Sales engine</p>
        <h1>Офферы, воронка и unit economics</h1>
        <p>
          Sales-команда управляет продуктовой полкой, переходом audit -> rebuild/video и цифрами,
          которые подтверждают спрос до масштабирования офиса и рекламы.
        </p>
        <div class="noviq-detail-actions">
          <a class="button primary" href={projectHref}>Назад к сценарию</a>
          <a class="button secondary" href={investmentHref}>Модель инвестиций</a>
        </div>
      </div>
      <article class="glass-panel noviq-detail-focus">
        <SystemIcon name="lead" />
        <strong>Главная проверка</strong>
        <p>
          Не “можем ли мы делать сайты”, а сколько оплаченных диагностик, rebuild-проектов и video packs
          появляется из 1 000-2 000 контактов в месяц.
        </p>
      </article>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Offer shelf</p>
          <h2>Три продукта для первой продажи</h2>
        </div>
        <p>
          У каждого оффера своя роль: audit снижает барьер, rebuild дает основной чек,
          video pack создает recurring-потенциал через Vidorix.app.
        </p>
      </div>
      <div class="noviq-offer-grid">
        {noviqOffers.map((offer) => (
          <article class="glass-panel noviq-offer-card">
            <span>{offer.role}</span>
            <h3>{offer.name}</h3>
            <p>{offer.text}</p>
            <dl>
              <div>
                <dt>Price</dt>
                <dd>{offer.price}</dd>
              </div>
              <div>
                <dt>Margin</dt>
                <dd>{offer.margin}</dd>
              </div>
              <div>
                <dt>Cycle</dt>
                <dd>{offer.cycle}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Funnel control</p>
          <h2>Что должен приносить один менеджер</h2>
        </div>
        <p>
          Эти цифры не обещание, а рамка контроля. Если менеджер не дает встреч и аудитов,
          его быстро видно в CRM и можно менять скрипт, базу или самого менеджера.
        </p>
      </div>
      <div class="noviq-funnel-grid">
        {noviqFunnelModes.map((mode) => (
          <article class="glass-panel noviq-funnel-card">
            <h3>{mode.mode}</h3>
            <dl>
              <div>
                <dt>Calls</dt>
                <dd>{mode.calls}</dd>
              </div>
              <div>
                <dt>Meetings</dt>
                <dd>{mode.meetings}</dd>
              </div>
              <div>
                <dt>Audits</dt>
                <dd>{mode.audits}</dd>
              </div>
              <div>
                <dt>Rebuilds</dt>
                <dd>{mode.rebuilds}</dd>
              </div>
              <div>
                <dt>Video packs</dt>
                <dd>{mode.videoPacks}</dd>
              </div>
              <div>
                <dt>Target revenue</dt>
                <dd>{formatNoviqEur(mode.revenue)}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section class="section split-panel">
      <article class="glass-panel private-slide-card">
        <p class="eyebrow">Sales operating rhythm</p>
        <h2>Еженедельный контроль</h2>
        <ul class="feature-list">
          <li>Каждый менеджер фиксирует звонки, дозвоны, встречи и следующий шаг в CRM.</li>
          <li>Sales lead слушает записи звонков и правит скрипты по возражениям.</li>
          <li>Founder подключается только к presale, demo и закрытию крупных сделок.</li>
          <li>Реклама масштабируется только после подтверждения конверсии в audit sprint.</li>
        </ul>
      </article>
      <article class="glass-panel private-slide-card">
        <p class="eyebrow">Decision rule</p>
        <h2>Что значит “работает”</h2>
        <p>
          Воронка считается живой, когда команда стабильно получает оплаченные аудиты,
          а часть аудитов переходит в rebuild или recurring video package. Без этого масштабировать офис
          и рекламу рано.
        </p>
      </article>
    </section>

    <section class="section">
      <div class="section-header">
        <div>
          <p class="eyebrow">Risks</p>
          <h2>Риски и защита</h2>
        </div>
        <p>Риск-контур фиксирует слабые места модели и правила контроля до масштабирования.</p>
      </div>
      <div class="noviq-risk-grid">
        {noviqRisks.map((risk) => (
          <article class="glass-panel noviq-risk-card">
            <h3>{risk.title}</h3>
            <p>{risk.mitigation}</p>
          </article>
        ))}
      </div>
    </section>
  </div>

  <style>
    .noviq-detail-page :is(h1, h2, h3, p, a, span, strong, small, li, dt, dd) {
      letter-spacing: 0;
    }

    .noviq-detail-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.48fr);
      gap: clamp(24px, 4vw, 52px);
      align-items: center;
      padding-top: clamp(32px, 5vw, 72px);
    }

    .noviq-detail-hero h1 {
      max-width: 780px;
      margin: 0;
      font-size: clamp(2.8rem, 5.5vw, 5.3rem);
      line-height: 0.98;
      text-wrap: balance;
    }

    .noviq-detail-hero p:not(.eyebrow),
    .noviq-detail-focus p {
      max-width: 760px;
      color: var(--muted);
      line-height: 1.7;
    }

    .noviq-detail-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 26px;
    }

    .noviq-detail-focus {
      display: grid;
      gap: 16px;
      padding: 26px;
      background:
        radial-gradient(circle at 82% 0%, rgba(216, 251, 255, 0.12), transparent 38%),
        linear-gradient(135deg, rgba(5, 25, 54, 0.58), rgba(3, 16, 36, 0.5));
      box-shadow:
        0 22px 58px rgba(0, 0, 0, 0.18),
        inset 0 1px 0 rgba(255, 255, 255, 0.09);
    }

    .noviq-detail-focus .system-icon {
      width: 54px;
      height: 54px;
    }

    .noviq-detail-focus strong {
      color: #fff;
      font-size: 1.35rem;
    }

    .noviq-offer-grid,
    .noviq-funnel-grid,
    .noviq-risk-grid {
      display: grid;
      gap: 16px;
      margin-top: 24px;
    }

    .noviq-offer-grid,
    .noviq-funnel-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .noviq-risk-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .noviq-offer-card,
    .noviq-funnel-card,
    .noviq-risk-card {
      display: grid;
      align-content: start;
      gap: 14px;
      min-height: 250px;
      padding: 22px;
      background:
        radial-gradient(circle at 82% 0%, rgba(216, 251, 255, 0.11), transparent 38%),
        linear-gradient(135deg, rgba(5, 25, 54, 0.56), rgba(3, 16, 36, 0.48));
      box-shadow:
        0 20px 54px rgba(0, 0, 0, 0.18),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .noviq-offer-card span {
      color: var(--pearl);
      font-size: 0.76rem;
      font-weight: 900;
      text-transform: uppercase;
    }

    .noviq-offer-card h3,
    .noviq-funnel-card h3,
    .noviq-risk-card h3 {
      margin: 0;
      color: #fff;
      font-size: 1.35rem;
      line-height: 1.16;
      text-shadow: 0 2px 16px rgba(0, 7, 26, 0.48);
    }

    .noviq-offer-card p,
    .noviq-risk-card p {
      margin: 0;
      color: rgba(238, 248, 255, 0.88);
      line-height: 1.6;
      text-shadow: 0 1px 12px rgba(0, 7, 26, 0.34);
    }

    .noviq-offer-card dl,
    .noviq-funnel-card dl {
      display: grid;
      gap: 10px;
      margin: 0;
    }

    .noviq-offer-card dl div,
    .noviq-funnel-card dl div {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      border-top: 1px solid rgba(216, 251, 255, 0.13);
      padding-top: 10px;
    }

    .noviq-offer-card dt,
    .noviq-funnel-card dt {
      color: var(--faint);
      font-size: 0.76rem;
      font-weight: 800;
      text-transform: uppercase;
    }

    .noviq-offer-card dd,
    .noviq-funnel-card dd {
      margin: 0;
      color: #fff;
      font-weight: 900;
      text-align: right;
    }

    @media (max-width: 1100px) {
      .noviq-detail-hero {
        grid-template-columns: 1fr;
      }

      .noviq-risk-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .noviq-detail-hero h1 {
        font-size: clamp(2.1rem, 9vw, 2.8rem);
        line-height: 1.04;
      }

      .noviq-offer-grid,
      .noviq-funnel-grid,
      .noviq-risk-grid {
        grid-template-columns: 1fr;
      }

      .noviq-offer-card dl div,
      .noviq-funnel-card dl div {
        align-items: flex-start;
        flex-direction: column;
      }

      .noviq-offer-card dd,
      .noviq-funnel-card dd {
        text-align: left;
      }
    }
  </style>
</Layout>
