---
import PageHero from "@/components/PageHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { formatMoldovagazProjectCount, getMoldovagazProject, moldovagazUi } from "@/data/moldovagaz-project";
import { localizePath } from "@/data/i18n";
import type { Locale } from "@/data/i18n";
import type { MoldovagazModule } from "@/data/moldovagaz-project";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;
const contentLocale = locale;
const shellLocale = contentLocale;
const project = getMoldovagazProject(contentLocale);
const ui = moldovagazUi[contentLocale];
const localizedProjectPath = localizePath(`/projects/${project.slug}/`, locale);
const moduleBySlug = new Map(project.modules.map((module) => [module.slug, module]));
const directionGroups = project.groups.map((group) => ({
  ...group,
  modules: group.projects
    .map((slug) => moduleBySlug.get(slug))
    .filter((module): module is MoldovagazModule => Boolean(module))
}));
const directionDeckCards = directionGroups
  .map((group, originalIndex) => ({ group, originalIndex }))
  .reverse();
const defaultActiveDirectionSlug = directionGroups[0]?.slug;
const directionDeckOffsets = [
  { x: "0px", y: "0px", z: 105, rotate: "-0.8deg" },
  { x: "18px", y: "70px", z: 104, rotate: "0.7deg" },
  { x: "-10px", y: "140px", z: 103, rotate: "-0.5deg" },
  { x: "22px", y: "210px", z: 102, rotate: "0.6deg" },
  { x: "6px", y: "280px", z: 101, rotate: "-0.7deg" }
];
const priorityQuadrants = project.priorityMatrix.map((quadrant) => ({
  ...quadrant,
  modules: quadrant.projects
    .map((slug) => moduleBySlug.get(slug))
    .filter((module): module is MoldovagazModule => Boolean(module))
}));

const directionSignals = directionGroups.map((group, index) => ({
  title: group.title,
  state: formatMoldovagazProjectCount(contentLocale, group.modules.length),
  icon: group.icon,
  detail: group.summary,
  meter: `${76 + index * 4}%`,
  href: `#${group.slug}`
}));
const mapNavItems = directionGroups.map((group, index) => ({
  href: `#${group.slug}`,
  kicker: `${ui.directionLabel} ${String(index + 1).padStart(2, "0")}`,
  title: group.title,
  detail: formatMoldovagazProjectCount(contentLocale, group.modules.length)
}));
const applicationProposalHref =
  contentLocale === "ru"
    ? localizePath(`/projects/${project.slug}/chisinaugaz-requests/`, locale)
    : `/projects/${project.slug}/chisinaugaz-requests/`;
const applicationProposal = {
  eyebrow: "Проектное предложение",
  title: "Chișinău-Gaz: заявления Единого окна",
  text:
    "Готовая клиентская выкладка по цифровизации подачи, мониторинга и контроля заявлений вокруг 1C/ERP: состав работ, сложные места, сроки, бюджет и данные для точной оценки.",
  tags: ["1C/ERP", "SLA", "OTP и QR", "Уведомления", "Dashboard", "Бюджет"],
  metrics: [
    { value: "до 20", label: "недель на первый запуск" },
    { value: "до 110k", label: "EUR бюджет запуска" },
    { value: "до 3", label: "недель на обследование" }
  ],
  points: [
    "клиентская проверка статуса заявления без звонка;",
    "панель руководителя для сроков, рисков и просрочек;",
    "автоматические уведомления и доказательная история действий."
  ]
};

const projectVisual = {
  mode: "private-project",
  icon: project.icon,
  label: project.client,
  state: project.status,
  output: ui.heroFlow,
  coreHref: localizedProjectPath,
  nodes: directionSignals,
  metrics: [
    { value: String(project.groups.length).padStart(2, "0"), label: ui.metricDirections },
    { value: String(project.modules.length).padStart(2, "0"), label: ui.modules },
    { value: contentLocale === "ru" ? "Аудит" : "Audit", label: ui.auditStartPoint }
  ]
};
---

<Layout title={`${project.title} | AlfaRank`} description={project.summary} locale={shellLocale} robots="noindex, nofollow">
  <div class="private-project-page" data-no-translate>
    <PageHero
      eyebrow={project.eyebrow}
      title={project.title}
      text={project.summary}
      primaryHref="#audit"
      primaryLabel={ui.projectOverview}
      secondaryHref="#navigation"
      secondaryLabel={ui.navigationLabel}
      locale={locale}
      visual={projectVisual}
    />

    <section class="section moldovagaz-proposal-section" id="project-proposals">
      <div class="section-header">
        <div>
          <p class="eyebrow">{applicationProposal.eyebrow}</p>
          <h2>{applicationProposal.title}</h2>
        </div>
        <p>{applicationProposal.text}</p>
      </div>

      <article class="glass-panel moldovagaz-proposal-card">
        <div class="moldovagaz-proposal-card__main">
          <p class="eyebrow">Готово для обсуждения с клиентом</p>
          <h3>Цифровизация заявлений вокруг 1C/ERP</h3>
          <p>
            Страница упакована как презентация: что нужно сделать, где возникнут сложности,
            сколько времени займет первый запуск и какой бюджет стоит закладывать.
          </p>
          <div class="tag-grid">
            {applicationProposal.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <a class="button primary" href={applicationProposalHref}>Открыть предложение</a>
        </div>
        <div class="moldovagaz-proposal-card__side">
          <div class="moldovagaz-proposal-metrics">
            {applicationProposal.metrics.map((metric) => (
              <span>
                <strong>{metric.value}</strong>
                <small>{metric.label}</small>
              </span>
            ))}
          </div>
          <ul class="feature-list">
            {applicationProposal.points.map((point) => <li>{point}</li>)}
          </ul>
        </div>
      </article>
    </section>

    <section class="section moldovagaz-map-navigation" id="navigation">
      <div class="section-header">
        <div>
          <p class="eyebrow">{ui.navigationLabel}</p>
          <h2>{ui.hierarchyTitle}</h2>
        </div>
        <p>{ui.hierarchyText}</p>
      </div>
      <nav class="moldovagaz-map-nav" aria-label={ui.mapNavigationAria}>
        {mapNavItems.map((item) => (
          <a href={item.href}>
            <span>{item.kicker}</span>
            <strong>{item.title}</strong>
            <small>{item.detail}</small>
          </a>
        ))}
      </nav>
    </section>

    <section class="section split-panel private-pitch-split" id="audit">
      <article class="glass-panel private-slide-card private-slide-card--lead moldovagaz-lead-card">
        <p class="eyebrow">{ui.projectOverview}</p>
        <h2>{project.thesis.title}</h2>
        <p>{project.thesis.text}</p>
      </article>
      <article class="glass-panel private-slide-card">
        <p class="eyebrow">{ui.outputs}</p>
        <div class="tag-grid">
          {project.outputs.map((output) => <span class="tag">{output}</span>)}
        </div>
        <h3>{project.status}</h3>
        <p>{project.description}</p>
      </article>
    </section>

    <section class="section" id="project-map">
      <div class="section-header">
        <div>
          <p class="eyebrow">{ui.projectMap}</p>
          <h2>{project.navigation.title}</h2>
        </div>
        <p>{project.navigation.text}</p>
      </div>

      <div class="moldovagaz-direction-stack moldovagaz-direction-stack--restored">
        <div class="moldovagaz-direction-deck__intro">
          <p class="eyebrow">{ui.deckIntroEyebrow}</p>
          <h3>{ui.deckIntroTitle}</h3>
          <p>{ui.deckIntroText}</p>
        </div>
        <div class="moldovagaz-direction-deck__tabs" aria-label={ui.deckIntroTitle}>
          {directionGroups.map((group, index) => (
            <article
              class="glass-panel moldovagaz-direction-card moldovagaz-direction-card--static"
              id={group.slug}
              data-direction-card={group.slug}
              style={`--stack-accent: ${74 + index * 5}%;`}
            >
              <div class="moldovagaz-direction-card__top">
                <span class="private-slide-number">{String(index + 1).padStart(2, "0")}</span>
                <SystemIcon name={group.icon} />
                <div class="moldovagaz-direction-card__head">
                  <div>
                    <p class="eyebrow">{ui.directionProjects}</p>
                    <h3>{group.title}</h3>
                  </div>
                </div>
                <span class="moldovagaz-stack-layer__count">{formatMoldovagazProjectCount(contentLocale, group.modules.length)}</span>
              </div>
              <div class="moldovagaz-stack-layer__content">
                <div class="moldovagaz-stack-layer__body">
                  <p>{group.summary}</p>
                  <p>{group.framing}</p>
                  <div class="tag-grid">
                    {group.outcomes.map((outcome) => <span class="tag">{outcome}</span>)}
                  </div>
                </div>
                <div class="moldovagaz-stack-layer__projects" aria-label={group.title}>
                  <p class="eyebrow">{ui.directionProjects}</p>
                  <div class="moldovagaz-project-list">
                    {group.modules.map((module, moduleIndex) => (
                      <a class="moldovagaz-project-link" href={localizePath(`/projects/${project.slug}/${module.slug}/`, locale)}>
                        <span>{String(moduleIndex + 1).padStart(2, "0")}</span>
                        <strong>{module.title}</strong>
                        <small>{module.summary}</small>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="moldovagaz-direction-deck__panels">
          {directionGroups.map((group, index) => (
            <article
              class={`glass-panel moldovagaz-direction-panel${group.slug === defaultActiveDirectionSlug ? " is-active" : ""}`}
              data-direction-panel={group.slug}
              style={`--stack-accent: ${74 + index * 5}%;`}
            >
              <div class="moldovagaz-direction-panel__head">
                <span class="private-slide-number">{String(index + 1).padStart(2, "0")}</span>
                <SystemIcon name={group.icon} />
                <div>
                  <p class="eyebrow">{ui.directionProjects}</p>
                  <h3>{group.title}</h3>
                </div>
                <span class="moldovagaz-stack-layer__count">{formatMoldovagazProjectCount(contentLocale, group.modules.length)}</span>
              </div>
              <div class="moldovagaz-stack-layer__content">
                <div class="moldovagaz-stack-layer__body">
                  <p>{group.summary}</p>
                  <p>{group.framing}</p>
                  <div class="tag-grid">
                    {group.outcomes.map((outcome) => <span class="tag">{outcome}</span>)}
                  </div>
                </div>
                <div class="moldovagaz-stack-layer__projects" aria-label={`${group.title}: ${ui.directionProjects}`}>
                  <p class="eyebrow">{ui.directionProjects}</p>
                  <div class="moldovagaz-project-list">
                  {group.modules.map((module, moduleIndex) => (
                    <a class="moldovagaz-project-link" href={localizePath(`/projects/${project.slug}/${module.slug}/`, locale)}>
                      <span>{String(moduleIndex + 1).padStart(2, "0")}</span>
                      <strong>{module.title}</strong>
                      <small>{module.summary}</small>
                    </a>
                  ))}
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="priority-matrix">
      <div class="section-header">
        <div>
          <p class="eyebrow">{ui.priorityMatrix}</p>
          <h2>{ui.priorityTitle}</h2>
        </div>
        <p>{ui.priorityText}</p>
      </div>
      <div class="moldovagaz-priority-grid">
        {priorityQuadrants.map((quadrant, index) => (
          <article class="glass-panel private-slide-card moldovagaz-priority-card">
            <span class="private-slide-number">{String(index + 1).padStart(2, "0")}</span>
            <p class="eyebrow">{quadrant.label}</p>
            <h3>{quadrant.title}</h3>
            <p>{quadrant.summary}</p>
            <div class="tag-grid">
              {quadrant.criteria.map((criterion) => <span class="tag">{criterion}</span>)}
            </div>
            <div class="moldovagaz-project-list moldovagaz-project-list--compact">
              {quadrant.modules.map((module) => (
                <a class="moldovagaz-project-link" href={localizePath(`/projects/${project.slug}/${module.slug}/`, locale)}>
                  <SystemIcon name={module.icon} />
                  <strong>{module.title}</strong>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" id="selection">
      <div class="section-header">
        <div>
          <p class="eyebrow">{ui.implementationPlan}</p>
          <h2>{project.implementation.title}</h2>
        </div>
        <p>{project.implementation.text}</p>
      </div>
      <ol class="private-step-list">
        {project.implementation.steps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <p>{step}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="section" id="presentation">
      <div class="section-header">
        <div>
          <p class="eyebrow">{ui.presentationFlow}</p>
          <h2>{ui.presentationTitle}</h2>
        </div>
        <p>{project.navigation.core}</p>
      </div>
      <div class="private-presentation-deck">
        {project.presentationCards.map((card, index) => (
          <article class="glass-panel private-slide-card">
            <span class="private-slide-number">{String(index + 1).padStart(2, "0")}</span>
            <p class="eyebrow">{card.eyebrow}</p>
            <h3>{card.title}</h3>
            <p>{card.text}</p>
            <div class="tag-grid">
              {card.items.map((item) => <span class="tag">{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section split-panel">
      <article class="glass-panel private-slide-card">
        <p class="eyebrow">{ui.valuePromise}</p>
        <h2>{project.thesis.title}</h2>
        <ul class="feature-list">
          {project.thesis.items.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="glass-panel private-slide-card">
        <p class="eyebrow">{ui.guardrails}</p>
        <h2>{project.guardrail.title}</h2>
        <p>{project.guardrail.text}</p>
        <ul class="feature-list">
          {project.guardrail.items.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </section>
  </div>

  <script>
    document.querySelectorAll("[data-direction-deck]").forEach((deck) => {
      const cards = Array.from(deck.querySelectorAll("[data-direction-card]"));

      const activateDirection = (slug) => {
        cards.forEach((card) => {
          const isActive = card.getAttribute("data-direction-card") === slug;
          const trigger = card.querySelector("[data-direction-trigger]");

          card.classList.toggle("is-active", isActive);
          trigger?.setAttribute("aria-expanded", String(isActive));
        });
      };

      const activateFromHash = () => {
        const slug = window.location.hash.slice(1);
        if (slug && cards.some((card) => card.getAttribute("data-direction-card") === slug)) {
          activateDirection(slug);
        }
      };

      cards.forEach((card) => {
        const slug = card.getAttribute("data-direction-card");
        const trigger = card.querySelector("[data-direction-trigger]");
        if (!slug) return;

        trigger?.addEventListener("click", () => activateDirection(slug));
        trigger?.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            activateDirection(slug);
          }
        });
      });

      activateFromHash();
      window.addEventListener("hashchange", activateFromHash);
    });
  </script>

  <style>
    .moldovagaz-proposal-section {
      margin-top: clamp(38px, 5vw, 72px);
    }

    .moldovagaz-proposal-card {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(360px, 0.58fr);
      gap: clamp(22px, 3.5vw, 52px);
      align-items: stretch;
      border-color: rgba(255, 209, 102, 0.34);
      padding: clamp(24px, 3.4vw, 46px);
      background:
        linear-gradient(90deg, rgba(255, 209, 102, 0.1), transparent 26%),
        radial-gradient(circle at 88% 16%, rgba(141, 233, 255, 0.16), transparent 32%),
        rgba(6, 26, 48, 0.84);
    }

    .moldovagaz-proposal-card__main,
    .moldovagaz-proposal-card__side {
      min-width: 0;
    }

    .moldovagaz-proposal-card__main {
      display: grid;
      align-content: start;
      gap: 18px;
    }

    .moldovagaz-proposal-card__main h3 {
      margin: 0;
      color: #ffffff;
      font-size: clamp(30px, 3vw, 46px);
      line-height: 1.04;
      letter-spacing: 0;
    }

    .moldovagaz-proposal-card__main p:not(.eyebrow) {
      max-width: 760px;
      margin: 0;
      color: rgba(238, 248, 255, 0.82);
      font-size: clamp(17px, 1.3vw, 21px);
      line-height: 1.58;
    }

    .moldovagaz-proposal-card__main .button {
      width: fit-content;
      margin-top: 4px;
    }

    .moldovagaz-proposal-card__side {
      display: grid;
      gap: 18px;
      align-content: start;
    }

    .moldovagaz-proposal-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .moldovagaz-proposal-metrics span {
      display: grid;
      min-height: 112px;
      align-content: center;
      border: 1px solid rgba(216, 251, 255, 0.18);
      border-radius: 6px;
      padding: 14px;
      background: rgba(255, 255, 255, 0.055);
    }

    .moldovagaz-proposal-metrics strong,
    .moldovagaz-proposal-metrics small {
      display: block;
    }

    .moldovagaz-proposal-metrics strong {
      color: #ffd166;
      font-size: clamp(24px, 2.2vw, 34px);
      line-height: 1;
    }

    .moldovagaz-proposal-metrics small {
      margin-top: 10px;
      color: rgba(238, 248, 255, 0.74);
      font-size: 13px;
      font-weight: 800;
      line-height: 1.35;
    }

    .moldovagaz-proposal-card__side .feature-list {
      border: 1px solid rgba(216, 251, 255, 0.14);
      border-radius: 6px;
      padding: 18px 20px;
      background: rgba(2, 15, 31, 0.34);
    }

    @media (max-width: 1180px) {
      .moldovagaz-proposal-card {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .moldovagaz-proposal-card {
        padding: 22px;
      }

      .moldovagaz-proposal-metrics {
        grid-template-columns: 1fr;
      }

      .moldovagaz-proposal-card__main .button {
        width: 100%;
      }
    }
  </style>

  <style is:global>
    html body .private-project-page .moldovagaz-direction-stack[data-direction-deck] {
      --moldovagaz-card-header: 82px;
      --moldovagaz-card-open: 620px;
      position: relative !important;
      min-height: 860px !important;
      margin-top: clamp(118px, 11vw, 150px) !important;
      padding: 0 !important;
      overflow: visible !important;
      perspective: none !important;
    }

    html body .private-project-page .moldovagaz-direction-stack[data-direction-deck] .moldovagaz-direction-deck__intro {
      position: absolute !important;
      top: clamp(-150px, -11vw, -118px) !important;
      right: 0 !important;
      left: 0 !important;
      z-index: 8 !important;
      display: grid !important;
      grid-template-columns: minmax(360px, 0.74fr) minmax(420px, 1fr) !important;
      column-gap: clamp(30px, 5vw, 74px) !important;
      row-gap: 10px !important;
      align-items: end !important;
      width: auto !important;
      max-width: none !important;
      padding: 0 0 clamp(20px, 2.4vw, 30px) !important;
      pointer-events: none !important;
    }

    html body .private-project-page .moldovagaz-direction-stack[data-direction-deck] .moldovagaz-direction-deck__intro .eyebrow {
      grid-column: 1 / -1 !important;
      margin: 0 !important;
    }

    html body .private-project-page .moldovagaz-direction-stack[data-direction-deck] .moldovagaz-direction-deck__intro h3 {
      grid-column: 1 / 2 !important;
      max-width: 560px !important;
      margin: 0 !important;
      font-size: clamp(34px, 3vw, 50px) !important;
      line-height: 1.04 !important;
      overflow-wrap: normal !important;
      text-wrap: balance !important;
      word-break: normal !important;
      hyphens: none !important;
    }

    html body .private-project-page .moldovagaz-direction-stack[data-direction-deck] .moldovagaz-direction-deck__intro p:not(.eyebrow) {
      grid-column: 2 / 3 !important;
      justify-self: end !important;
      max-width: 620px !important;
      margin: 0 !important;
      border-left: 1px solid rgba(216, 251, 255, 0.64) !important;
      padding-left: clamp(18px, 2vw, 28px) !important;
      color: rgba(238, 248, 255, 0.78) !important;
      font-size: clamp(15px, 1.05vw, 18px) !important;
      line-height: 1.48 !important;
    }

    html body .private-project-page .moldovagaz-direction-stack[data-direction-deck] .moldovagaz-direction-deck__tabs {
      position: absolute !important;
      top: clamp(34px, 3.2vw, 48px) !important;
      right: clamp(34px, 4vw, 58px) !important;
      bottom: clamp(34px, 4vw, 58px) !important;
      left: clamp(34px, 4vw, 58px) !important;
      z-index: 12 !important;
      width: auto !important;
      height: auto !important;
      padding: 0 !important;
      pointer-events: auto !important;
    }

    html body .private-project-page .moldovagaz-direction-stack[data-direction-deck]:hover .moldovagaz-direction-deck__tabs .moldovagaz-stack-layer:not(.is-active),
    html body .private-project-page .moldovagaz-direction-deck__tabs .moldovagaz-stack-layer,
    html body .private-project-page .moldovagaz-direction-deck__tabs .moldovagaz-stack-layer:not(.is-active) {
      position: absolute !important;
      top: var(--sheet-top, 0px) !important;
      right: var(--sheet-right, 16%) !important;
      left: var(--sheet-left, 0%) !important;
      z-index: var(--deck-z, 10) !important;
      height: var(--moldovagaz-card-header) !important;
      min-height: var(--moldovagaz-card-header) !important;
      max-height: var(--moldovagaz-card-header) !important;
      border: 0 !important;
      border-radius: 6px !important;
      padding: 0 !important;
      overflow: visible !important;
      background: transparent !important;
      box-shadow: none !important;
      opacity: 0.82 !important;
