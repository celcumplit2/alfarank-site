    partnerTypes: [
      ["Агентства", "Клиенту нужен системный слой шире кампаний, дизайна или контента.", "flow"],
      ["Разработчики", "Вы видите бизнес-scope, которому нужны продуктовая логика и операционный UX.", "api"],
      ["SEO-специалисты", "Рост требует контентной инфраструктуры, фидов, мониторинга или publishing-процессов.", "lens"],
      ["Консультанты", "Бизнес-процесс понятен, но техническая система еще не собрана в форму.", "target"],
      ["Нишевые каналы", "Аудитория часто спрашивает про автоматизацию, панели, CRM или платформы.", "lead"]
    ],
    steps: [
      ["01", "Источник сохранен", "Partner/ref-код, UTM, язык, страница и оффер сохраняются вместе с лидом.", "data"],
      ["02", "Fit квалифицирован", "Заявка маршрутизируется как партнерский трафик и получает оценку срочности и ясности scope.", "chip"],
      ["03", "Scope открыт", "AlfaRank превращает запрос в маршрут: автоматизация, платформа, SEO/content, данные или интеграция.", "map"]
    ],
    metrics: [
      ["Источник партнера", "Сохранен"],
      ["Оффер", "partner-program"],
      ["Маршрут", "partner"]
    ]
  }
} as const;

const copy = copyByLocale[locale];
---

<Layout title={`${copy.eyebrow} | AlfaRank`} description={copy.meta} locale={locale}>
  <section class="section partner-program" id="partner-intake">
    <div class="partner-program__shell ar-system-block">
      <div class="partner-program__intro">
        <p class="eyebrow">{copy.eyebrow}</p>
        <h1>{copy.title}</h1>
        <p class="hero-text">{copy.intro}</p>
        <p class="partner-program__note">{copy.note}</p>

        <div class="partner-program__metrics" aria-label={copy.attributionTitle}>
          {copy.metrics.map(([label, value]) => (
            <span>
              <strong>{value}</strong>
              {label}
            </span>
          ))}
        </div>
      </div>

      <form
        class="glass-panel partner-program__form"
        method="post"
        action="/api/start-project"
        data-track-source
        data-partner-intake
        data-conversion-form="partner-program"
        data-sending-label={copy.sending}
        data-sending-status={copy.sendingStatus}
      >
        <p class="eyebrow">{copy.formEyebrow}</p>
        <h2>{copy.formTitle}</h2>
        <input type="hidden" name="source_path" value="/partner-program/" />
        <input type="hidden" name="landing_page" value="/partner-program/" />
        <input type="hidden" name="landing_offer" value="partner-program" />
        <input type="hidden" name="form_variant" value="partner-program" />
        <input type="hidden" name="locale" value={locale} />
        <input type="hidden" name="referrer" />
        <input type="hidden" name="lead_channel" value="partner" />
        <input type="hidden" name="partner_ref" />
        <input type="hidden" name="project_type" value="Partner referral" />
        <input type="hidden" name="desired_output" value="Partner qualification route" />
        <input type="hidden" name="integrations" value="Partner referral tracking, source attribution, lead routing" />
        <input type="hidden" name="utm_source" />
        <input type="hidden" name="utm_medium" />
        <input type="hidden" name="utm_campaign" />
        <input type="hidden" name="utm_term" />
        <input type="hidden" name="utm_content" />
        <div class="spam-field" aria-hidden="true">
          <label for={`partner-company-website-${locale}`}>Company website</label>
          <input id={`partner-company-website-${locale}`} name="company_website" tabindex="-1" autocomplete="off" />
        </div>
        <div class="form-grid">
          <div class="field">
            <label for={`partner-name-${locale}`}>{copy.name}</label>
            <input id={`partner-name-${locale}`} name="name" autocomplete="name" required />
          </div>
          <div class="field">
            <label for={`partner-email-${locale}`}>{copy.email}</label>
            <input id={`partner-email-${locale}`} name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field">
            <label for={`partner-company-${locale}`}>{copy.company}</label>
            <input id={`partner-company-${locale}`} name="company" autocomplete="organization" />
          </div>
          <div class="field">
            <label for={`partner-type-${locale}`}>{copy.partnerType}</label>
            <input
              id={`partner-type-${locale}`}
              name="current_system"
              placeholder={copy.partnerTypePlaceholder}
              required
            />
          </div>
          <div class="field full">
            <label for={`partner-problem-${locale}`}>{copy.businessProblem}</label>
            <textarea
              id={`partner-problem-${locale}`}
              name="business_problem"
              placeholder={copy.businessProblemPlaceholder}
              required
            ></textarea>
          </div>
          <div class="field full">
            <label for={`partner-result-${locale}`}>{copy.desiredResult}</label>
            <textarea
              id={`partner-result-${locale}`}
              name="desired_result"
              placeholder={copy.desiredResultPlaceholder}
              required
            ></textarea>
          </div>
          <div class="field full">
            <label for={`partner-contact-${locale}`}>{copy.contactDetails}</label>
            <textarea
              id={`partner-contact-${locale}`}
              name="contact_details"
              placeholder={copy.contactDetailsPlaceholder}
            ></textarea>
          </div>
        </div>
        <TurnstileField />
        <div class="section-actions">
          <button class="button primary" type="submit">{copy.submit}</button>
        </div>
        <p class="form-status" data-form-status aria-live="polite"></p>
      </form>

      <div class="partner-program__network" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">{copy.eyebrow}</p>
        <h2>{copy.typesTitle}</h2>
      </div>
      <p>{copy.attributionText}</p>
    </div>
    <div class="partner-type-grid">
      {copy.partnerTypes.map(([title, text, icon]) => (
        <article class="partner-type-card">
          <SystemIcon name={icon} />
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="partner-route ar-system-block">
      <div class="partner-route__header">
        <p class="eyebrow">{copy.eyebrow}</p>
        <h2>{copy.routeTitle}</h2>
      </div>
      <div class="partner-route__steps">
        {copy.steps.map(([number, title, text, icon]) => (
          <article class="partner-route__step">
            <SystemIcon name={icon} />
            <span>{number}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
      <aside class="partner-route__attribution">
        <h3>{copy.attributionTitle}</h3>
        <p>{copy.attributionText}</p>
      </aside>
    </div>
  </section>

  <section class="section partner-program__contact">
    <div class="glass-panel">
      <p class="eyebrow">{copy.contactTitle}</p>
      <h2>{copy.contactTitle}</h2>
      <ContactChannels locale={locale} />
    </div>
  </section>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const aliases = {
        partner_ref: ["partner_ref", "partner", "ref", "affiliate", "affiliate_id"],
        utm_source: ["utm_source"],
        utm_medium: ["utm_medium"],
        utm_campaign: ["utm_campaign"],
        utm_term: ["utm_term"],
        utm_content: ["utm_content"]
      };
      const firstParam = (keys) => keys.map((key) => params.get(key)).find(Boolean) || "";

      document.querySelectorAll("form[data-partner-intake]").forEach((form) => {
        const setValue = (name, value) => {
          const input = form.querySelector(`[name='${name}']`);
          if (input) input.value = value;
        };

        setValue("source_path", `${window.location.pathname}${window.location.search}`);
        setValue("landing_page", window.location.pathname);
        setValue("landing_offer", "partner-program");
        setValue("lead_channel", "partner");
        setValue("referrer", document.referrer || "");

        Object.entries(aliases).forEach(([name, keys]) => {
          const value = firstParam(keys);
          if (value) setValue(name, value);
        });
      });
    })();
  </script>
</Layout>
