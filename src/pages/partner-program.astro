    formTitle: "Trimite un semnal de partener.",
    name: "Nume",
    email: "Email",
    company: "Companie sau canal",
    partnerType: "Tip de partener / audienta",
    partnerTypePlaceholder: "Agentie, consultant, dezvoltator, SEO, comunitate, media de nisa",
    businessProblem: "Ce tip de clienti poti recomanda?",
    businessProblemPlaceholder: "Descrie presiunea clientului, sectorul, nivelul bugetului sau cererea repetata pe care o vezi.",
