    routeTitle: "Cum sunt procesate leadurile de partener",
    attributionTitle: "Reguli de atribuire",
    attributionText:
      "Traficul de partener este urmarit prin partner_ref, partner, ref, affiliate, affiliate_id si parametri UTM. Formularul seteaza si offer=partner-program.",
    contactTitle: "Preferi un mesaj direct?",
    partnerTypes: [
      ["Agentii", "Clientii au nevoie de sisteme dincolo de campanii, design sau continut.", "flow"],
      ["Dezvoltatori", "Vezi scope de business care are nevoie de directie de produs si UX operational.", "api"],
      ["Specialisti SEO", "Cresterea are nevoie de infrastructura de continut, feeduri, monitorizare sau publicare.", "lens"],
      ["Consultanti", "Procesul de business este clar, dar sistemul tehnic nu este inca format.", "target"],
      ["Canale de nisa", "Audienta cere des automatizari, dashboarduri, CRM sau platforme.", "lead"]
    ],
    steps: [
      ["01", "Sursa capturata", "Codul partner/ref, UTM, limba, pagina si oferta sunt salvate cu leadul.", "data"],
      ["02", "Fit calificat", "Cererea este rutata ca trafic de partener si scorata dupa urgenta si claritatea scope-ului.", "chip"],
      ["03", "Scope deschis", "AlfaRank transforma cererea intr-un traseu: automatizare, platforma, SEO/content, date sau integrare.", "map"]
    ],
    metrics: [
      ["Sursa partener", "Salvata"],
      ["Oferta", "partner-program"],
      ["Rutare", "partner"]
    ]
  },
  ru: {
    meta: "Партнерская программа AlfaRank для агентств, консультантов, разработчиков, SEO-специалистов и нишевых каналов, которые могут передавать компании с потребностью в цифровых системах.",
    eyebrow: "Партнерская программа",
    title: "Передавайте клиентов, которым нужна цифровая система.",
    intro:
      "AlfaRank берет квалифицированную бизнес-потребность и превращает ее в автоматизацию, веб-платформу, content/SEO-систему, процессы данных или интеграции.",
    note: "Партнерские лиды сразу сохраняют источник, campaign-контекст и понятное следующее действие.",
    formEyebrow: "Партнерский intake",
    formTitle: "Отправьте партнерский сигнал.",
