---
const siteUrl = Astro.site ?? new URL("https://alfarank.com");
const homeUrl = new URL("/", siteUrl).toString();
const contactUrl = new URL("/contact/", siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <meta name="description" content="The requested AlfaRank page could not be found." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Page not found | AlfaRank</title>
    <style>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #080b10;
        color: #eef4f8;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
        padding: 32px;
        background:
          radial-gradient(circle at 24% 24%, rgba(54, 142, 184, 0.22), transparent 34%),
          linear-gradient(135deg, #080b10 0%, #111820 52%, #091014 100%);
      }

      main {
        width: min(720px, 100%);
      }

      p {
        margin: 0;
        color: #aab9c3;
        font-size: 18px;
        line-height: 1.7;
      }

      .eyebrow {
        margin-bottom: 20px;
        color: #74d1a6;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0 0 18px;
        max-width: 12ch;
        color: #ffffff;
        font-size: clamp(48px, 9vw, 88px);
        line-height: 0.95;
        letter-spacing: 0;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 32px;
      }

      a {
        display: inline-flex;
        min-height: 44px;
        align-items: center;
        justify-content: center;
        padding: 0 18px;
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 6px;
        color: #eef4f8;
        font-weight: 700;
        text-decoration: none;
      }

      a:first-child {
        border-color: transparent;
        background: #74d1a6;
        color: #07100c;
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p>The requested URL does not exist on AlfaRank. Use the homepage or contact page to continue.</p>
      <nav aria-label="Recovery links">
        <a href={homeUrl}>Homepage</a>
        <a href={contactUrl}>Contact</a>
      </nav>
    </main>
  </body>
</html>
