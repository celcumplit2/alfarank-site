---
import PageHero from "@/components/PageHero.astro";
import LeadAssurance from "@/components/LeadAssurance.astro";
import LeadProofPatterns from "@/components/LeadProofPatterns.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import TurnstileField from "@/components/TurnstileField.astro";
import Layout from "@/layouts/Layout.astro";
import { intakeHeroVisual } from "@/data/hero";
import { translateCopy } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;

const intakeSignals = ["Problem", "Current system", "Desired output", "Integrations"].map((signal) => translateCopy(locale, signal));
const intakePath = [
  {
    title: translateCopy(locale, "Capture context"),
    icon: "lead",
    text: translateCopy(locale, "The request enters with source, offer, UTM, current system, and business pressure.")
  },
  {
    title: translateCopy(locale, "Map scope"),
    icon: "flow",
    text: translateCopy(locale, "Inputs, integrations, expected output, and first launch boundary are turned into a build path.")
  },
  {
    title: translateCopy(locale, "Route next step"),
    icon: "monitor",
    text: translateCopy(locale, "The project can be reviewed as a landing page, automation, system, platform, or data workflow.")
  }
];

const projectTypeOptions = [
  "AI automation",
  "Web platform",
  "SEO/content infrastructure",
  "Data or monitoring system",
  "E-commerce infrastructure",
  "WordPress/API integration",
  "Internal business tool"
].map((option) => translateCopy(locale, option));

const desiredOutputOptions = [
  "Working first version",
  "Automation workflow",
  "Website or platform launch",
  "Dashboard or internal tool",
  "Content/publishing system",
  "Data monitoring/reporting system"
].map((option) => translateCopy(locale, option));

const sendingRequestLabel = translateCopy(locale, "Sending request...");
const sendingSourceStatus = translateCopy(locale, "Sending request with source context...");
---

<Layout title="Start a Project | AlfaRank" locale={locale}>
  <PageHero
    eyebrow={translateCopy(locale, "Start a Project")}
    title={translateCopy(locale, "Define the system your business needs.")}
    text={translateCopy(locale, "Use the form to describe the project type, current setup, business problem, desired result, and optional timeline or budget.")}
    visual={intakeHeroVisual}
    locale={locale}
  />

  <section class="section" id="project-intake">
    <div class="intake-reactor ar-system-block">
    <article class="glass-panel intake-reactor__quick quick-intake">
      <div class="quick-intake__copy">
        <p class="eyebrow">{translateCopy(locale, "Quick project signal")}</p>
        <h2>{translateCopy(locale, "Send a short request first.")}</h2>
        <p>{translateCopy(locale, "If the full brief feels early, send the pressure point and contact. The first reply can turn it into scope.")}</p>
      </div>
      <form
        class="quick-intake__form"
        method="post"
        action="/api/start-project"
        data-track-source
        data-conversion-form="quick-intake"
        data-sending-label={sendingRequestLabel}
        data-sending-status={sendingSourceStatus}
      >
        <input type="hidden" name="source_path" value="/start-project/" />
        <input type="hidden" name="landing_page" />
        <input type="hidden" name="landing_offer" value="quick-intake" />
        <input type="hidden" name="form_variant" value="quick-intake" />
        <input type="hidden" name="locale" value={locale} />
        <input type="hidden" name="referrer" />
        <input type="hidden" name="lead_channel" />
        <input type="hidden" name="partner_ref" />
        <input type="hidden" name="project_type" value="Quick diagnostic request" />
        <input type="hidden" name="desired_output" value="First project conversation" />
        <input type="hidden" name="desired_result" value="Define the first useful step from a short request." />
        <input type="hidden" name="utm_source" />
        <input type="hidden" name="utm_medium" />
        <input type="hidden" name="utm_campaign" />
        <input type="hidden" name="utm_term" />
        <input type="hidden" name="utm_content" />
        <div class="spam-field" aria-hidden="true">
          <label for="company_website_quick">{translateCopy(locale, "Company website")}</label>
          <input id="company_website_quick" name="company_website" tabindex="-1" autocomplete="off" />
        </div>
        <div class="quick-intake__fields">
          <div class="field">
            <label for="quick-name">{translateCopy(locale, "Name")}</label>
            <input id="quick-name" name="name" autocomplete="name" required />
          </div>
          <div class="field">
            <label for="quick-email">{translateCopy(locale, "Email")}</label>
            <input id="quick-email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field quick-intake__problem">
            <label for="quick-problem">{translateCopy(locale, "What should become faster or clearer?")}</label>
            <input id="quick-problem" name="business_problem" required />
          </div>
        </div>
        <TurnstileField />
        <div class="quick-intake__actions">
          <button class="button primary" type="submit">{translateCopy(locale, "Send Quick Request")}</button>
          <a class="button secondary" href="#full-project-brief">{translateCopy(locale, "Open full brief")}</a>
        </div>
        <p class="form-status" data-form-status aria-live="polite"></p>
      </form>
    </article>

    <article class="intake-reactor__bridge ar-system-core">
      <SystemIcon name="lead" />
      <span>{translateCopy(locale, "Intake reactor")}</span>
      <strong>{translateCopy(locale, "Turn context into scope.")}</strong>
      <p>{translateCopy(locale, "The form routes business pressure, current systems, desired output, and integrations into one project request.")}</p>
      <div class="ar-signal-strip">
        {intakeSignals.map((signal) => <span class="ar-signal">{signal}</span>)}
      </div>
    </article>

    <form
      id="full-project-brief"
      class="glass-panel intake-reactor__form"
      method="post"
      action="/api/start-project"
      data-track-source
      data-conversion-form="start-project"
      data-sending-label={sendingRequestLabel}
      data-sending-status={sendingSourceStatus}
    >
      <input type="hidden" name="source_path" value="/start-project/" />
      <input type="hidden" name="landing_page" />
      <input type="hidden" name="landing_offer" />
      <input type="hidden" name="form_variant" value="start-project" />
      <input type="hidden" name="locale" value={locale} />
      <input type="hidden" name="referrer" />
      <input type="hidden" name="lead_channel" />
      <input type="hidden" name="partner_ref" />
      <input type="hidden" name="utm_source" />
      <input type="hidden" name="utm_medium" />
      <input type="hidden" name="utm_campaign" />
      <input type="hidden" name="utm_term" />
      <input type="hidden" name="utm_content" />
      <div class="spam-field" aria-hidden="true">
        <label for="company_website">{translateCopy(locale, "Company website")}</label>
        <input id="company_website" name="company_website" tabindex="-1" autocomplete="off" />
      </div>
      <div class="form-grid">
        <div class="field">
          <label for="name">{translateCopy(locale, "Name")}</label>
          <input id="name" name="name" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="email">{translateCopy(locale, "Email")}</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
        </div>
        <div class="field">
          <label for="company">{translateCopy(locale, "Company optional")}</label>
          <input id="company" name="company" autocomplete="organization" />
        </div>
        <div class="field">
          <label id="project-type-label">{translateCopy(locale, "Project type")}</label>
          <div class="ar-select" data-custom-select>
            <input id="project-type" type="hidden" name="project_type" value={projectTypeOptions[0]} />
            <button class="ar-select__button" type="button" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="project-type-label">
              <span class="ar-select__value">{projectTypeOptions[0]}</span>
            </button>
            <div class="ar-select__menu" role="listbox">
              {projectTypeOptions.map((option, index) => (
                <button
                  class:list={["ar-select__option", index === 0 && "is-selected"]}
                  type="button"
                  role="option"
                  aria-selected={index === 0 ? "true" : "false"}
                  data-value={option}
                >
                  {option}
                </button>
              ))}
            </div>
          </div>
        </div>
        <div class="field">
          <label for="current-system">{translateCopy(locale, "Current website/system")}</label>
          <input id="current-system" name="current_system" placeholder={translateCopy(locale, "URL or short description")} />
        </div>
        <div class="field">
          <label id="desired-output-label">{translateCopy(locale, "Desired output")}</label>
          <div class="ar-select" data-custom-select>
            <input id="desired-output" type="hidden" name="desired_output" value={desiredOutputOptions[0]} />
            <button class="ar-select__button" type="button" aria-haspopup="listbox" aria-expanded="false" aria-labelledby="desired-output-label">
              <span class="ar-select__value">{desiredOutputOptions[0]}</span>
            </button>
            <div class="ar-select__menu" role="listbox">
              {desiredOutputOptions.map((option, index) => (
                <button
                  class:list={["ar-select__option", index === 0 && "is-selected"]}
                  type="button"
                  role="option"
                  aria-selected={index === 0 ? "true" : "false"}
                  data-value={option}
                >
                  {option}
                </button>
              ))}
            </div>
          </div>
        </div>
        <div class="field full">
          <label for="problem">{translateCopy(locale, "Business problem")}</label>
          <textarea id="problem" name="business_problem" required></textarea>
        </div>
        <div class="field full">
          <label for="result">{translateCopy(locale, "Desired result")}</label>
          <textarea id="result" name="desired_result" required></textarea>
        </div>
        <div class="field full">
          <label for="integrations">{translateCopy(locale, "Systems, tools, or integrations")}</label>
          <textarea id="integrations" name="integrations" placeholder={translateCopy(locale, "CMS, CRM, APIs, spreadsheets, databases, analytics, automation tools")}></textarea>
        </div>
        <div class="field">
          <label for="budget">{translateCopy(locale, "Budget optional")}</label>
          <input id="budget" name="budget" />
        </div>
        <div class="field">
          <label for="timeline">{translateCopy(locale, "Timeline optional")}</label>
          <input id="timeline" name="timeline" />
        </div>
        <div class="field full">
          <label for="contact-details">{translateCopy(locale, "Contact details optional")}</label>
          <textarea id="contact-details" name="contact_details" placeholder={translateCopy(locale, "Preferred contact channel, time zone, or extra context")}></textarea>
        </div>
      </div>
      <TurnstileField />
      <div class="section-actions" style="margin-top: 18px;">
        <button class="button primary" type="submit">{translateCopy(locale, "Send Project Request")}</button>
      </div>
      <p class="form-status" data-form-status aria-live="polite"></p>
    </form>

    <div class="intake-reactor__console">
      <div class="intake-reactor__path">
        {intakePath.map((step, index) => (
          <article class:list={["intake-reactor__step", `intake-reactor__step--${index + 1}`]}>
            <SystemIcon name={step.icon} />
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>

      <LeadAssurance locale={locale} />

      <aside class="glass-panel intake-reactor__guide">
        <h2>{translateCopy(locale, "Good project inputs")}</h2>
        <ul class="feature-list">
          <li>{translateCopy(locale, "What process needs to become faster, clearer, or more automated.")}</li>
          <li>{translateCopy(locale, "What data, website, CRM, CMS, or internal system already exists.")}</li>
          <li>{translateCopy(locale, "What output should be visible after the first implementation phase.")}</li>
          <li>{translateCopy(locale, "Which integrations, tools, or manual workflows should be connected.")}</li>
        </ul>
      </aside>
    </div>
    </div>
  </section>

  <LeadProofPatterns locale={locale} ctaHref="#project-intake" />

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const aliases = {
        landing_page: ["landing_page", "lp"],
        landing_offer: ["landing_offer", "offer"],
        partner_ref: ["partner_ref", "partner", "ref", "affiliate", "affiliate_id"],
        utm_source: ["utm_source"],
        utm_medium: ["utm_medium"],
        utm_campaign: ["utm_campaign"],
        utm_term: ["utm_term"],
        utm_content: ["utm_content"]
      };
      const firstParam = (keys) => keys.map((key) => params.get(key)).find(Boolean) || "";
      const inferLeadChannel = () => {
        if (firstParam(aliases.partner_ref) || params.get("offer") === "partner-program") return "partner";
        const medium = (params.get("utm_medium") || "").toLowerCase();
        if (["cpc", "ppc", "paid", "paid-search", "paid-social", "display"].includes(medium)) return "paid";
        if (params.get("utm_source")) return "campaign";
        if (document.referrer) return "referral";
        return "direct";
      };

      document.querySelectorAll("form[data-track-source]").forEach((form) => {
        const source = form.querySelector("[name='source_path']");
        if (source) source.value = `${window.location.pathname}${window.location.search}`;
        const referrer = form.querySelector("[name='referrer']");
        if (referrer) referrer.value = document.referrer || "";
        const leadChannel = form.querySelector("[name='lead_channel']");
        if (leadChannel) leadChannel.value = inferLeadChannel();

        Object.entries(aliases).forEach(([name, keys]) => {
          const input = form.querySelector(`[name='${name}']`);
          if (!input) return;
          const value = firstParam(keys);
          if (value) input.value = value;
          if (name === "landing_page" && !input.value) input.value = window.location.pathname;
        });
      });

      const closeSelect = (select) => {
        select.classList.remove("is-open");
        const button = select.querySelector(".ar-select__button");
        if (button) button.setAttribute("aria-expanded", "false");
      };

      const closeAllSelects = (except) => {
        document.querySelectorAll("[data-custom-select].is-open").forEach((select) => {
          if (select !== except) closeSelect(select);
        });
      };

      document.querySelectorAll("[data-custom-select]").forEach((select) => {
        const input = select.querySelector("input[type='hidden']");
        const button = select.querySelector(".ar-select__button");
        const value = select.querySelector(".ar-select__value");
        const options = Array.from(select.querySelectorAll(".ar-select__option"));
        if (!input || !button || !value || !options.length) return;

        const setOption = (option) => {
          const nextValue = option.dataset.value || option.textContent.trim();
          input.value = nextValue;
          value.textContent = nextValue;
          options.forEach((item) => {
            const isSelected = item === option;
            item.classList.toggle("is-selected", isSelected);
            item.setAttribute("aria-selected", isSelected ? "true" : "false");
          });
        };

        const openSelect = () => {
          closeAllSelects(select);
          select.classList.add("is-open");
          button.setAttribute("aria-expanded", "true");
        };

        const toggleSelect = () => {
          if (select.classList.contains("is-open")) {
            closeSelect(select);
            return;
          }
          openSelect();
        };

        const focusOption = (direction) => {
          const current = options.indexOf(document.activeElement);
          const next = current === -1 ? 0 : (current + direction + options.length) % options.length;
          options[next].focus();
        };

        button.addEventListener("click", toggleSelect);
        button.addEventListener("keydown", (event) => {
          if (event.key === "ArrowDown" || event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            openSelect();
            const selected = options.find((option) => option.classList.contains("is-selected")) || options[0];
            selected.focus();
          }
        });

        options.forEach((option) => {
          option.addEventListener("click", () => {
            setOption(option);
            closeSelect(select);
            button.focus();
          });

          option.addEventListener("keydown", (event) => {
            if (event.key === "ArrowDown") {
              event.preventDefault();
              focusOption(1);
            }
            if (event.key === "ArrowUp") {
              event.preventDefault();
              focusOption(-1);
            }
            if (event.key === "Enter" || event.key === " ") {
              event.preventDefault();
              setOption(option);
              closeSelect(select);
              button.focus();
            }
            if (event.key === "Escape") {
              event.preventDefault();
              closeSelect(select);
              button.focus();
            }
          });
        });
      });

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        if (!event.target.closest("[data-custom-select]")) closeAllSelects();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeAllSelects();
      });
    })();
  </script>
</Layout>
