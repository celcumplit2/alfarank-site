---
import NovaArticle from "@/components/NovaArticle.astro";
import Layout from "@/layouts/Layout.astro";
import {
  articleDescription,
  articleImage,
  articleTitle,
  getNovaArticle,
  getNovaArticleSummaries,
  newsArticleSchema
} from "@/lib/nova";
import type { NewsLocale } from "@/lib/nova";

export async function getStaticPaths() {
  const articles = await getNovaArticleSummaries("en");
  return articles.map((article) => ({
    params: { slug: article.slug }
  }));
}

const locale: NewsLocale = "en";
const { slug } = Astro.params;
const article = slug ? await getNovaArticle(slug, locale) : undefined;

if (!article) {
  return Astro.redirect("/news/");
}
---

<Layout
  title={`${articleTitle(article)} | AlfaRank`}
  description={articleDescription(article)}
  image={articleImage(article) || undefined}
  robots="noindex, follow"
  ogType="article"
  structuredData={newsArticleSchema(article, locale)}
>
  <NovaArticle article={article} locale={locale} />
</Layout>
