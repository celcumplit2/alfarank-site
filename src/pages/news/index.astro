---
import Layout from "@/layouts/Layout.astro";
import {
  articleCategory,
  articleDate,
  articleDescription,
  articleTitle,
  formatArticleDate,
  getNovaArticleSummaries,
  newsPath
} from "@/lib/nova";
import { translateNewsText } from "@/data/nova-news-translations";
import type { NewsLocale } from "@/lib/nova";

const locale: NewsLocale = "en";
const articles = await getNovaArticleSummaries(locale);
---

<Layout
  title="AlfaRank News Analysis | AlfaRank"
  description="Source-backed AlfaRank news analysis on automation, AI workflows, data systems, web platforms, and digital operations."
>
  <section class="section nova-news-index">
    <header class="nova-news-index__hero">
      <p class="eyebrow">News Analysis</p>
      <h1>AlfaRank intelligence for digital operators.</h1>
      <p>
        Analytical coverage from the NOVA monitoring engine: source-backed market signals, operational consequences,
        data points, and decision context for teams building automation and digital systems.
      </p>
      <nav class="nova-news-index__trust" aria-label="News trust pages">
        <a href="/news/about/">About AlfaRank News</a>
        <a href="/news/editorial-policy/">Editorial Policy</a>
        <a href="/news/authors/andrei/">Author</a>
      </nav>
    </header>

    <div class="nova-news-grid">
      {articles.map((article) => (
        <article class="nova-news-card">
          <a href={newsPath(`/news/${article.slug}/`, locale)}>
            <time datetime={articleDate(article)}>{formatArticleDate(articleDate(article), locale)}</time>
            {article.category && <span class="nova-news-card__category">{articleCategory(article, locale)}</span>}
            <h2 data-heading-copy-limit="ignore">{articleTitle(article)}</h2>
            <p>{articleDescription(article)}</p>
            {article.seo?.tags && (
              <ul>
                {article.seo.tags.slice(0, 4).map((tag) => <li>{translateNewsText(tag, locale)}</li>)}
              </ul>
            )}
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
