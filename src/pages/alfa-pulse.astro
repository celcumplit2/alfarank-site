---
import Layout from "@/layouts/Layout.astro";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;

const offers: Record<Locale, {
  metaTitle: string;
  metaDescription: string;
  eyebrow: string;
  title: string;
  lead: string;
  promiseTitle: string;
  bullets: string[];
  modelTitle: string;
  modelText: string;
  metrics: string[];
  download: string;
  open: string;
  pdf: string;
  cover: string;
  previewLabel: string;
}> = {
  en: {
    metaTitle: "ALFA Pulse Commercial Offer | AlfaRank",
    metaDescription: "ALFA Pulse commercial offer PDF for connecting website, advertising, CRM, sales and revenue into one management layer.",
    eyebrow: "ALFA Pulse / Digital Revenue Operations",
    title: "ALFA Pulse commercial offer",
    lead:
      "A management layer that connects the website, advertising, CRM, sales handling and actual revenue into one controlled digital contour.",
    promiseTitle: "What the company gets",
    bullets: [
      "website control as the first conversion point",
      "connection between ads, forms, CRM, sales and revenue",
      "visibility into where digital creates revenue or leaks budget",
      "budget recommendations based on actual commercial result"
    ],
    modelTitle: "Commercial model",
    modelText:
      "Instead of paying for a fragmented digital department, the company pays for a management contour that shows the link between budget and revenue.",
    metrics: ["Website", "Advertising", "CRM", "Sales", "Revenue"],
    download: "Download PDF",
    open: "Open PDF",
    pdf: "/offers/alfa-pulse/alfa-pulse-offer-en.pdf",
    cover: "/offers/alfa-pulse/alfa-pulse-cover-en.png",
    previewLabel: "English PDF"
  },
  ro: {
    metaTitle: "Oferta comercială ALFA Pulse | AlfaRank",
    metaDescription: "Oferta comercială ALFA Pulse în format PDF pentru conectarea site-ului, publicității, CRM-ului, vânzărilor și venitului real.",
    eyebrow: "ALFA Pulse / managementul vânzărilor digitale",
    title: "Oferta comercială ALFA Pulse",
    lead:
      "Un strat de management care conectează site-ul, publicitatea, CRM-ul, procesarea vânzărilor și venitul real într-un circuit digital unic.",
    promiseTitle: "Ce primește compania",
    bullets: [
      "controlul site-ului ca primul punct de conversie",
      "legătura dintre publicitate, formulare, CRM, vânzări și venit",
      "vizibilitate asupra locurilor unde digitalul aduce bani sau pierde buget",
      "recomandări de buget pe baza rezultatului real"
    ],
    modelTitle: "Forma comercială",
    modelText:
      "În loc să plătească un departament digital fragmentat, compania plătește un circuit de management care arată legătura dintre buget și venit.",
    metrics: ["Site", "Publicitate", "CRM", "Vânzări", "Venit"],
    download: "Descarcă PDF",
    open: "Deschide PDF",
    pdf: "/offers/alfa-pulse/alfa-pulse-offer-ro.pdf",
    cover: "/offers/alfa-pulse/alfa-pulse-cover-ro.png",
    previewLabel: "PDF în română"
  },
  ru: {
    metaTitle: "Коммерческое предложение ALFA Pulse | AlfaRank",
    metaDescription: "Коммерческое предложение ALFA Pulse в PDF: сайт, реклама, CRM, продажи и выручка в одном управляемом digital-контуре.",
    eyebrow: "ALFA Pulse / управление digital-продажами",
    title: "Коммерческое предложение ALFA Pulse",
    lead:
      "Управляющий слой, который связывает сайт, рекламу, CRM, обработку продаж и фактическую выручку в единый цифровой контур.",
    promiseTitle: "Что получает компания",
    bullets: [
      "контроль сайта как первой точки конверсии",
      "связь рекламы, форм, CRM, продаж и выручки",
      "понимание, где digital приносит деньги, а где теряет бюджет",
      "рекомендации по бюджету на основе реального результата"
    ],
    modelTitle: "Коммерческая форма",
    modelText:
      "Вместо оплаты разрозненного digital-отдела компания оплачивает контур управления, который показывает связь бюджета с выручкой.",
    metrics: ["Сайт", "Реклама", "CRM", "Продажи", "Выручка"],
    download: "Скачать PDF",
    open: "Открыть PDF",
    pdf: "/offers/alfa-pulse/alfa-pulse-offer-ru.pdf",
    cover: "/offers/alfa-pulse/alfa-pulse-cover-ru.png",
    previewLabel: "PDF на русском"
  }
};

const copy = offers[locale] ?? offers.en;
---

<Layout title={copy.metaTitle} description={copy.metaDescription} locale={locale}>
  <section class="section pulse-offer" data-no-translate>
    <div class="pulse-offer__shell">
      <div class="pulse-offer__hero">
        <div class="pulse-offer__copy">
          <p class="eyebrow">{copy.eyebrow}</p>
          <h1>{copy.title}</h1>
          <p>{copy.lead}</p>
        </div>

        <div class="pulse-offer__actions" aria-label={copy.previewLabel}>
          <a class="button primary" href={copy.pdf} download>{copy.download}</a>
          <a class="button secondary" href={copy.pdf} target="_blank" rel="noreferrer">{copy.open}</a>
        </div>
      </div>

      <div class="pulse-offer__body">
        <article class="pulse-offer__content">
          <div class="pulse-offer__signal-row" aria-label="ALFA Pulse contour">
            {copy.metrics.map((metric) => <span>{metric}</span>)}
          </div>

          <div class="pulse-offer__detail-grid">
            <section class="pulse-offer__detail">
              <h2>{copy.promiseTitle}</h2>
              <ul>
                {copy.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            </section>
            <section class="pulse-offer__detail">
              <h2>{copy.modelTitle}</h2>
              <p>{copy.modelText}</p>
            </section>
          </div>
        </article>

        <aside class="pulse-offer__document" aria-label={copy.previewLabel}>
          <div class="pulse-offer__document-head">
            <span>{copy.previewLabel}</span>
            <strong>PDF</strong>
          </div>
          <a href={copy.pdf} target="_blank" rel="noreferrer" aria-label={copy.open}>
            <img src={copy.cover} alt={copy.previewLabel} loading="eager" />
          </a>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pulse-offer {
    width: 100%;
    max-width: 100%;
    overflow-x: clip;
    padding-top: clamp(18px, 3vw, 42px);
  }

  .pulse-offer,
  .pulse-offer * {
    box-sizing: border-box;
    min-width: 0;
  }

  .pulse-offer__shell {
    position: relative;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    border: 1px solid rgba(216, 251, 255, 0.14);
    border-radius: 4px;
    background:
      radial-gradient(circle at 10% 0%, rgba(216, 251, 255, 0.14), transparent 34%),
      linear-gradient(135deg, rgba(10, 40, 78, 0.54), rgba(4, 18, 45, 0.72));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 26px 72px rgba(0, 12, 34, 0.34);
  }

  .pulse-offer__shell::before,
  .pulse-offer__shell::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }

  .pulse-offer__shell::before {
    inset: 0;
    opacity: 0.34;
    background-image:
      linear-gradient(rgba(216, 251, 255, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(216, 251, 255, 0.06) 1px, transparent 1px);
    background-size: 72px 72px;
  }

  .pulse-offer__shell::after {
    left: -12%;
    right: -8%;
    bottom: -24%;
    height: 48%;
    border-top: 1px solid rgba(216, 251, 255, 0.30);
    border-radius: 50% 50% 0 0;
    background: linear-gradient(180deg, rgba(216, 251, 255, 0.16), rgba(4, 25, 62, 0.06));
    transform: rotate(-3deg);
  }

  .pulse-offer__hero,
  .pulse-offer__body {
    position: relative;
    z-index: 1;
  }

  .pulse-offer__hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    padding: clamp(24px, 5vw, 56px);
    border-bottom: 1px solid rgba(216, 251, 255, 0.11);
  }

  .pulse-offer__copy {
    max-width: 820px;
  }

  .pulse-offer__copy h1 {
    margin: 0;
    max-width: 760px;
    color: #fff;
    font-size: clamp(40px, 5.3vw, 72px);
    line-height: 1;
    letter-spacing: 0;
    text-shadow: 0 2px 2px rgba(0, 18, 72, 0.55), 0 8px 22px rgba(0, 30, 120, 0.35);
  }

  .pulse-offer__copy p:not(.eyebrow) {
    max-width: 720px;
    margin: 22px 0 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(17px, 1.65vw, 21px);
    line-height: 1.5;
  }

  .pulse-offer__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
    width: min(320px, 100%);
  }

  .pulse-offer__actions .button {
    width: 100%;
  }

  .pulse-offer__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.68fr);
    gap: clamp(20px, 4vw, 48px);
    align-items: start;
    padding: 0 clamp(18px, 5vw, 56px) clamp(24px, 5vw, 56px);
  }

  .pulse-offer__content,
  .pulse-offer__document {
    border: 1px solid rgba(128, 199, 255, 0.22);
    border-radius: 4px;
    background:
      linear-gradient(135deg, rgba(14, 38, 66, 0.36), rgba(7, 22, 39, 0.22)),
      rgba(4, 16, 31, 0.24);
    box-shadow: inset 0 1px 14px rgba(255, 255, 255, 0.10), 0 22px 46px -28px rgba(0, 21, 78, 0.34);
  }

  .pulse-offer__content {
    padding: clamp(22px, 4vw, 42px);
  }

  .pulse-offer__signal-row {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 6px;
    padding: 6px;
    border: 1px solid rgba(216, 251, 255, 0.16);
    border-radius: 4px;
    background: rgba(3, 18, 45, 0.48);
  }

  .pulse-offer__signal-row span {
    min-height: 42px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(216, 251, 255, 0.14);
    border-radius: 3px;
    color: #d8fbff;
    background: rgba(216, 251, 255, 0.06);
    font-size: 12px;
    font-weight: 850;
    text-align: center;
  }

  .pulse-offer__detail-grid {
    display: grid;
    grid-template-columns: 1.12fr 0.88fr;
    gap: 14px;
    margin-top: 18px;
  }

  .pulse-offer__detail {
    min-height: 190px;
    padding: 20px;
    border: 1px solid rgba(216, 251, 255, 0.14);
    border-radius: 4px;
    background: rgba(3, 18, 45, 0.34);
  }

  .pulse-offer__detail h2 {
    margin: 0;
    color: #fff;
    font-size: 21px;
    line-height: 1.2;
  }

  .pulse-offer__detail p,
  .pulse-offer__detail li {
    color: rgba(255, 255, 255, 0.84);
    font-size: 15px;
    line-height: 1.5;
  }

  .pulse-offer__detail p {
    margin: 14px 0 0;
  }

  .pulse-offer__detail ul {
    margin: 14px 0 0;
    padding-left: 18px;
  }

  .pulse-offer__document {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .pulse-offer__document-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(216, 251, 255, 0.13);
    color: rgba(255, 255, 255, 0.74);
    font-size: 12px;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .pulse-offer__document-head strong {
    color: #d8fbff;
  }

  .pulse-offer__document a {
    display: block;
    padding: 16px;
  }

  .pulse-offer__document img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    object-position: center top;
    background: rgba(3, 18, 45, 0.62);
    border: 1px solid rgba(216, 251, 255, 0.16);
    border-radius: 3px;
    box-shadow: 0 18px 40px rgba(0, 10, 30, 0.34);
  }

  @media (max-width: 1080px) {
    .pulse-offer__hero,
    .pulse-offer__body {
      grid-template-columns: 1fr;
    }

    .pulse-offer__actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    .pulse-offer {
      padding-top: 18px;
    }

    .pulse-offer__hero,
    .pulse-offer__content,
    .pulse-offer__body {
      padding-left: 14px;
      padding-right: 14px;
    }

    .pulse-offer__hero {
      gap: 22px;
    }

    .pulse-offer__copy h1 {
      font-size: clamp(36px, 10vw, 44px);
      line-height: 1.04;
    }

    .pulse-offer__copy p:not(.eyebrow) {
      font-size: 17px;
      line-height: 1.48;
    }

    .pulse-offer__signal-row,
    .pulse-offer__detail-grid {
      grid-template-columns: 1fr;
    }

    .pulse-offer__document img {
      max-height: 360px;
    }
  }

  @media (max-width: 420px) {
    .pulse-offer__copy h1 {
      font-size: 35px;
    }

    .pulse-offer__detail {
      padding: 16px;
    }
  }
</style>
