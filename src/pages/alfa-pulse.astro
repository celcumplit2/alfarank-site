        { title: "Web Layer", text: "Миграция или обновление сайта может входить в стартовый пакет." },
        { title: "Add-ons", text: "Соцсети, контент, product content, visual/AI production и интеграции подключаются отдельно." }
      ],
      conclusion:
        "ALFA Pulse становится верхним слоем управления вашим digital-полем: сайт становится точкой конверсии, CRM - источником обратной связи, реклама - каналом, который оптимизируется по реальным деньгам."
    },
    form: {
      eyebrow: "Интерес к ALFA Pulse",
      title: "Оставьте контакты, и мы подключим следующий шаг",
      text:
        "Отправьте короткий сигнал. Заявка попадет в существующую lead-систему AlfaRank с ALFA Pulse как источником оффера.",
      name: "Имя",
      email: "Email",
      company: "Компания необязательно",
      problem: "Что ALFA Pulse должен прояснить в первую очередь?",
      contact: "Телефон, мессенджер или дополнительный контекст необязательно",
      submit: "Отправить заявку",
      sending: "Отправляем заявку...",
      status: "Отправляем заявку ALFA Pulse с контекстом источника...",
      validation: "Проверьте выделенное поле и попробуйте еще раз.",
      projectType: "Digital revenue operations",
      desiredOutput: "Контур управления ALFA Pulse",
      desiredResult: "Связать сайт, рекламу, CRM, продажи и выручку в единый слой управления.",
      integrations: "Сайт, рекламные кабинеты, CRM, аналитика, процесс продаж",
      honeypot: "Сайт компании"
    }
  }
};

const copy = offers[locale] ?? offers.en;
const sourcePath = localizePath("/alfa-pulse/", locale);
const formVariant = "alfa-pulse-offer";
const documentCardLabel = copy.pdfLabel.replace(/\s+PDF$/i, "");
---

<Layout title={copy.metaTitle} description={copy.metaDescription} image={copy.cover} locale={locale}>
  <div class="pulse-page" data-no-translate>
    <section class="section pulse-hero" aria-labelledby="pulse-title">
      <div class="pulse-hero__copy">
        <p class="eyebrow">{copy.eyebrow}</p>
        <h1 id="pulse-title">{copy.title}</h1>
        <p class="pulse-hero__lead">{copy.lead}</p>
        <div class="hero-actions">
          <a class="button primary" href="#pulse-contact">{copy.primaryCta}</a>
          <a class="button secondary" href={copy.pdf} download>{copy.downloadCta}</a>
          <a class="button secondary" href={copy.pdf} target="_blank" rel="noreferrer">{copy.openPdf}</a>
        </div>
      </div>

      <aside class="pulse-document-card" aria-label={copy.pdfLabel}>
        <div class="pulse-document-card__head">
          <span>{documentCardLabel}</span>
          <strong>PDF</strong>
        </div>
        <a href={copy.pdf} target="_blank" rel="noreferrer" aria-label={copy.openPdf}>
          <img src={copy.cover} alt={copy.previewAlt} loading="eager" />
        </a>
      </aside>
    </section>

    <section class="section pulse-contour" aria-label="ALFA Pulse contour">
      <div class="pulse-contour__metrics">
        {copy.metrics.map((metric) => <span>{metric}</span>)}
      </div>
      <article class="pulse-contour__core">
        <span>ALFA Pulse</span>
        <strong>{copy.connects.core}</strong>
      </article>
    </section>

    <section class="section pulse-content-section" aria-labelledby="pulse-leakage-title">
      <div class="section-header">
        <div>
          <p class="eyebrow">{copy.leakage.eyebrow}</p>
          <h2 id="pulse-leakage-title">{copy.leakage.title}</h2>
        </div>
        <p>{copy.leakage.text}</p>
      </div>
      <div class="pulse-card-grid pulse-card-grid--four">
        {copy.leakage.cards.map((card) => (
          <article class="glass-panel pulse-info-card">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
      <p class="pulse-section-note">{copy.leakage.closing}</p>
    </section>

    <section class="section pulse-content-section" aria-labelledby="pulse-connects-title">
      <div class="section-header">
        <div>
          <p class="eyebrow">{copy.connects.eyebrow}</p>
          <h2 id="pulse-connects-title">{copy.connects.title}</h2>
        </div>
        <p>{copy.connects.text}</p>
      </div>
      <div class="pulse-flow">
        {copy.connects.flow.map((item) => (
          <article>
            <strong>{item.title}</strong>
            <span>{item.text}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="section pulse-content-section" aria-labelledby="pulse-website-title">
      <div class="section-header">
        <div>
          <p class="eyebrow">{copy.website.eyebrow}</p>
          <h2 id="pulse-website-title">{copy.website.title}</h2>
        </div>
        <p>{copy.website.text}</p>
      </div>
      <div class="pulse-card-grid">
        {copy.website.cards.map((card) => (
          <article class="glass-panel pulse-info-card">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section pulse-content-section" aria-labelledby="pulse-days-title">
      <div class="section-header">
        <div>
          <p class="eyebrow">{copy.first90.eyebrow}</p>
          <h2 id="pulse-days-title">{copy.first90.title}</h2>
        </div>
        <p>{copy.first90.text}</p>
      </div>
      <div class="pulse-timeline">
        {copy.first90.steps.map((step, index) => (
          <article class="glass-panel pulse-step">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <small>{step.label}</small>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </article>
        ))}
      </div>
      <p class="pulse-section-note pulse-section-note--accent">{copy.first90.effect}</p>
    </section>

    <section class="section pulse-content-section" aria-labelledby="pulse-boundaries-title">
      <div class="section-header">
        <div>
          <p class="eyebrow">{copy.boundaries.eyebrow}</p>
          <h2 id="pulse-boundaries-title">{copy.boundaries.title}</h2>
        </div>
        <p>{copy.boundaries.text}</p>
      </div>
      <div class="pulse-boundaries">
        <article class="glass-panel">
          <h3>{copy.boundaries.coreTitle}</h3>
          <ul>
            {copy.boundaries.core.map((item) => <li>{item}</li>)}
          </ul>
        </article>
        <article class="glass-panel">
          <h3>{copy.boundaries.separateTitle}</h3>
          <ul>
            {copy.boundaries.separate.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      </div>
      <p class="pulse-section-note">{copy.boundaries.note}</p>
    </section>

    <section class="section pulse-content-section" aria-labelledby="pulse-commercial-title">
      <div class="section-header">
        <div>
          <p class="eyebrow">{copy.commercial.eyebrow}</p>
          <h2 id="pulse-commercial-title">{copy.commercial.title}</h2>
        </div>
        <p>{copy.commercial.text}</p>
      </div>
      <div class="pulse-card-grid pulse-card-grid--four">
        {copy.commercial.cards.map((card) => (
          <article class="glass-panel pulse-info-card">
            <h3>{card.title}</h3>
            <p>{card.text}</p>
          </article>
        ))}
      </div>
      <p class="pulse-section-note">{copy.commercial.conclusion}</p>
    </section>

    <section class="section split-panel pulse-contact-section" id="pulse-contact">
      <form
        class="glass-panel pulse-contact-form"
        method="post"
        action="/api/start-project"
        data-track-source
        data-conversion-form={formVariant}
        data-sending-label={copy.form.sending}
        data-sending-status={copy.form.status}
        data-validation-status={copy.form.validation}
      >
        <input type="hidden" name="source_path" value={sourcePath} />
        <input type="hidden" name="landing_page" value={sourcePath} />
        <input type="hidden" name="landing_offer" value="alfa-pulse" />
        <input type="hidden" name="form_variant" value={formVariant} />
        <input type="hidden" name="locale" value={locale} />
        <input type="hidden" name="referrer" />
        <input type="hidden" name="lead_channel" />
        <input type="hidden" name="partner_ref" />
        <input type="hidden" name="project_type" value={copy.form.projectType} />
        <input type="hidden" name="desired_output" value={copy.form.desiredOutput} />
        <input type="hidden" name="desired_result" value={copy.form.desiredResult} />
        <input type="hidden" name="integrations" value={copy.form.integrations} />
        <input type="hidden" name="utm_source" />
        <input type="hidden" name="utm_medium" />
        <input type="hidden" name="utm_campaign" />
        <input type="hidden" name="utm_term" />
        <input type="hidden" name="utm_content" />
        <div class="spam-field" aria-hidden="true">
          <label for="pulse-company-website">{copy.form.honeypot}</label>
          <input id="pulse-company-website" name="company_website" tabindex="-1" autocomplete="off" />
        </div>

        <div class="pulse-contact-form__head">
          <p class="eyebrow">{copy.form.eyebrow}</p>
          <h2>{copy.form.title}</h2>
          <p>{copy.form.text}</p>
        </div>

        <div class="form-grid pulse-form-grid">
          <div class="field">
            <label for="pulse-name">{copy.form.name}</label>
            <input id="pulse-name" name="name" autocomplete="name" required />
          </div>
          <div class="field">
            <label for="pulse-email">{copy.form.email}</label>
            <input id="pulse-email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="field full">
            <label for="pulse-company">{copy.form.company}</label>
            <input id="pulse-company" name="company" autocomplete="organization" />
          </div>
          <div class="field full">
            <label for="pulse-problem">{copy.form.problem}</label>
            <textarea id="pulse-problem" name="business_problem" required></textarea>
          </div>
          <div class="field full">
            <label for="pulse-contact-details">{copy.form.contact}</label>
            <textarea id="pulse-contact-details" name="contact_details"></textarea>
          </div>
        </div>

        <TurnstileField />
        <div class="section-actions">
          <button class="button primary" type="submit">{copy.form.submit}</button>
          <a class="button secondary" href={copy.pdf} download>{copy.downloadCta}</a>
        </div>
        <ContactChannels locale={locale} />
        <p class="form-status" data-form-status aria-live="polite"></p>
      </form>

      <aside class="glass-panel pulse-download-panel">
        <p class="eyebrow">{copy.pdfLabel}</p>
        <h2>{copy.downloadCta}</h2>
        <p>{copy.metaDescription}</p>
        <div class="section-actions">
          <a class="button primary" href={copy.pdf} download>{copy.downloadCta}</a>
          <a class="button secondary" href={copy.pdf} target="_blank" rel="noreferrer">{copy.openPdf}</a>
        </div>
      </aside>
    </section>
  </div>

  <script is:inline>
    (() => {
      const params = new URLSearchParams(window.location.search);
      const aliases = {
        landing_page: ["landing_page", "lp"],
        landing_offer: ["landing_offer", "offer"],
        partner_ref: ["partner_ref", "partner", "ref", "affiliate", "affiliate_id"],
        utm_source: ["utm_source"],
        utm_medium: ["utm_medium"],
        utm_campaign: ["utm_campaign"],
        utm_term: ["utm_term"],
        utm_content: ["utm_content"]
      };
      const firstParam = (keys) => keys.map((key) => params.get(key)).find(Boolean) || "";
      const inferLeadChannel = () => {
        if (params.get("lead_channel")) return params.get("lead_channel");
        if (firstParam(aliases.partner_ref)) return "partner";
        const medium = (params.get("utm_medium") || "").toLowerCase();
        if (["cpc", "ppc", "paid", "paid-search", "paid-social", "display"].includes(medium)) return "paid";
        if (params.get("utm_source")) return "campaign";
        if (document.referrer) return "referral";
        return "direct";
      };

      document.querySelectorAll("form[data-track-source]").forEach((form) => {
        const source = form.querySelector("[name='source_path']");
        if (source) source.value = `${window.location.pathname}${window.location.search}`;
        const referrer = form.querySelector("[name='referrer']");
        if (referrer) referrer.value = document.referrer || "";
        const leadChannel = form.querySelector("[name='lead_channel']");
        if (leadChannel) leadChannel.value = inferLeadChannel();

        Object.entries(aliases).forEach(([name, keys]) => {
          const input = form.querySelector(`[name='${name}']`);
          if (!input) return;
          const value = firstParam(keys);
          if (value) input.value = value;
          if (name === "landing_page" && !input.value) input.value = window.location.pathname;
        });
      });
    })();
  </script>
</Layout>

<style>
  .pulse-page,
  .pulse-page * {
    box-sizing: border-box;
    min-width: 0;
  }

  .pulse-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.46fr);
    gap: clamp(22px, 4vw, 52px);
    align-items: end;
    padding: clamp(26px, 5vw, 62px);
    overflow: hidden;
    border: 1px solid rgba(216, 251, 255, 0.16);
    border-radius: 4px;
    background:
      linear-gradient(rgba(216, 251, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(216, 251, 255, 0.045) 1px, transparent 1px),
      linear-gradient(135deg, rgba(11, 54, 102, 0.66), rgba(3, 18, 42, 0.78));
    background-size: 58px 58px, 58px 58px, auto;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1), 0 28px 72px rgba(0, 12, 34, 0.32);
  }

  .pulse-hero__copy {
    max-width: 920px;
  }

  .pulse-hero h1 {
    max-width: 900px;
    margin-bottom: 20px;
    font-size: clamp(42px, 6.4vw, 86px);
    line-height: 0.98;
  }

  .pulse-hero__lead {
    max-width: 780px;
    margin: 0 0 26px;
    color: rgba(255, 255, 255, 0.84);
    font-size: clamp(17px, 1.6vw, 22px);
    line-height: 1.5;
  }

  .pulse-document-card,
  .pulse-download-panel,
  .pulse-contact-form,
  .pulse-boundaries .glass-panel,
  .pulse-info-card,
  .pulse-step {
    border: 1px solid rgba(162, 226, 255, 0.2);
    border-radius: 4px;
    background:
      linear-gradient(135deg, rgba(14, 48, 88, 0.38), rgba(3, 18, 42, 0.44)),
      rgba(4, 18, 42, 0.48);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08), 0 20px 50px -36px rgba(0, 7, 26, 0.62);
  }

  .pulse-document-card {
    overflow: hidden;
  }

  .pulse-document-card__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(216, 251, 255, 0.14);
    color: rgba(255, 255, 255, 0.72);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pulse-document-card__head span {
    line-height: 1.25;
    overflow-wrap: normal;
    hyphens: none;
  }

  .pulse-document-card__head strong {
    min-width: max-content;
    color: #d8fbff;
    white-space: nowrap;
  }

  .pulse-document-card a {
    display: block;
    padding: 14px;
  }

  .pulse-document-card img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    object-position: center top;
    border: 1px solid rgba(216, 251, 255, 0.18);
    border-radius: 3px;
    background: rgba(2, 14, 34, 0.62);
  }

  .pulse-contour {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 0.32fr);
    gap: 14px;
    align-items: stretch;
  }

  .pulse-contour__metrics,
  .pulse-contour__core {
    border: 1px solid rgba(216, 251, 255, 0.14);
    border-radius: 4px;
    background: rgba(3, 20, 46, 0.42);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .pulse-contour__metrics {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 6px;
    padding: 6px;
  }

  .pulse-contour__metrics span {
    min-height: 58px;
    display: grid;
    place-items: center;
    padding: 10px;
    border: 1px solid rgba(216, 251, 255, 0.12);
    border-radius: 3px;
    color: #d8fbff;
    background: rgba(216, 251, 255, 0.06);
    font-size: 12px;
    font-weight: 850;
    text-align: center;
  }

  .pulse-contour__core {
    display: grid;
    align-content: center;
    gap: 6px;
    padding: 18px;
  }

  .pulse-contour__core span,
  .pulse-step small {
    color: rgba(216, 251, 255, 0.74);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pulse-contour__core strong {
    color: #fff;
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.12;
  }

  .pulse-content-section {
    content-visibility: visible;
    contain-intrinsic-size: none;
  }

  .pulse-card-grid,
  .pulse-boundaries,
  .pulse-timeline {
    display: grid;
    gap: 14px;
  }

  .pulse-card-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .pulse-card-grid--four,
  .pulse-timeline {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .pulse-timeline {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .pulse-info-card,
  .pulse-step,
  .pulse-boundaries .glass-panel,
  .pulse-download-panel,
  .pulse-contact-form {
    padding: clamp(18px, 2.4vw, 28px);
  }

  .pulse-info-card h3,
  .pulse-step h3,
  .pulse-boundaries h3 {
    margin-top: 0;
  }

  .pulse-info-card p,
  .pulse-step p,
  .pulse-boundaries li,
  .pulse-download-panel p,
  .pulse-contact-form p {
    color: rgba(235, 249, 255, 0.78);
  }

  .pulse-section-note {
    margin: 16px 0 0;
    padding: 16px 18px;
    border-left: 2px solid rgba(216, 251, 255, 0.42);
    color: rgba(255, 255, 255, 0.82);
    background: rgba(3, 20, 46, 0.36);
  }

  .pulse-section-note--accent {
    border-color: rgba(255, 207, 112, 0.82);
    color: #fff;
  }

  .pulse-flow {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 8px;
    padding: 8px;
    border: 1px solid rgba(216, 251, 255, 0.14);
    border-radius: 4px;
    background: rgba(3, 20, 46, 0.38);
  }

  .pulse-flow article {
    display: grid;
    gap: 8px;
    min-height: 118px;
    align-content: center;
    padding: 16px;
    border: 1px solid rgba(216, 251, 255, 0.14);
    border-radius: 3px;
    background: rgba(216, 251, 255, 0.055);
  }

  .pulse-flow strong {
    color: #fff;
    font-size: 17px;
  }

  .pulse-flow span {
    color: rgba(216, 251, 255, 0.72);
    font-size: 13px;
    line-height: 1.4;
  }

  .pulse-step span {
    display: block;
    margin-bottom: 10px;
    color: rgba(255, 207, 112, 0.92);
    font-size: 22px;
    font-weight: 900;
  }

  .pulse-boundaries {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .pulse-boundaries ul {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 18px;
  }

  .pulse-contact-section {
    align-items: start;
  }

  .pulse-contact-form {
    display: grid;
    gap: 18px;
  }

  .pulse-contact-form__head {
    max-width: 680px;
  }

  .pulse-contact-form__head h2,
  .pulse-download-panel h2 {
    margin-bottom: 10px;
  }

  .pulse-form-grid {
    margin-top: 4px;
  }

  .pulse-download-panel {
    display: grid;
    gap: 16px;
  }

  .pulse-download-panel p {
    margin: 0;
  }

  @media (max-width: 1120px) {
    .pulse-hero,
    .pulse-contour,
    .pulse-contact-section {
      grid-template-columns: 1fr;
    }

    .pulse-card-grid,
    .pulse-card-grid--four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 780px) {
    .pulse-hero {
      padding: 22px 16px;
    }

    .pulse-hero h1 {
      font-size: clamp(36px, 10vw, 48px);
      line-height: 1.04;
    }

    .pulse-contour__metrics,
    .pulse-flow,
    .pulse-card-grid,
    .pulse-card-grid--four,
    .pulse-timeline,
    .pulse-boundaries,
    .pulse-form-grid {
      grid-template-columns: 1fr;
    }

    .pulse-contour__metrics span {
      min-height: 44px;
    }

    .pulse-flow article {
      min-height: 0;
    }
  }
</style>
