---
import PageHero from "@/components/PageHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { collectionHeroVisual } from "@/data/hero";
import { getSolutions, localizePath, translateCopy } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;
const solutions = getSolutions(locale);
const siteUrl = Astro.site ?? new URL("https://alfarank.com");
const pagePath = localizePath("/solutions/", locale);
const pageUrl = new URL(pagePath, siteUrl).toString();
const pageDescription = translateCopy(
  locale,
  "Solution pages connect operational, marketing, content, and data problems to the infrastructure required to solve them."
);

const problemRouteRows = [
  {
    problem: "Slow leads",
    problemText: "Leads leak. Growth stays flat.",
    problemIcon: "lead",
    problemHref: "/solutions/automate-lead-processing/",
    output: "Qualified pipeline",
    outputText: "Better leads. More opportunities.",
    outputIcon: "lead",
    outputHref: "/lp/automate-lead-processing/"
  },
  {
    problem: "Manual content",
    problemText: "Too much time. Not enough output.",
    problemIcon: "content",
    problemHref: "/solutions/generate-more-content/",
    output: "Publish engine",
    outputText: "Content at scale. Always on.",
    outputIcon: "media",
    outputHref: "/lp/ai-content-workflow/"
  },
  {
    problem: "Broken data",
    problemText: "Messy, scattered, unusable.",
    problemIcon: "data",
    problemHref: "/solutions/build-data-monitoring-system/",
    output: "Live dashboards",
    outputText: "Real-time clarity. Smarter decisions.",
    outputIcon: "ranking",
    outputHref: "/capabilities/data-systems-scraping/"
  }
];

const localizedProblemRouteRows = problemRouteRows.map((row) => ({
  ...row,
  problem: translateCopy(locale, row.problem),
  problemText: translateCopy(locale, row.problemText),
  problemHref: localizePath(row.problemHref, locale),
  output: translateCopy(locale, row.output),
  outputText: translateCopy(locale, row.outputText),
  outputHref: localizePath(row.outputHref, locale)
}));
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: translateCopy(locale, "Solutions | AlfaRank"),
    description: pageDescription,
    url: pageUrl,
    inLanguage: locale
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: translateCopy(locale, "AlfaRank solution routes"),
    itemListElement: solutions.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      description: item.summary,
      url: new URL(localizePath(`/solutions/${item.slug}/`, locale), siteUrl).toString()
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "AlfaRank",
        item: new URL(localizePath("/", locale), siteUrl).toString()
      },
      {
        "@type": "ListItem",
        position: 2,
        name: translateCopy(locale, "Solutions"),
        item: pageUrl
      }
    ]
  }
];
---

<Layout
  title={translateCopy(locale, "Solutions | AlfaRank")}
  description={pageDescription}
  locale={locale}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="Solutions"
    title="Business problems translated into working systems."
    text="Solution pages connect operational, marketing, content, and data problems to the infrastructure required to solve them."
    primaryHref="/start-project/"
    primaryLabel="Start a Project"
    locale={locale}
    visual={collectionHeroVisual(solutions, {
      mode: "solutions",
      icon: "flow",
      label: "Solution router",
      state: "Problem routes mapped",
      output: "Business needs translated into operating systems",
      primaryMetric: "Solutions",
      secondaryMetric: "Routing"
    })}
  />

  <section class="section solution-route-map" aria-labelledby="solution-map-title">
    <div class="section-header">
      <div>
        <p class="eyebrow">{translateCopy(locale, "Solution routes")}</p>
        <h2 id="solution-map-title">{translateCopy(locale, "Business pressure routed into system output.")}</h2>
      </div>
      <p>{translateCopy(locale, "Each solution starts from an operational problem and turns it into a path for content, leads, data, products, teams, or growth systems.")}</p>
    </div>

    <div class="system-route-lab">
      <div class="system-route-lab__problems">
        {localizedProblemRouteRows.map((row) => (
          <a class="route-problem-card" href={row.problemHref}>
            <SystemIcon name={row.problemIcon} />
            <div>
              <strong>{row.problem}</strong>
              <p>{row.problemText}</p>
            </div>
          </a>
        ))}
      </div>

      <article class="system-route-lab__core">
        <SystemIcon name="flow" />
        <strong>{translateCopy(locale, "ALFARANK ROUTING ENGINE")}</strong>
        <span>{translateCopy(locale, "Capture. Process. Route. Deliver.")}</span>
        <a href={localizePath("/start-project/", locale)}>{translateCopy(locale, "Scope a route")}</a>
      </article>

      <div class="system-route-lab__outputs">
        {localizedProblemRouteRows.map((row) => (
          <a class="route-output-card" href={row.outputHref}>
            <SystemIcon name={row.outputIcon} />
            <div>
              <strong>{row.output}</strong>
              <p>{row.outputText}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
