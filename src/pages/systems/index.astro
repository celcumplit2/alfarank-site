---
import PageHero from "@/components/PageHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { collectionHeroVisual } from "@/data/hero";
import { getSystems, localizePath, translateCopy } from "@/data/i18n";
import type { Locale } from "@/data/i18n";

type Props = {
  locale?: Locale;
};

const { locale = "en" } = Astro.props;
const systems = getSystems(locale);
const siteUrl = Astro.site ?? new URL("https://alfarank.com");
const pagePath = localizePath("/systems/", locale);
const pageUrl = new URL(pagePath, siteUrl).toString();
const pageDescription = translateCopy(
  locale,
  "This section is structured around systems, modules, workflows, outputs, and implementation logic instead of a generic portfolio grid."
);

const systemSignals = ["Profile", "Modules", "Workflow", "Output", "Scope", "Launch"].map((signal) => translateCopy(locale, signal));
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: translateCopy(locale, "Systems | AlfaRank"),
    description: pageDescription,
    url: pageUrl,
    inLanguage: locale
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: translateCopy(locale, "AlfaRank system profiles"),
    itemListElement: systems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      description: item.summary,
      url: new URL(localizePath(`/systems/${item.slug}/`, locale), siteUrl).toString()
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "AlfaRank",
        item: new URL(localizePath("/", locale), siteUrl).toString()
      },
      {
        "@type": "ListItem",
        position: 2,
        name: translateCopy(locale, "Systems"),
        item: pageUrl
      }
    ]
  }
];
---

<Layout
  title={translateCopy(locale, "Systems | AlfaRank")}
  description={pageDescription}
  locale={locale}
  structuredData={structuredData}
>
  <PageHero
    eyebrow="Systems"
    title="System and project profiles."
    text="This section is structured around systems, modules, workflows, outputs, and implementation logic instead of a generic portfolio grid."
    primaryHref="/start-project/"
    primaryLabel="Start a Project"
    locale={locale}
    visual={collectionHeroVisual(systems, {
      mode: "systems",
      icon: "product",
      label: "System profiles",
      state: "Reusable patterns online",
      output: "Profiles, modules, workflows, outputs, implementation logic",
      primaryMetric: "Profiles",
      secondaryMetric: "Reuse"
    })}
  />

  <section class="section">
    <div class="systems-navigation-console ar-system-block">
      <article class="systems-navigation-console__core ar-system-core">
        <SystemIcon name="product" />
        <span>{translateCopy(locale, "System profile library")}</span>
        <strong>{translateCopy(locale, `${systems.length} reusable patterns`)}</strong>
        <p>{translateCopy(locale, "Each profile shows modules, workflow, output, and how the pattern can become a scoped implementation path.")}</p>
        <a class="systems-navigation-console__cta button secondary" href={localizePath("/start-project/?offer=system-profile-library&amp;landing_page=/systems/", locale)}>{translateCopy(locale, "Scope a system")}</a>
      </article>

      {systems.map((item, index) => (
        <a class:list={["systems-navigation-node", "ar-system-node", `systems-navigation-node--${index + 1}`]} href={localizePath(`/systems/${item.slug}/`, locale)} style={`--ar-level: ${72 + index * 4}%;`}>
          <SystemIcon name={item.icon} />
          <span>{systemSignals[index] ?? "System"}</span>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <b class="ar-metric-bar"></b>
        </a>
      ))}
    </div>
  </section>
</Layout>
