---
import PageHero from "@/components/PageHero.astro";
import SystemIcon from "@/components/SystemIcon.astro";
import Layout from "@/layouts/Layout.astro";
import { aboutHeroVisual } from "@/data/hero";

const operatingPrinciples = [
  {
    title: "Business pressure",
    state: "Input",
    icon: "lens",
    text: "Projects start from the process that needs to become faster, clearer, measurable, or automated."
  },
  {
    title: "System design",
    state: "Map",
    icon: "flow",
    text: "The work becomes interfaces, content models, automations, APIs, data flows, dashboards, and publishing systems."
  },
  {
    title: "Launch output",
    state: "Operate",
    icon: "monitor",
    text: "The first version must make a practical business output visible enough to improve."
  }
];
---

<Layout title="About AlfaRank | Digital Systems Company">
  <PageHero
    eyebrow="About AlfaRank"
    title="Practical system development for business output."
    text="AlfaRank combines marketing logic, engineering, automation, content infrastructure, and data workflows to build digital systems that work inside real business processes."
    primaryHref="/start-project/"
    primaryLabel="Start a Project"
    visual={aboutHeroVisual}
  />

  <section class="section">
    <div class="about-operating-console ar-system-block">
      <article class="about-operating-console__core ar-system-core">
        <SystemIcon name="product" />
        <span>Operating principles</span>
        <strong>Business problem to working system.</strong>
        <p>Projects move through scope, prototype, implementation, integration, launch, and measurement.</p>
        <a class="button secondary" href="/start-project/">Start a project</a>
      </article>

      {operatingPrinciples.map((principle, index) => (
        <article class:list={["about-principle-node", "ar-system-node", `about-principle-node--${index + 1}`]}>
          <SystemIcon name={principle.icon} />
          <span>{principle.state}</span>
          <h3>{principle.title}</h3>
          <p>{principle.text}</p>
        </article>
      ))}

      <div class="about-operating-console__signals ar-signal-strip">
        <span class="ar-signal">Automation-first</span>
        <span class="ar-signal">Marketing + engineering</span>
        <span class="ar-signal">Measurable output</span>
      </div>
    </div>
  </section>
</Layout>
