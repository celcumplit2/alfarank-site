---
import SystemIcon from "@/components/SystemIcon.astro";
import "@/styles/global.css";

const cards = [
  {
    number: "01",
    className: "card-ai",
    icon: "ai",
    title: "AI Automation",
    text: "AI workflows that reduce manual work, accelerate content and data operations, and connect business systems."
  },
  {
    number: "02",
    className: "card-web",
    icon: "web",
    title: "Web Platforms",
    text: "Web platforms, product interfaces, dashboards, portals, MVPs, and operational tools built around workflows."
  },
  {
    number: "03",
    className: "card-content",
    icon: "content",
    title: "Content Infrastructure",
    text: "Search and content systems based on data, templates, publishing workflows, and scalable site architecture."
  },
  {
    number: "04",
    className: "card-data",
    icon: "data",
    title: "Data Systems",
    text: "Data pipelines, scraping, monitoring and analytics systems that turn raw data into clear insights."
  },
  {
    number: "05",
    className: "card-commerce",
    icon: "commerce",
    title: "E-commerce Systems",
    text: "E-commerce infrastructure, catalog management, pricing, integrations and order automation."
  },
  {
    number: "06",
    className: "card-media",
    icon: "media",
    title: "Media Pipelines",
    text: "Video and content generation pipelines that scale production and speed up content delivery."
  },
  {
    number: "07",
    className: "card-api",
    icon: "api",
    title: "API Integrations",
    text: "Secure API integrations and middleware that connect systems, automate processes, and flow data reliably."
  },
  {
    number: "08",
    className: "card-tools",
    icon: "tools",
    title: "Internal Tools",
    text: "Custom internal tools and workflows that streamline operations and empower teams to move faster."
  }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Icon Background Variants | AlfaRank</title>
  </head>
  <body class="variant-board-body">
    <main class="variant-board" aria-label="Icon background variants">
      {cards.map((card) => (
        <article class={`board-card ${card.className}`}>
          <div class="board-card-icon primary-icon" aria-hidden="true">
            <SystemIcon name={card.icon} />
          </div>

          {card.className === "card-api" && (
            <div class="board-card-icon secondary-icon" aria-hidden="true">
              <SystemIcon name="scale" />
            </div>
          )}

          {card.className === "card-tools" && (
            <div class="mesh-layer" aria-hidden="true">
              {["api", "tools", "flow", "monitor", "web", "data"].map((icon) => (
                <div class="mesh-icon">
                  <SystemIcon name={icon} />
                </div>
              ))}
            </div>
          )}

          <div class="board-copy">
            <span class="board-number">{card.number}</span>
            <div>
              <h2>{card.title}</h2>
              <p>{card.text}</p>
            </div>
            <a href="/capabilities/">Learn more <span>→</span></a>
          </div>
        </article>
      ))}
    </main>
  </body>
</html>

<style>
  :global(html) {
    width: 100%;
    min-width: 0;
    min-height: 100%;
    overflow: hidden;
    background: #021328;
  }

  :global(.variant-board-body) {
    width: 100%;
    min-width: 0;
    min-height: 100vh;
    margin: 0;
    overflow: hidden;
    color: #ffffff;
    background:
      radial-gradient(70rem 30rem at 18% -8%, rgba(26, 111, 201, 0.28), transparent 62%),
      radial-gradient(52rem 24rem at 100% 88%, rgba(15, 104, 204, 0.22), transparent 58%),
      linear-gradient(118deg, #020d1f 0%, #031b38 48%, #020d1f 100%);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  :global(astro-dev-toolbar) {
    display: none !important;
  }

  .variant-board {
    position: relative;
    display: grid;
    width: 100vw;
    height: 100vh;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    gap: clamp(18px, 1.45vw, 26px);
    padding: clamp(34px, 2.45vw, 46px) clamp(40px, 2.4vw, 48px);
    isolation: isolate;
  }

  .variant-board::before,
  .variant-board::after {
    content: "";
    position: absolute;
    inset: -10%;
    z-index: -2;
    pointer-events: none;
  }

  .variant-board::before {
    background:
      radial-gradient(95rem 18rem at -4% 9%, transparent 34%, rgba(18, 118, 236, 0.42) 39%, rgba(96, 181, 255, 0.2) 42%, transparent 49%),
      radial-gradient(92rem 18rem at 104% 37%, transparent 36%, rgba(38, 147, 255, 0.44) 41%, rgba(123, 201, 255, 0.18) 45%, transparent 54%),
      radial-gradient(80rem 15rem at 20% 94%, transparent 36%, rgba(15, 112, 230, 0.42) 42%, rgba(97, 184, 255, 0.18) 48%, transparent 58%);
    filter: blur(0.6px);
    opacity: 0.82;
  }

  .variant-board::after {
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(rgba(255, 255, 255, 0.024) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(circle at 50% 50%, #000 0%, transparent 68%);
    opacity: 0.18;
  }

  .board-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(220, 244, 255, 0.42);
    border-radius: 7px;
    background:
      radial-gradient(42rem 22rem at 78% 24%, rgba(73, 155, 230, 0.18), transparent 62%),
      linear-gradient(140deg, rgba(255, 255, 255, 0.095), rgba(255, 255, 255, 0.035)),
      rgba(7, 30, 60, 0.78);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.32),
      inset 0 -1px 18px rgba(6, 37, 92, 0.28),
      0 26px 54px -28px rgba(0, 8, 28, 0.84),
      0 0 28px rgba(69, 154, 255, 0.08);
    backdrop-filter: blur(10px);
  }

  .board-card::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(26rem 18rem at 12% 8%, rgba(255, 255, 255, 0.1), transparent 66%),
      radial-gradient(22rem 16rem at 100% 100%, rgba(82, 177, 255, 0.12), transparent 62%);
    pointer-events: none;
  }

  .board-copy {
    position: relative;
    z-index: 3;
    display: grid;
    height: 100%;
    grid-template-rows: auto 1fr auto;
    padding: clamp(22px, 1.45vw, 28px);
    text-shadow:
      0 1px 1px rgba(0, 10, 35, 0.88),
      0 6px 16px rgba(0, 11, 44, 0.7);
  }

  .board-number {
    display: block;
    color: rgba(255, 255, 255, 0.92);
    font-size: clamp(22px, 1.45vw, 29px);
    font-weight: 850;
    line-height: 1;
  }

  .board-copy > div {
    align-self: end;
    max-width: 76%;
    margin-bottom: clamp(18px, 1.8vw, 32px);
  }

  .board-copy h2 {
    margin: 0 0 10px;
    color: #ffffff;
    font-size: clamp(28px, 2.05vw, 40px);
    line-height: 1.03;
    letter-spacing: 0;
  }

  .board-copy p {
    margin: 0;
    color: rgba(255, 255, 255, 0.93);
    font-size: clamp(15px, 0.98vw, 18px);
    line-height: 1.42;
  }

  .board-copy a {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 12px;
    color: #ffffff;
    font-size: clamp(15px, 0.95vw, 18px);
    font-weight: 620;
  }

  .board-copy a span {
    font-size: 1.45em;
    line-height: 1;
  }

  .board-card-icon,
  .mesh-layer {
    position: absolute;
    z-index: 1;
    pointer-events: none;
  }

  :global(.board-card-icon .system-icon),
  :global(.mesh-icon .system-icon) {
    width: 100%;
    height: 100%;
    margin: 0;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
  }

  :global(.board-card-icon .system-icon::before),
  :global(.board-card-icon .system-icon::after),
  :global(.mesh-icon .system-icon::before),
  :global(.mesh-icon .system-icon::after) {
    opacity: 0;
  }

  :global(.board-card-icon .system-icon svg),
  :global(.mesh-icon .system-icon svg) {
    width: 100%;
    height: 100%;
  }

  :global(.variant-board .board-card-icon .system-icon .icon-glass),
  :global(.variant-board .mesh-icon .system-icon .icon-glass) {
    fill: transparent !important;
    stroke: transparent !important;
    stroke-width: 1 !important;
  }

  :global(.variant-board .board-card-icon .system-icon .icon-glow),
  :global(.variant-board .mesh-icon .system-icon .icon-glow) {
    opacity: 0 !important;
  }

  :global(.variant-board .board-card-icon .system-icon .icon-lines),
  :global(.variant-board .mesh-icon .system-icon .icon-lines) {
    stroke: rgba(84, 165, 255, 0.68) !important;
    stroke-width: 1.25 !important;
    filter:
      drop-shadow(0 0 7px rgba(72, 158, 255, 0.46))
      drop-shadow(0 0 18px rgba(34, 122, 238, 0.22)) !important;
  }

  .card-ai .primary-icon {
    right: -48%;
    bottom: -36%;
    width: 138%;
    height: 138%;
    opacity: 0.48;
  }

  .card-web .primary-icon {
    right: -9%;
    top: -2%;
    width: 126%;
    height: 126%;
    opacity: 0.44;
  }

  .card-content .primary-icon {
    right: -23%;
    top: -12%;
    width: 138%;
    height: 138%;
    opacity: 0.38;
    filter: blur(1px);
  }

  .card-data .primary-icon {
    right: -39%;
    top: -25%;
    width: 160%;
    height: 160%;
    opacity: 0.5;
    transform: rotate(-16deg);
  }

  .card-commerce .primary-icon {
    right: -28%;
    top: -10%;
    width: 136%;
    height: 136%;
    opacity: 0.48;
  }

  .card-media .primary-icon {
    left: -6%;
    top: -8%;
    width: 132%;
    height: 132%;
    opacity: 0.44;
    transform: rotate(-3deg);
  }

  .card-api .primary-icon {
    left: -29%;
    top: -36%;
    width: 112%;
    height: 112%;
    opacity: 0.42;
  }

  .card-api .secondary-icon {
    right: -39%;
    bottom: -38%;
    width: 124%;
    height: 124%;
    opacity: 0.52;
    transform: rotate(-10deg);
  }

  .card-tools .primary-icon {
    display: none;
  }

  .card-tools .mesh-layer {
    inset: -13% -18%;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    opacity: 0.62;
    transform: rotate(0deg);
  }

  .mesh-icon {
    width: 100%;
    height: 100%;
  }

  :global(.variant-board .card-tools .mesh-icon .system-icon .icon-lines) {
    stroke: rgba(58, 143, 235, 0.48) !important;
    stroke-width: 1.05 !important;
  }

  @media (max-width: 1100px) {
    :global(html),
    :global(.variant-board-body) {
      overflow: auto;
    }

    .variant-board {
      height: auto;
      min-height: 100vh;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: minmax(330px, 1fr);
    }
  }

  @media (max-width: 640px) {
    .variant-board {
      grid-template-columns: 1fr;
      padding: 20px;
    }

    .board-card {
      min-height: 330px;
    }
  }
</style>
