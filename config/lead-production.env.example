# Copy to .env.lead.production.local and fill real production values.
# Do not commit the filled file.

# Required: private token for /lead-desk/, /api/lead-report,
# /api/lead-status, and /api/lead-export.
LEAD_REPORT_TOKEN=replace-with-generated-token

# Required: at least one notification route.
# Use webhook:
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_TOKEN=

# Or Telegram:
LEAD_TELEGRAM_BOT_TOKEN=
LEAD_TELEGRAM_CHAT_ID=
LEAD_TELEGRAM_MESSAGE_THREAD_ID=

# Required: at least one public quick contact channel.
PUBLIC_CONTACT_EMAIL=
PUBLIC_CONTACT_TELEGRAM_URL=
PUBLIC_CONTACT_WHATSAPP_URL=

# Required: at least one analytics adapter.
PUBLIC_GTM_ID=
PUBLIC_GA_ID=
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SRC=

# Optional but recommended anti-spam challenge.
# Set both keys together or leave both empty.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional for smoke when Turnstile is enabled.
LEAD_SMOKE_TURNSTILE_TOKEN=
